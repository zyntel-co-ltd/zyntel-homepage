---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Hospital operations, intelligently managed"
  description="Kanta by Zyntel tracks equipment, monitors lab performance, and gives hospital teams the visibility they need — starting free, forever. Built for East Africa."
>
  <Nav />
  <main>

    <!-- Hero -->
    <section class="hero">
      <div class="container hero-inner">
        <div class="hero-content">
          <p class="hero-eyebrow">Kanta by Zyntel</p>
          <h1 class="hero-title">Hospital operations,<br /><span class="hero-hl">intelligently managed.</span></h1>
          <p class="hero-desc">Kanta tracks equipment, monitors lab performance, and gives hospital teams the visibility they need — starting free, forever.</p>
          <div class="hero-actions">
            <a href="#" title="kanta.app — coming soon" class="btn btn-primary">Try Kanta Free →</a>
            <a href="/products" class="btn btn-secondary">See how it works →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Social proof strip -->
    <div class="proof-strip">
      <div class="container">
        <p class="proof-text">Trusted by hospitals in Kampala, Uganda</p>
      </div>
    </div>

    <!-- Kanta feature highlights -->
    <section class="section features-section">
      <div class="container">
        <h2 class="section-title">Everything a hospital operations team needs</h2>
        <p class="section-sub">Three modules. One platform. Real visibility.</p>
        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
            </div>
            <h3>Equipment Tracking</h3>
            <p>QR scan, location, status. Any device, any ward. Know where every asset is and whether it is fit for use.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
            </div>
            <h3>Maintenance Intelligence</h3>
            <p>Automated alerts before equipment fails. Maintenance logs that actually get used. Preventive, not reactive.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <h3>Lab &amp; QC Monitoring</h3>
            <p>TAT tracking. Westgard QC. Multi-department dashboards. Know your performance numbers before an auditor does.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Secondary product: Zyntel Forms -->
    <section class="section forms-section">
      <div class="container">
        <div class="forms-card">
          <div class="forms-card-content">
            <p class="forms-eyebrow">Also from Zyntel</p>
            <h2 class="forms-title">Zyntel Forms</h2>
            <p class="forms-desc">The form builder built for teams. Multi-company org structure, AI generation, unlimited forms free. Replace paper workflows without replacing your team.</p>
            <a href="/products" class="btn btn-secondary forms-cta">Learn more →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- About strip -->
    <section class="section about-strip">
      <div class="container about-strip-inner">
        <div class="about-strip-text">
          <h2 class="about-strip-title">Built in Kampala. Built for East Africa.</h2>
          <p class="about-strip-desc">Zyntel Co. Limited builds operational intelligence software for healthcare and regulated industries. We build for the infrastructure that actually exists — not the infrastructure that would be convenient.</p>
          <a href="/about" class="btn btn-secondary about-cta">About us →</a>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="section final-cta">
      <div class="container final-cta-inner">
        <h2 class="final-cta-title">Start with Kanta — free forever.</h2>
        <p class="final-cta-sub">No credit card. No time limit. Full access to equipment tracking and lab monitoring.</p>
        <a href="#" title="kanta.app — coming soon" class="btn btn-primary">Try Kanta Free</a>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: 9rem 0 6rem;
    background: var(--bg-dark);
    border-bottom: 1px solid var(--border);
  }

  .hero-inner {
    max-width: 720px;
  }

  .hero-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--cyan);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.25rem;
  }

  .hero-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .hero-hl {
    color: var(--cyan);
  }

  .hero-desc {
    font-size: 1.15rem;
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: 540px;
    margin-bottom: 2.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ── Social proof strip ── */
  .proof-strip {
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
  }

  .proof-text {
    font-size: 0.875rem;
    color: var(--text-muted);
    text-align: center;
    font-weight: 500;
  }

  /* ── Features ── */
  .section {
    padding: 6rem 0;
  }

  .section-title {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    text-align: center;
  }

  .section-sub {
    font-size: 1.05rem;
    color: var(--text-muted);
    text-align: center;
    margin-bottom: 3rem;
  }

  .features-section {
    background: var(--bg-dark);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .feature-card:hover {
    border-color: var(--cyan);
    box-shadow: 0 8px 32px var(--card-shadow);
  }

  .feature-icon {
    color: var(--cyan);
    margin-bottom: 1.25rem;
    display: flex;
  }

  .feature-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.6rem;
    letter-spacing: -0.01em;
  }

  .feature-card p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* ── Zyntel Forms card ── */
  .forms-section {
    background: var(--bg-elevated);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .forms-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 3rem;
    max-width: 640px;
  }

  .forms-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .forms-title {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .forms-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }

  /* ── About strip ── */
  .about-strip {
    background: var(--bg-dark);
    border-top: 1px solid var(--border);
  }

  .about-strip-inner {
    max-width: 680px;
  }

  .about-strip-title {
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .about-strip-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.75rem;
  }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--bg-elevated);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .final-cta-inner {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  .final-cta-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--text-primary);
    margin-bottom: 0.6rem;
  }

  .final-cta-sub {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .hero { padding: 7rem 0 4rem; }
    .features-grid { grid-template-columns: 1fr; }
    .forms-card { padding: 2rem; }
  }
</style>
