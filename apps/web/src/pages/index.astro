---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Web Agency — Apps, Websites & Software"
  ogTitle="Zyntel — Digital products built for Africa"
  description="Zyntel is a web agency based in Kampala, Uganda. We build web apps, websites, mobile apps, and custom software for East African businesses."
  jsonLdOrganization={true}
  hideStickyCta={true}
>
  <Nav />
  <main class="ag-page">

    <!-- ── HERO ── -->
    <section class="ag-hero">
      <div class="ag-blob ag-blob--1" aria-hidden="true"></div>
      <div class="ag-blob ag-blob--2" aria-hidden="true"></div>
      <div class="ag-wrap">
        <div class="ag-eyebrow">
          <svg class="ag-eyebrow-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.09 6.26L21 10l-6.91 1.74L12 18l-2.09-5.26L3 11l6.91-1.74z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
          Web Agency · Kampala, Uganda
        </div>
        <h1 class="ag-hero-title">
          We build digital products<br>
          <span class="ag-grad-text">that move Africa forward.</span>
        </h1>
        <p class="ag-hero-sub">
          Apps, websites, and custom software engineered for East African businesses — fast, reliable, and built to last.
        </p>
        <div class="ag-hero-actions">
          <a href="/contact" class="ag-btn ag-btn--dark">Start your project</a>
          <a href="/services" class="ag-btn ag-btn--white">Explore services →</a>
        </div>
        <div class="ag-stats-row">
          <div class="ag-stat">
            <span class="ag-stat-num">25+</span>
            <span class="ag-stat-label">Projects delivered</span>
          </div>
          <div class="ag-stat-div" aria-hidden="true"></div>
          <div class="ag-stat">
            <span class="ag-stat-num">15+</span>
            <span class="ag-stat-label">Clients served</span>
          </div>
          <div class="ag-stat-div" aria-hidden="true"></div>
          <div class="ag-stat">
            <span class="ag-stat-num">3+</span>
            <span class="ag-stat-label">Years building</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── SERVICES ── -->
    <section class="ag-section ag-section--alt" id="services">
      <div class="ag-wrap">
        <p class="ag-section-eyebrow">What we do</p>
        <h2 class="ag-section-title">End-to-end digital<br>product development</h2>
        <p class="ag-section-sub">From first idea to live product — design, engineering, and delivery under one roof.</p>
        <div class="ag-services-grid">

          <article class="ag-service-card">
            <div class="ag-service-icon ag-service-icon--v">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.75"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>
            </div>
            <h3>Web Applications</h3>
            <p>Powerful, scalable web apps with great UX. Dashboards, platforms, and SaaS products built on modern stacks.</p>
            <a href="/services#web-apps" class="ag-card-link">Learn more →</a>
          </article>

          <article class="ag-service-card">
            <div class="ag-service-icon ag-service-icon--c">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.75"/><path d="M2 12h20M12 2a15 15 0 010 20M12 2a15 15 0 000 20" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>
            </div>
            <h3>Websites & Landing Pages</h3>
            <p>Fast, SEO-friendly websites that convert. Corporate sites, portfolios, and marketing pages done right.</p>
            <a href="/services#websites" class="ag-card-link">Learn more →</a>
          </article>

          <article class="ag-service-card">
            <div class="ag-service-icon ag-service-icon--v">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="5" y="2" width="14" height="20" rx="2" stroke="currentColor" stroke-width="1.75"/><circle cx="12" cy="17" r="1" fill="currentColor"/></svg>
            </div>
            <h3>Mobile Apps</h3>
            <p>Cross-platform mobile applications for iOS and Android, built for East African connectivity realities.</p>
            <a href="/services#mobile" class="ag-card-link">Learn more →</a>
          </article>

          <article class="ag-service-card">
            <div class="ag-service-icon ag-service-icon--c">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M10 20l4-16M4 9l-3 3 3 3M20 9l3 3-3 3" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>Custom Software & APIs</h3>
            <p>Bespoke backend systems, REST APIs, integrations, and data pipelines tailored to your operations.</p>
            <a href="/services#custom" class="ag-card-link">Learn more →</a>
          </article>

        </div>
      </div>
    </section>

    <!-- ── ZYNTFORMS SPOTLIGHT ── -->
    <section class="ag-section">
      <div class="ag-wrap">
        <div class="ag-zf-card">
          <div class="ag-zf-glow" aria-hidden="true"></div>
          <div>
            <div class="ag-zf-eyebrow">
              <span class="ag-zf-dot" aria-hidden="true"></span>
              New product
            </div>
            <h2 class="ag-zf-title">
              <span class="ag-zf-brand">ZyntForms</span> —<br>
              built for field teams.
            </h2>
            <p class="ag-zf-desc">
              Enterprise-grade data collection that works offline. ZyntForms lets remote teams capture, validate, and sync data without reliable internet — with AI-assisted field intelligence built in.
            </p>
            <ul class="ag-zf-features">
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/></svg>
                Offline-first — zero data loss without Wi-Fi
              </li>
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/></svg>
                AI-powered validation and smart suggestions
              </li>
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/></svg>
                Instant sync when connectivity returns
              </li>
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/></svg>
                Built for NGOs, researchers, and field operations
              </li>
            </ul>
            <div class="ag-zf-actions">
              <a href="https://zyntforms.com" target="_blank" rel="noopener noreferrer" class="ag-btn ag-btn--violet">Explore ZyntForms ↗</a>
              <a href="/contact" class="ag-btn ag-btn--zf">Get early access</a>
            </div>
          </div>
          <div aria-hidden="true">
            <div class="ag-zf-mock">
              <div class="ag-zf-mock-topbar">
                <div class="ag-zf-mock-dots"><span></span><span></span><span></span></div>
                <span class="ag-zf-mock-title">Field Survey</span>
              </div>
              <div class="ag-zf-mock-body">
                <div class="ag-zf-mock-label">Respondent name</div>
                <div class="ag-zf-mock-field"></div>
                <div class="ag-zf-mock-label">Location</div>
                <div class="ag-zf-mock-field ag-zf-mock-field--sm"></div>
                <div class="ag-zf-mock-label">Response type</div>
                <div class="ag-zf-mock-pills">
                  <span class="active">Option A</span>
                  <span>Option B</span>
                  <span>Option C</span>
                </div>
                <div class="ag-zf-mock-submit">Submit response</div>
              </div>
              <div class="ag-zf-sync-badge">
                <span class="ag-sync-dot"></span> Syncing 3 of 12…
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── PROCESS ── -->
    <section class="ag-section ag-section--alt">
      <div class="ag-wrap">
        <p class="ag-section-eyebrow">How we work</p>
        <h2 class="ag-section-title">From idea to live product<br>in three clear stages</h2>
        <div class="ag-process-grid">
          <div class="ag-process-step">
            <div class="ag-process-num">01</div>
            <h3>Discover</h3>
            <p>We learn your business, users, and goals. Then we map the right technology to the right problem — no jargon, just clarity.</p>
          </div>
          <div class="ag-process-arrow" aria-hidden="true">→</div>
          <div class="ag-process-step">
            <div class="ag-process-num">02</div>
            <h3>Design & Build</h3>
            <p>UI/UX design, rapid prototyping, then full-stack development with regular milestone check-ins and your feedback built in.</p>
          </div>
          <div class="ag-process-arrow" aria-hidden="true">→</div>
          <div class="ag-process-step">
            <div class="ag-process-num">03</div>
            <h3>Launch & Grow</h3>
            <p>We deploy, test, and remain your technical partner for maintenance, iterations, and scaling as your business grows.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="ag-section">
      <div class="ag-wrap">
        <div class="ag-cta-card">
          <div class="ag-cta-blob ag-cta-blob--v" aria-hidden="true"></div>
          <div class="ag-cta-blob ag-cta-blob--p" aria-hidden="true"></div>
          <p class="ag-cta-eyebrow">Ready when you are</p>
          <h2 class="ag-cta-title">Let's build something<br><span class="ag-grad-text">great together.</span></h2>
          <p class="ag-cta-sub">Tell us about your project and we'll get back to you within one business day.</p>
          <div class="ag-cta-actions">
            <a href="/contact" class="ag-btn ag-btn--violet">Start a project</a>
            <a href="mailto:contact@zyntel.net" class="ag-btn ag-btn--white-outline">contact@zyntel.net</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
