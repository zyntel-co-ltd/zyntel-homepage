---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    id: 'web-apps',
    num: '01',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.75"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>`,
    accent: 'violet',
    image: '/images/services/web-apps-hero.jpg',
    title: 'Web Application Development',
    tagline: 'Powerful platforms built to scale',
    description: 'We build complex web applications from scratch — dashboards, SaaS platforms, internal tools, and data-heavy systems. Every app is engineered for performance, security, and built to grow with your business from day one.',
    description2: 'Whether you need a customer portal, an operations dashboard, or a full SaaS product, we handle the complete stack — frontend, backend, databases, APIs, and cloud deployment. You own the product vision; we own the engineering.',
    bestFor: 'SaaS startups · Internal tools · Data platforms · Customer portals',
    timeline: '6–12 weeks',
    features: [
      'React / Next.js / Astro frontends',
      'Node.js, Python & Go backends',
      'PostgreSQL, MongoDB & Redis',
      'REST & GraphQL APIs',
      'Role-based authentication & access control',
      'Cloud deployment (AWS, Railway, Vercel)',
    ],
  },
  {
    id: 'websites',
    num: '02',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.75"/><path d="M2 12h20M12 2a15 15 0 010 20M12 2a15 15 0 000 20" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>`,
    accent: 'cyan',
    image: '/images/services/websites-hero.jpg',
    title: 'Websites & Landing Pages',
    tagline: 'Fast, beautiful, and built to convert',
    description: 'Your website is the first impression most clients will ever have of your business. We design and build websites that make that impression count — fast, responsive, and crafted to turn visitors into clients.',
    description2: 'From corporate sites to high-converting product landing pages, every site we build is SEO-optimised from the first line of code, scores green on Core Web Vitals, and looks sharp on every screen size.',
    bestFor: 'Businesses · NGOs · Product launches · Agencies & studios',
    timeline: '2–5 weeks',
    features: [
      'Corporate & portfolio sites',
      'Marketing & product landing pages',
      'CMS integration (Sanity, Contentful)',
      'SEO-first architecture & metadata',
      'Core Web Vitals optimisation',
      'Custom animations & micro-interactions',
    ],
  },
  {
    id: 'mobile',
    num: '03',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none"><rect x="5" y="2" width="14" height="20" rx="2" stroke="currentColor" stroke-width="1.75"/><circle cx="12" cy="17" r="1" fill="currentColor"/></svg>`,
    accent: 'violet',
    image: '/images/services/mobile-hero.jpg',
    title: 'Mobile App Development',
    tagline: "Built for Africa's connectivity realities",
    description: 'Cross-platform iOS and Android apps built with React Native. We build mobile experiences that work reliably on the devices and networks your users actually have — including offline-first apps for areas with unreliable connectivity.',
    description2: 'We have shipped offline-capable field collection apps, B2B management tools, and consumer apps. Every mobile app includes proper background sync, push notifications, and a smooth submission path through the App Store and Google Play.',
    bestFor: 'Field teams · Healthcare · Logistics · Consumer apps',
    timeline: '8–14 weeks',
    features: [
      'React Native for iOS & Android',
      'Offline-first architecture with sync',
      'Push notifications & background tasks',
      'Biometric & OTP authentication',
      'App Store & Google Play submission',
      'Low-bandwidth optimisation',
    ],
  },
  {
    id: 'custom',
    num: '04',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none"><path d="M10 20l4-16M4 9l-3 3 3 3M20 9l3 3-3 3" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    accent: 'cyan',
    image: '/images/services/custom-hero.jpg',
    title: 'Custom Software & APIs',
    tagline: 'Bespoke systems for complex problems',
    description: "When off-the-shelf software doesn't fit — or the integration you need doesn't exist yet — we build it. Custom backend systems, third-party integrations, automated data pipelines, and APIs that connect your entire stack together.",
    description2: 'We have built integrations with local payment gateways (MTN MoMo, Airtel Money), HMIS systems, WhatsApp Business API, and M-Pesa. If your business runs on data flows, we can automate, connect, and scale them.',
    bestFor: 'Fintech · Healthcare systems · Logistics · Enterprise automation',
    timeline: '4–10 weeks',
    features: [
      'Custom REST & GraphQL APIs',
      'Third-party & payment integrations',
      'Automated data pipelines & ETL',
      'Webhook & event-driven systems',
      'Legacy system modernisation',
      'Internal tooling & workflow automation',
    ],
  },
  {
    id: 'design',
    num: '05',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    accent: 'violet',
    image: '/images/services/design-hero.jpg',
    title: 'UI/UX Design',
    tagline: 'Interfaces people actually enjoy using',
    description: 'Great design is invisible — users simply feel it working. We design intuitive interfaces that reduce friction, guide users naturally through complex flows, and make products feel effortless to use.',
    description2: 'We do research-driven design: user journey mapping, wireframing, high-fidelity Figma prototypes, and usability testing. Every design decision is grounded in how real users think and behave, not just what looks good in a mockup.',
    bestFor: 'Product teams · Founders · Existing products needing a redesign',
    timeline: '2–4 weeks',
    features: [
      'User research & journey mapping',
      'Wireframing & rapid prototyping',
      'High-fidelity UI design in Figma',
      'Design systems & component libraries',
      'Accessibility (WCAG 2.1 AA compliant)',
      'Usability testing & iteration rounds',
    ],
  },
  {
    id: 'support',
    num: '06',
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/></svg>`,
    accent: 'cyan',
    image: '/images/services/maintenance-hero.jpg',
    title: 'Maintenance & Support',
    tagline: 'A long-term partner, not a one-off vendor',
    description: "We don't disappear after launch. Our ongoing support retainers keep your product secure, performant, and up-to-date — so you can focus on running your business while we keep the tech running smoothly.",
    description2: 'Every retainer includes a dedicated response SLA, monthly performance reports, proactive security patching, and a clear process for requesting feature additions or improvements. One monthly rate. No surprises.',
    bestFor: 'Live products · Growing teams · Clients without in-house devs',
    timeline: 'Ongoing monthly',
    features: [
      'Monthly maintenance retainers',
      'Uptime & performance monitoring',
      'Security patches & dependency updates',
      'Feature additions & improvements',
      'Priority response SLA (< 4 hours)',
      'Monthly technical health reports',
    ],
  },
];

const advantages = [
  {
    accent: 'violet',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
    title: 'Africa-first engineering',
    body: "We don't adapt Western solutions — we build from scratch for low bandwidth, diverse devices, local payment systems, and the operational realities of East African businesses.",
  },
  {
    accent: 'pink',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: 'One team, full ownership',
    body: 'Design, frontend, backend, deployment — one team owns all of it. No hand-offs between agencies, no finger-pointing, no coordination overhead. Accountable from brief to live.',
  },
  {
    accent: 'violet',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>`,
    title: 'Fixed-price transparency',
    body: 'We scope projects thoroughly upfront and deliver a fixed-price proposal — clear deliverables, clear cost, no billable-hour anxiety. You always know exactly what you are getting and what it costs.',
  },
  {
    accent: 'pink',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
    title: 'Long-term partnership',
    body: "Our best client relationships span years. We stay invested in the products we build — maintenance retainers, feature roadmaps, and the technical guidance to keep growing as your business does.",
  },
];

const techStack = [
  'React', 'Next.js', 'Astro', 'TypeScript',
  'Node.js', 'Python', 'Go', 'PostgreSQL',
  'MongoDB', 'Redis', 'React Native', 'Figma',
  'AWS', 'Railway', 'Vercel', 'Sanity CMS',
  'REST APIs', 'GraphQL', 'Docker', 'MTN MoMo',
];
---
<BaseLayout
  title="Services — Web Apps, Websites & Mobile"
  description="Zyntel builds web applications, websites, mobile apps, and custom software for East African businesses. Based in Kampala, Uganda."
  hideStickyCta={true}
>
  <Nav />
  <main class="ag-page">

    <!-- ── HERO ── -->
    <div class="ag-hero-wrapper">
      <section class="ag-hero ag-hero--compact">
        <div class="ag-blob ag-blob--1" aria-hidden="true"></div>
        <div class="ag-blob ag-blob--2" aria-hidden="true"></div>
        <div class="ag-wrap">
          <h1 class="ag-hero-title">
            Everything you need<br>
            <span class="ag-grad-text">to ship great software.</span>
          </h1>
          <p class="ag-hero-sub">
            Six services. One team. No hand-offs. We handle the complete journey — from first wireframe to live product — and stay your partner long after launch.
          </p>
          <div class="ag-hero-actions">
            <a href="/contact" class="ag-btn ag-btn--dark">Start a project</a>
            <a href="#web-apps" class="ag-btn ag-btn--white">Explore services ↓</a>
          </div>
        </div>
      </section>
    </div>

    <!-- ── SERVICES NAV STRIP ── -->
    <nav class="svc-index" aria-label="Services navigation">
      <div class="svc-index-inner">
        {services.map((svc) => (
          <a href={`#${svc.id}`} class="svc-index-item" data-svc={svc.id}>
            <span class="svc-index-num">{svc.num}</span>
            <span class="svc-index-label">{svc.title}</span>
          </a>
        ))}
      </div>
    </nav>

    <!-- ── SERVICES SECTIONS ── -->
    <div class="ag-section-pill" id="services-pill">
      <section class="ag-section svc-section">
        <div class="ag-wrap">

          <div class="svc-rows">
            {services.map((svc, i) => (
              <article class:list={["svc-row", i % 2 !== 0 && "svc-row--flip"]} id={svc.id}>

                <!-- Ghost number -->
                <div class="svc-row-left" aria-hidden="true">
                  <span class="svc-row-num">{svc.num}</span>
                </div>

                <!-- Main body: text | image split -->
                <div class="svc-row-body">

                  <!-- Text column -->
                  <div class="svc-row-text">
                    <div class="svc-row-header">
                      <div class={`svc-icon svc-icon--${svc.accent}`} set:html={svc.icon} aria-hidden="true" />
                      <div>
                        <p class="svc-row-tagline">{svc.tagline}</p>
                        <h2 class="svc-row-title">{svc.title}</h2>
                      </div>
                    </div>

                    <p class="svc-row-desc">{svc.description}</p>
                    <p class="svc-row-desc">{svc.description2}</p>

                    <div class="svc-meta-row">
                      <div class="svc-meta-item">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        <span>{svc.timeline}</span>
                      </div>
                      <div class="svc-meta-divider" aria-hidden="true"></div>
                      <div class="svc-meta-item">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                        <span class="svc-meta-best">{svc.bestFor}</span>
                      </div>
                    </div>

                    <!-- Feature list -->
                    <ul class="svc-feat-list" aria-label="Included in this service">
                      {svc.features.map((f) => (
                        <li>
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/></svg>
                          {f}
                        </li>
                      ))}
                    </ul>

                    <a href="/contact" class="svc-cta-link">
                      Start this service
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                  </div>

                  <!-- Image column -->
                  <div class="svc-row-img-wrap">
                    <img
                      src={svc.image}
                      alt={svc.title}
                      class="svc-row-img"
                      loading="lazy"
                      decoding="async"
                    />
                    <div class="svc-row-img-overlay" aria-hidden="true"></div>
                  </div>

                </div><!-- end .svc-row-body -->
              </article>
            ))}
          </div>

        </div>
      </section>
    </div>

    <!-- ── WHY ZYNTEL ── -->
    <section class="ag-section--free why-section" id="why-zyntel">
      <div class="ag-wrap">
        <div class="ag-label-pill">
          <span class="ag-label-pill-dot" aria-hidden="true"></span>
          Why Zyntel
        </div>
        <h2 class="ag-section-title">Four reasons clients<br>choose us and stay.</h2>
        <p class="ag-section-sub">We're not the cheapest, and we don't try to be. We're the team you call when quality, reliability, and partnership matter.</p>

        <div class="why-grid">
          {advantages.map((adv) => (
            <article class={`why-card why-card--${adv.accent}`}>
              <div class={`why-icon why-icon--${adv.accent}`} set:html={adv.icon} aria-hidden="true" />
              <h3 class="why-card-title">{adv.title}</h3>
              <p class="why-card-body">{adv.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ── TECH STACK STRIP ── -->
    <section class="ag-section--naked stack-strip">
      <div class="ag-wrap">
        <p class="stack-label">Technologies we work with</p>
        <div class="stack-tags">
          {techStack.map((tech) => (
            <span class="stack-tag">{tech}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <div class="ag-cta-light">
      <div class="ag-cta-light-mark" aria-hidden="true">Zyntel</div>
      <div class="ag-cta-light-icon" aria-hidden="true">
        <svg width="36" height="36" viewBox="0 0 1024 1024" fill="none" xmlns="http://www.w3.org/2000/svg">
          <text x="80" y="700" font-family="'Geist Sans','Segoe UI',system-ui,sans-serif" font-weight="700" font-size="1200" fill="#ffffff">}</text>
        </svg>
      </div>
      <h2 class="ag-cta-light-title">Ready to start<br>your project?</h2>
      <p class="ag-cta-light-sub">Tell us what you're building and we'll put together a plan. No commitment required — just a conversation.</p>
      <div class="ag-cta-light-links">
        <a href="/contact" class="ag-cta-light-pill">
          Get in touch
          <span class="ag-cta-light-pill-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
        <a href="mailto:contact@zyntel.net" class="ag-cta-light-pill">
          contact@zyntel.net
          <span class="ag-cta-light-pill-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
        </a>
        <a href="https://x.com/ZyntelTech" target="_blank" rel="noopener noreferrer" class="ag-cta-light-pill">
          Twitter / X
          <span class="ag-cta-light-pill-icon" aria-hidden="true">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.26 5.632 5.904-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </span>
        </a>
        <a href="https://www.linkedin.com/company/zynteltech" target="_blank" rel="noopener noreferrer" class="ag-cta-light-pill">
          LinkedIn
          <span class="ag-cta-light-pill-icon" aria-hidden="true">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </span>
        </a>
      </div>
    </div>

  </main>
  <Footer />
</BaseLayout>

<script>
  // ── Services nav: sticky active-state highlight on scroll ──
  const navItems = document.querySelectorAll<HTMLElement>('.svc-index-item');
  const sections = document.querySelectorAll<HTMLElement>('.svc-row[id]');

  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        navItems.forEach(a => {
          a.classList.toggle('is-active', a.dataset.svc === id);
        });
      }
    });
  }, { rootMargin: '-40% 0px -50% 0px' });

  sections.forEach(s => io.observe(s));

  // ── Service rows: staggered scroll reveal ──
  const rows = document.querySelectorAll<HTMLElement>('.svc-row');
  const revealIo = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('svc-revealed');
        revealIo.unobserve(entry.target);
      }
    });
  }, { threshold: 0.07 });
  rows.forEach(r => revealIo.observe(r));

  // ── Why cards: staggered reveal ──
  const whyCards = Array.from(document.querySelectorAll<HTMLElement>('.why-card'));
  const whyIo = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const i = whyCards.indexOf(el);
      setTimeout(() => el.classList.add('why-revealed'), i * 110);
      whyIo.unobserve(el);
    });
  }, { threshold: 0.1 });
  whyCards.forEach(c => whyIo.observe(c));
</script>

<style>

/* ─── Services nav strip ─── */
.svc-index {
  background: #ffffff;
  border-bottom: 1px solid rgba(0, 0, 0, 0.07);
  overflow-x: auto;
  scrollbar-width: none;
  position: sticky;
  top: 0;
  z-index: 20;
  box-shadow: 0 1px 0 rgba(0,0,0,0.05);
}
.svc-index::-webkit-scrollbar { display: none; }

.svc-index-inner {
  display: flex;
  align-items: stretch;
  min-width: max-content;
  max-width: 80rem;
  margin-inline: auto;
  padding-inline: clamp(1.25rem, 5vw, 3.5rem);
}

.svc-index-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.85rem 1.25rem;
  text-decoration: none;
  color: var(--ag-muted);
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: -0.01em;
  border-right: 1px solid rgba(0, 0, 0, 0.06);
  transition: color 0.2s, background 0.2s;
  white-space: nowrap;
  position: relative;
}

.svc-index-item::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, #7c3aed, #4f46e5);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.25s ease;
}

.svc-index-item:hover,
.svc-index-item.is-active {
  color: #7c3aed;
  background: rgba(124, 58, 237, 0.03);
}

.svc-index-item:hover::after,
.svc-index-item.is-active::after {
  transform: scaleX(1);
}

.svc-index-num {
  font-size: 0.63rem;
  font-weight: 800;
  color: #7c3aed;
  letter-spacing: 0.06em;
  opacity: 0.6;
  transition: opacity 0.2s;
}
.svc-index-item:hover .svc-index-num,
.svc-index-item.is-active .svc-index-num { opacity: 1; }

/* ─── Service section ─── */
.svc-section {
  background: #ffffff;
  padding-top: 0;
  padding-bottom: 0;
}

/* ─── Service rows ─── */
.svc-rows {
  border-top: 1px solid rgba(0, 0, 0, 0.07);
}

.svc-row {
  display: grid;
  grid-template-columns: 4.5rem 1fr;
  gap: 2rem;
  padding: 4rem 0;
  border-bottom: 1px solid rgba(0, 0, 0, 0.07);
  /* scroll reveal initial state */
  opacity: 0;
  transform: translateY(32px);
  transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
}

.svc-row.svc-revealed {
  opacity: 1;
  transform: translateY(0);
}

/* Ghost number column */
