---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    id: 'web-apps',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.75"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>`,
    accent: 'violet',
    image: '/images/services/web development.jpg',
    title: 'Web Application Development',
    tagline: 'Powerful platforms that scale',
    description: 'We build complex web applications from scratch — dashboards, SaaS platforms, internal tools, and data-heavy systems. Every app is engineered for performance and built to grow with your business.',
    features: ['React / Next.js / Astro frontends', 'Node.js, Python & Go backends', 'PostgreSQL, MongoDB & Redis', 'REST & GraphQL APIs', 'Authentication & access control', 'Cloud deployment (AWS, Railway, Vercel)'],
  },
  {
    id: 'websites',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.75"/><path d="M2 12h20M12 2a15 15 0 010 20M12 2a15 15 0 000 20" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>`,
    accent: 'cyan',
    image: '/images/services/website.jpg',
    title: 'Websites & Landing Pages',
    tagline: 'Fast, beautiful, and built to convert',
    description: 'From corporate sites to high-converting landing pages, we design and build websites that make strong first impressions. Fully responsive, SEO-optimized, and blazing fast.',
    features: ['Corporate & portfolio sites', 'Marketing & product landing pages', 'CMS integration (Sanity, Contentful)', 'SEO-first architecture', 'Core Web Vitals optimization', 'Custom animations & interactions'],
  },
  {
    id: 'mobile',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><rect x="5" y="2" width="14" height="20" rx="2" stroke="currentColor" stroke-width="1.75"/><circle cx="12" cy="17" r="1" fill="currentColor"/></svg>`,
    accent: 'violet',
    image: '/images/services/mobile.jpg',
    title: 'Mobile App Development',
    tagline: "Built for Africa's connectivity realities",
    description: 'Cross-platform mobile apps for iOS and Android using React Native. We build offline-capable apps designed to work reliably on the networks and devices your users actually have.',
    features: ['React Native for iOS & Android', 'Offline-first architecture', 'Push notifications & background sync', 'Biometric authentication', 'App store submission & review', 'Low-bandwidth optimization'],
  },
  {
    id: 'custom',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M10 20l4-16M4 9l-3 3 3 3M20 9l3 3-3 3" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    accent: 'cyan',
    image: '/images/services/custom.jpg',
    title: 'Custom Software & APIs',
    tagline: 'Bespoke systems for complex problems',
    description: "When off-the-shelf software doesn't cut it, we build exactly what you need. Custom backend systems, third-party integrations, data pipelines, and APIs that connect your stack together.",
    features: ['Custom REST & GraphQL APIs', 'Third-party integrations', 'Automated data pipelines', 'Webhook & event-driven systems', 'Legacy system modernization', 'Internal tooling & automation'],
  },
  {
    id: 'design',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.75"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>`,
    accent: 'violet',
    image: '/images/services/ui.jpg',
    title: 'UI/UX Design',
    tagline: 'Interfaces people actually enjoy using',
    description: 'Great design is invisible — users just feel it. We design intuitive interfaces that reduce friction, guide users naturally, and make complex workflows feel simple.',
    features: ['User research & journey mapping', 'Wireframing & rapid prototyping', 'High-fidelity UI design (Figma)', 'Design systems & component libraries', 'Accessibility (WCAG 2.1 AA)', 'Usability testing & iteration'],
  },
  {
    id: 'support',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/></svg>`,
    accent: 'cyan',
    image: '/images/services/maintain.jpg',
    title: 'Maintenance & Support',
    tagline: 'A partner, not just a vendor',
    description: "We don't disappear after launch. Our ongoing support packages keep your product secure, performant, and up-to-date — so you can focus on your business while we keep the tech running.",
    features: ['Monthly maintenance retainers', 'Performance monitoring & alerts', 'Security patches & updates', 'Feature additions & improvements', 'Priority response SLA', 'Technical consulting & code review'],
  },
];
---
<BaseLayout
  title="Services — Web Apps, Websites & Mobile"
  description="Zyntel builds web applications, websites, mobile apps, and custom software for East African businesses. Based in Kampala, Uganda."
  hideStickyCta={true}
>
  <Nav />
  <main class="ag-page">

    <!-- HERO -->
    <section class="ag-hero">
      <div class="ag-blob ag-blob--1" aria-hidden="true"></div>
      <div class="ag-blob ag-blob--2" aria-hidden="true"></div>
      <div class="ag-wrap">
        <div class="ag-eyebrow">
          <svg class="ag-eyebrow-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.09 6.26L21 10l-6.91 1.74L12 18l-2.09-5.26L3 11l6.91-1.74z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
          What we build
        </div>
        <h1 class="ag-hero-title">
          Digital products,<br>
          <span class="ag-grad-text">engineered to last.</span>
        </h1>
        <p class="ag-hero-sub">
          Full-service web and mobile development for businesses that need more than a template. We build real products that solve real problems.
        </p>
        <a href="/contact" class="ag-btn ag-btn--dark">Discuss your project</a>
      </div>
    </section>

    <!-- SERVICES INDEX STRIP -->
    <nav class="svc-index" aria-label="Services navigation">
      <div class="ag-wrap">
        <ul class="svc-index-inner">
          {services.map((svc, i) => (
            <li>
              <a href={`#${svc.id}`} class="svc-index-item">
                <span class="svc-index-num">0{i + 1}</span>
                <span class="svc-index-label">{svc.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>

    <!-- SERVICES NUMBERED LIST -->
    <section class="ag-section svc-section">
      <div class="ag-wrap">

        <header class="svc-section-head">
          <p class="ag-section-eyebrow">Our Services</p>
          <h2 class="ag-section-title">Everything you need to ship</h2>
          <p class="ag-section-sub">From idea to production — we handle the full stack so you can focus on your business.</p>
        </header>

        <div class="svc-rows">
          {services.map((svc, i) => (
            <article class="svc-row" id={svc.id}>

              <div class="svc-row-left">
                <span class="svc-row-num">0{i + 1}</span>
              </div>

              <div class="svc-row-body">
                <div class="svc-row-head">
                  <div>
                    <p class="svc-row-tagline">{svc.tagline}</p>
                    <h3 class="svc-row-title">{svc.title}</h3>
                  </div>
                  <div class={`svc-row-icon svc-row-icon--${svc.accent}`} set:html={svc.icon} />
                </div>

                <p class="svc-row-desc">{svc.description}</p>

                <div class="svc-row-img-wrap">
                  <img src={svc.image} alt={svc.title} class="svc-row-img" loading="lazy" decoding="async" />
                </div>

                <ul class="svc-row-chips" aria-label="Included in this service">
                  {svc.features.map((f) => (
                    <li>{f}</li>
                  ))}
                </ul>
              </div>

            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- CTA -->
    <div class="ag-cta-light">
      <div class="ag-cta-light-mark" aria-hidden="true">Zyntel</div>
      <div class="ag-cta-light-icon" aria-hidden="true">
        <svg width="36" height="36" viewBox="0 0 1024 1024" fill="none" xmlns="http://www.w3.org/2000/svg">
          <text x="80" y="700" font-family="'Geist Sans','Segoe UI',system-ui,sans-serif" font-weight="700" font-size="1200" fill="#ffffff">}</text>
        </svg>
      </div>
      <h2 class="ag-cta-light-title">Ready to start<br>your project?</h2>
      <p class="ag-cta-light-sub">Tell us what you're building and we'll put together a plan. No commitment required.</p>
      <div class="ag-cta-light-links">
        <a href="/contact" class="ag-cta-light-pill">
          Get in touch
          <span class="ag-cta-light-pill-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
        <a href="mailto:contact@zyntel.net" class="ag-cta-light-pill">
          contact@zyntel.net
          <span class="ag-cta-light-pill-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
        </a>
        <a href="https://x.com/ZyntelTech" target="_blank" rel="noopener noreferrer" class="ag-cta-light-pill">
          Twitter / X
          <span class="ag-cta-light-pill-icon" aria-hidden="true">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.26 5.632 5.904-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </span>
        </a>
        <a href="https://www.linkedin.com/company/zynteltech" target="_blank" rel="noopener noreferrer" class="ag-cta-light-pill">
          LinkedIn
          <span class="ag-cta-light-pill-icon" aria-hidden="true">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </span>
        </a>
      </div>
    </div>

  </main>
  <Footer />
</BaseLayout>

<style>
/* ─── Services index strip ─── */
.svc-index {
  background: #ffffff;
  border-bottom: 1px solid rgba(0, 0, 0, 0.07);
  overflow-x: auto;
  scrollbar-width: none;
}
.svc-index::-webkit-scrollbar { display: none; }

.svc-index-inner {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: stretch;
  min-width: max-content;
}

.svc-index-item {
  display: flex;
  align-items: center;
  gap: 0.55rem;
  padding: 0.9rem 1.4rem;
  text-decoration: none;
  color: var(--ag-muted);
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: -0.01em;
  border-right: 1px solid rgba(0, 0, 0, 0.07);
  transition: color 0.2s, background 0.2s;
  white-space: nowrap;
}

.svc-index-item:hover {
  color: #7c3aed;
  background: rgba(124, 58, 237, 0.03);
}

.svc-index-num {
  font-size: 0.65rem;
  font-weight: 800;
  color: #7c3aed;
  letter-spacing: 0.06em;
  font-variant-numeric: tabular-nums;
  opacity: 0.7;
}

.svc-index-item:hover .svc-index-num {
  opacity: 1;
}

/* ─── Services section ─── */
.svc-section {
  background: #ffffff;
}

.svc-section-head {
  margin-bottom: 3.5rem;
}

/* ─── Numbered rows ─── */
.svc-rows {
  border-top: 1px solid rgba(0, 0, 0, 0.07);
}

.svc-row {
  display: grid;
  grid-template-columns: 5.5rem 1fr;
  gap: 2rem;
  padding: 2.75rem 0;
  border-bottom: 1px solid rgba(0, 0, 0, 0.07);
  transition: background 0.25s;
  margin: 0 -1.5rem;
  padding-left: 1.5rem;
  padding-right: 1.5rem;
  border-radius: 0;
}

.svc-row:hover {
  background: rgba(124, 58, 237, 0.025);
}

/* Big ghost number */
.svc-row-left {
  display: flex;
  align-items: flex-start;
  padding-top: 0.35rem;
}

.svc-row-num {
  font-size: clamp(2.5rem, 5vw, 3.75rem);
  font-weight: 900;
  letter-spacing: -0.06em;
  line-height: 1;
  color: rgba(124, 58, 237, 0.13);
  font-variant-numeric: tabular-nums;
  user-select: none;
  transition: color 0.25s;
}

.svc-row:hover .svc-row-num {
  color: rgba(124, 58, 237, 0.22);
}

/* Row body */
.svc-row-body {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.svc-row-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1.5rem;
  margin-bottom: 0.9rem;
}

.svc-row-tagline {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #7c3aed;
  margin-bottom: 0.3rem;
}

.svc-row-title {
  font-size: clamp(1.25rem, 2.5vw, 1.65rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  color: #0f0f14;
  line-height: 1.2;
}

/* Icon badge */
.svc-row-icon {
  width: 3rem;
  height: 3rem;
  border-radius: 0.875rem;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: transform 0.25s;
}

.svc-row:hover .svc-row-icon {
  transform: scale(1.05);
}

.svc-row-icon--violet {
  background: rgba(124, 58, 237, 0.08);
  color: #7c3aed;
  border: 1px solid rgba(124, 58, 237, 0.15);
}

.svc-row-icon--cyan {
  background: rgba(79, 70, 229, 0.08);
  color: #4f46e5;
  border: 1px solid rgba(79, 70, 229, 0.12);
}

/* Description */
.svc-row-desc {
  font-size: 0.95rem;
  color: #6b7280;
  line-height: 1.75;
  max-width: 46rem;
  margin-bottom: 1.4rem;
}

/* Feature chips */
.svc-row-chips {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
}

.svc-row-chips li {
  padding: 0.3rem 0.8rem;
  border-radius: 999px;
  background: rgba(124, 58, 237, 0.06);
  border: 1px solid rgba(124, 58, 237, 0.13);
  font-size: 0.78rem;
  font-weight: 600;
  color: #5b21b6;
  letter-spacing: -0.01em;
  transition: background 0.2s, border-color 0.2s;
}

.svc-row:hover .svc-row-chips li {
  background: rgba(124, 58, 237, 0.09);
  border-color: rgba(124, 58, 237, 0.2);
}

/* ─── Responsive ─── */
@media (max-width: 640px) {
  .svc-row {
    grid-template-columns: 1fr;
    gap: 0.75rem;
    padding: 2rem 1rem;
    margin: 0 -1rem;
  }

  .svc-row-num {
    font-size: 1rem;
    font-weight: 800;
    color: rgba(124, 58, 237, 0.5);
    letter-spacing: 0.06em;
  }

  .svc-row-left {
    padding-top: 0;
  }

  .svc-row-head {
    flex-direction: row-reverse;
    justify-content: flex-end;
    gap: 1rem;
  }

  .svc-row-icon {
    width: 2.5rem;
    height: 2.5rem;
  }
}

@media (max-width: 480px) {
  .svc-index-item {
    padding: 0.75rem 1rem;
    font-size: 0.75rem;
  }
}

/* ─── Service row image ─── */
.svc-row-img-wrap {
  margin-bottom: 1.4rem;
  border-radius: 0.75rem;
  overflow: hidden;
  max-width: 46rem;
  aspect-ratio: 16 / 7;
}

.svc-row-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.svc-row:hover .svc-row-img {
  transform: scale(1.03);
}
</style>
