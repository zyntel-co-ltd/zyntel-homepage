---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    id: 'web-apps',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.75"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>`,
    accent: 'violet',
    title: 'Web Application Development',
    tagline: 'Powerful platforms that scale',
    description: 'We build complex web applications from scratch — dashboards, SaaS platforms, internal tools, and data-heavy systems. Every app is engineered for performance and built to grow with your business.',
    features: ['React / Next.js / Astro frontends', 'Node.js, Python & Go backends', 'PostgreSQL, MongoDB & Redis', 'REST & GraphQL APIs', 'Authentication & access control', 'Cloud deployment (AWS, Railway, Vercel)'],
  },
  {
    id: 'websites',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.75"/><path d="M2 12h20M12 2a15 15 0 010 20M12 2a15 15 0 000 20" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>`,
    accent: 'cyan',
    title: 'Websites & Landing Pages',
    tagline: 'Fast, beautiful, and built to convert',
    description: 'From corporate sites to high-converting landing pages, we design and build websites that make strong first impressions. Fully responsive, SEO-optimized, and blazing fast.',
    features: ['Corporate & portfolio sites', 'Marketing & product landing pages', 'CMS integration (Sanity, Contentful)', 'SEO-first architecture', 'Core Web Vitals optimization', 'Custom animations & interactions'],
  },
  {
    id: 'mobile',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><rect x="5" y="2" width="14" height="20" rx="2" stroke="currentColor" stroke-width="1.75"/><circle cx="12" cy="17" r="1" fill="currentColor"/></svg>`,
    accent: 'violet',
    title: 'Mobile App Development',
    tagline: "Built for Africa's connectivity realities",
    description: 'Cross-platform mobile apps for iOS and Android using React Native. We build offline-capable apps designed to work reliably on the networks and devices your users actually have.',
    features: ['React Native for iOS & Android', 'Offline-first architecture', 'Push notifications & background sync', 'Biometric authentication', 'App store submission & review', 'Low-bandwidth optimization'],
  },
  {
    id: 'custom',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M10 20l4-16M4 9l-3 3 3 3M20 9l3 3-3 3" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    accent: 'cyan',
    title: 'Custom Software & APIs',
    tagline: 'Bespoke systems for complex problems',
    description: "When off-the-shelf software doesn't cut it, we build exactly what you need. Custom backend systems, third-party integrations, data pipelines, and APIs that connect your stack together.",
    features: ['Custom REST & GraphQL APIs', 'Third-party integrations', 'Automated data pipelines', 'Webhook & event-driven systems', 'Legacy system modernization', 'Internal tooling & automation'],
  },
  {
    id: 'design',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.75"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>`,
    accent: 'violet',
    title: 'UI/UX Design',
    tagline: 'Interfaces people actually enjoy using',
    description: 'Great design is invisible — users just feel it. We design intuitive interfaces that reduce friction, guide users naturally, and make complex workflows feel simple.',
    features: ['User research & journey mapping', 'Wireframing & rapid prototyping', 'High-fidelity UI design (Figma)', 'Design systems & component libraries', 'Accessibility (WCAG 2.1 AA)', 'Usability testing & iteration'],
  },
  {
    id: 'support',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/></svg>`,
    accent: 'cyan',
    title: 'Maintenance & Support',
    tagline: 'A partner, not just a vendor',
    description: "We don't disappear after launch. Our ongoing support packages keep your product secure, performant, and up-to-date — so you can focus on your business while we keep the tech running.",
    features: ['Monthly maintenance retainers', 'Performance monitoring & alerts', 'Security patches & updates', 'Feature additions & improvements', 'Priority response SLA', 'Technical consulting & code review'],
  },
];
---
<BaseLayout
  title="Services — Web Apps, Websites & Mobile"
  description="Zyntel builds web applications, websites, mobile apps, and custom software for East African businesses. Based in Kampala, Uganda."
  hideStickyCta={true}
>
  <Nav />
  <main class="ag-page">

    <!-- HERO -->
    <section class="ag-hero">
      <div class="ag-blob ag-blob--1" aria-hidden="true"></div>
      <div class="ag-blob ag-blob--2" aria-hidden="true"></div>
      <div class="ag-wrap">
        <div class="ag-eyebrow">
          <svg class="ag-eyebrow-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.09 6.26L21 10l-6.91 1.74L12 18l-2.09-5.26L3 11l6.91-1.74z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
          What we build
        </div>
        <h1 class="ag-hero-title">
          Digital products,<br>
          <span class="ag-grad-text">engineered to last.</span>
        </h1>
        <p class="ag-hero-sub">
          Full-service web and mobile development for businesses that need more than a template. We build real products that solve real problems.
        </p>
        <a href="/contact" class="ag-btn ag-btn--dark">Discuss your project</a>
      </div>
    </section>

    <!-- SERVICES LIST -->
    <section class="ag-section ag-section--alt">
      <div class="ag-wrap">
        {services.map((svc) => (
          <article class="ag-svc-item" id={svc.id}>
            <div class={`ag-svc-icon ag-svc-icon--${svc.accent}`} set:html={svc.icon} />
            <div class="ag-svc-body">
              <p class="ag-svc-tagline">{svc.tagline}</p>
              <h2 class="ag-svc-title">{svc.title}</h2>
              <p class="ag-svc-desc">{svc.description}</p>
              <ul class="ag-svc-features">
                {svc.features.map((f) => (
                  <li>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/></svg>
                    {f}
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="ag-section">
      <div class="ag-wrap">
        <div class="ag-cta-card">
          <div class="ag-cta-blob ag-cta-blob--v" aria-hidden="true"></div>
          <div class="ag-cta-blob ag-cta-blob--p" aria-hidden="true"></div>
          <p class="ag-cta-eyebrow">Let's work together</p>
          <h2 class="ag-cta-title">Ready to start<br><span class="ag-grad-text">your project?</span></h2>
          <p class="ag-cta-sub">Tell us what you're building and we'll put together a plan. No commitment required.</p>
          <div class="ag-cta-actions">
            <a href="/contact" class="ag-btn ag-btn--violet">Get in touch</a>
            <a href="mailto:contact@zyntel.net" class="ag-btn ag-btn--white-outline">contact@zyntel.net</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
