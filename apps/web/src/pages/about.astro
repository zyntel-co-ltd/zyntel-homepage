---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const team = [
  {
    initials: 'ND',
    name: 'Ntale Nithamu Diini',
    role: 'Chief Executive Officer',
    bio: "Product strategy and commercial growth — driving Zyntel's vision of building digital infrastructure for East African businesses.",
  },
  {
    initials: 'WM',
    name: 'Wycliff Matovu',
    role: 'Chief Technology Officer',
    bio: 'Systems architecture and engineering leadership — designing scalable, resilient software built for real-world African constraints.',
  },
  {
    initials: 'FM',
    name: 'Faridah',
    role: 'Chief Operating Officer',
    bio: 'Operations and client success — ensuring every project is delivered on time and every client relationship is built to last.',
  },
];

const values = [
  {
    accent: 'violet',
    title: 'Built for Africa first',
    body: "We don't port Western solutions onto African problems. We design from the ground up for the networks, devices, and workflows that East African businesses actually use.",
  },
  {
    accent: 'pink',
    title: 'Engineering over shortcuts',
    body: 'Clean architecture, proper testing, and maintainable code. We build things the right way because bad foundations are expensive to fix later.',
  },
  {
    accent: 'violet',
    title: 'Long-term partners',
    body: "We don't disappear after launch. Our best client relationships have lasted years — growing alongside the products we help build.",
  },
  {
    accent: 'pink',
    title: 'Transparency always',
    body: 'Honest timelines, clear pricing, and direct communication. No hidden fees, no overpromising — just straightforward collaboration.',
  },
];
---
<BaseLayout
  title="About — Zyntel Web Agency"
  description="Zyntel is a web agency based in Kampala, Uganda. Founded to build digital products that solve real African problems. Meet the team."
  hideStickyCta={true}
>
  <Nav />
  <main class="ag-page">

    <!-- HERO -->
    <section class="ag-hero ag-hero--left">
      <div class="ag-blob ag-blob--1" aria-hidden="true"></div>
      <div class="ag-wrap">
        <div class="ag-eyebrow">
          <svg class="ag-eyebrow-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.09 6.26L21 10l-6.91 1.74L12 18l-2.09-5.26L3 11l6.91-1.74z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
          Our story
        </div>
        <h1 class="ag-hero-title">
          Built in Kampala,<br>
          <span class="ag-grad-text">building for Africa.</span>
        </h1>
        <p class="ag-hero-sub">
          Zyntel started with a simple observation: East African businesses deserved better software — built for their reality, not adapted from somewhere else. That conviction drives every line of code we write.
        </p>
        <blockquote class="ag-hero-quote">
          <p>"We aren't just building software — we're building the digital infrastructure that African businesses will run on."</p>
          <cite>— Zyntel leadership</cite>
        </blockquote>
      </div>
    </section>

    <!-- VALUES -->
    <section class="ag-section ag-section--alt">
      <div class="ag-wrap">
        <p class="ag-section-eyebrow">What we stand for</p>
        <h2 class="ag-section-title">Values that shape<br>how we build</h2>
        <div class="ag-values-grid">
          {values.map((v) => (
            <article class={`ag-value-card ag-value-card--${v.accent}`}>
              <h3>{v.title}</h3>
              <p>{v.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- TEAM -->
    <section class="ag-section">
      <div class="ag-wrap">
        <p class="ag-section-eyebrow">The people</p>
        <h2 class="ag-section-title">The team behind Zyntel</h2>
        <p class="ag-section-sub">Small team, high standards. We care deeply about the work and the people we do it for.</p>
        <div class="ag-team-grid">
          {team.map((member) => (
            <article class="ag-team-card">
              <div class="ag-team-avatar">{member.initials}</div>
              <h3 class="ag-team-name">{member.name}</h3>
              <p class="ag-team-role">{member.role}</p>
              <p class="ag-team-bio">{member.bio}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- PRODUCT SPOTLIGHT -->
    <section class="ag-section ag-product-strip">
      <div class="ag-wrap">
        <div class="ag-strip-inner">
          <div>
            <p class="ag-section-eyebrow" style="text-align:left; margin-bottom: 0.75rem;">Our flagship product</p>
            <h2 class="ag-strip-title"><span class="ag-zf-brand">ZyntForms</span> — offline data<br>collection, reimagined.</h2>
            <p class="ag-strip-desc">Our newest product grew out of real problems we kept seeing: field teams losing data, broken syncs, forms that don't work without Wi-Fi. ZyntForms solves all of it.</p>
            <div class="ag-strip-actions">
              <a href="https://zyntforms.com" target="_blank" rel="noopener noreferrer" class="ag-btn ag-btn--violet">Visit ZyntForms ↗</a>
              <a href="/contact" class="ag-btn ag-btn--zf">Learn more</a>
            </div>
          </div>
          <div class="ag-strip-art" aria-hidden="true">
            <div class="ag-strip-art-inner">ZF</div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="ag-cta-light">
      <div class="ag-cta-light-mark" aria-hidden="true">Zyntel</div>
      <div class="ag-cta-light-icon" aria-hidden="true">
        <svg width="36" height="36" viewBox="0 0 1024 1024" fill="none" xmlns="http://www.w3.org/2000/svg">
          <text x="80" y="700" font-family="'Geist Sans','Segoe UI',system-ui,sans-serif" font-weight="700" font-size="1200" fill="#ffffff">}</text>
        </svg>
      </div>
      <h2 class="ag-cta-light-title">Ready to build<br>something great?</h2>
      <p class="ag-cta-light-sub">Based in Kampala, working with clients across East Africa and beyond. Let's talk.</p>
      <div class="ag-cta-light-links">
        <a href="/contact" class="ag-cta-light-pill">
          Get in touch
          <span class="ag-cta-light-pill-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
        <a href="/services" class="ag-cta-light-pill">
          See our services
          <span class="ag-cta-light-pill-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
        <a href="mailto:contact@zyntel.net" class="ag-cta-light-pill">
          contact@zyntel.net
          <span class="ag-cta-light-pill-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
        </a>
        <a href="https://www.linkedin.com/company/zynteltech" target="_blank" rel="noopener noreferrer" class="ag-cta-light-pill">
          LinkedIn
          <span class="ag-cta-light-pill-icon" aria-hidden="true">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </span>
        </a>
      </div>
    </div>

  </main>
  <Footer />
</BaseLayout>
