---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Contact — Start a Project"
  ogTitle="Contact Zyntel — Let's build something together"
  description="Get in touch with Zyntel. Based in Kampala, Uganda — building web apps, websites, and mobile products for East African businesses."
  hideStickyCta={true}
>
  <Nav />
  <main class="ag-page">

    <section class="ag-hero">
      <div class="ag-hero-glow ag-hero-glow--v" aria-hidden="true"></div>
      <div class="ag-wrap">
        <div class="ag-eyebrow">
          <span class="ag-dot ag-dot--pulse" aria-hidden="true"></span>
          We're available
        </div>
        <h1 class="ag-hero-title">
          Let's build something<br>
          <span class="ag-grad-text">great together.</span>
        </h1>
        <p class="ag-hero-sub">
          Tell us about your project. Whether it's a web app, website, mobile app, or something custom — we'd love to hear it.
        </p>
      </div>
    </section>

    <section class="ag-contact-section">
      <div class="ag-wrap ag-contact-grid">

        <!-- FORM -->
        <div class="ag-form-card">
          <h2 class="ag-form-heading">Send us a message</h2>
          <form id="contact-form" class="ag-form" novalidate>
            <div class="ag-form-row">
              <div class="ag-form-group">
                <label class="ag-label" for="name">Your name</label>
                <input class="ag-input" type="text" id="name" name="name" required autocomplete="name" placeholder="Alex Nakato" />
              </div>
              <div class="ag-form-group">
                <label class="ag-label" for="organization">Company / organization</label>
                <input class="ag-input" type="text" id="organization" name="organization" autocomplete="organization" placeholder="Acme Ltd" />
              </div>
            </div>
            <div class="ag-form-group">
              <label class="ag-label" for="email">Email address</label>
              <input class="ag-input" type="email" id="email" name="email" required autocomplete="email" placeholder="alex@company.com" />
            </div>
            <fieldset class="ag-form-group ag-fieldset">
              <legend class="ag-label">What can we help with?</legend>
              <div class="ag-pills">
                <label class="ag-pill">
                  <input type="radio" name="interest" value="Web application" checked />
                  <span>Web app</span>
                </label>
                <label class="ag-pill">
                  <input type="radio" name="interest" value="Website or landing page" />
                  <span>Website</span>
                </label>
                <label class="ag-pill">
                  <input type="radio" name="interest" value="Mobile app" />
                  <span>Mobile app</span>
                </label>
                <label class="ag-pill">
                  <input type="radio" name="interest" value="ZyntForms product inquiry" />
                  <span>ZyntForms</span>
                </label>
                <label class="ag-pill">
                  <input type="radio" name="interest" value="Custom software" />
                  <span>Custom software</span>
                </label>
                <label class="ag-pill">
                  <input type="radio" name="interest" value="Other" />
                  <span>Other</span>
                </label>
              </div>
            </fieldset>
            <div class="ag-form-group">
              <label class="ag-label" for="message">Tell us about your project</label>
              <textarea class="ag-input ag-textarea" id="message" name="message" required rows="5" placeholder="Describe what you're building, your timeline, and any relevant details…"></textarea>
            </div>
            <div id="form-status" class="ag-form-status" aria-live="polite"></div>
            <button type="submit" class="ag-btn ag-btn--grad ag-submit" id="submit-btn">
              Send message
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </form>
        </div>

        <!-- ASIDE -->
        <aside class="ag-contact-aside">
          <div class="ag-contact-office">
            <div class="ag-office-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 21s7-4.5 7-11a7 7 0 10-14 0c0 6.5 7 11 7 11z" stroke="currentColor" stroke-width="1.75"/><circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.75"/></svg>
            </div>
            <h2>Kampala office</h2>
            <p>Kampala, Uganda<br><strong>Mon – Fri:</strong> 8 AM – 6 PM (EAT)</p>
            <a href="mailto:contact@zyntel.net" class="ag-email-link">contact@zyntel.net →</a>
          </div>

          <div class="ag-contact-channels">
            <a href="mailto:contact@zyntel.net?subject=WhatsApp inquiry" class="ag-channel-card">
              <span class="ag-channel-icon ag-channel-icon--wa">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M21 11.5a8.5 8.5 0 01-12.4 7.5L3 21l2.1-5.5A8.5 8.5 0 1112.5 3 8.5 8.5 0 0121 11.5z" stroke="currentColor" stroke-width="1.75"/></svg>
              </span>
              <div>
                <p class="ag-channel-label">WhatsApp</p>
                <p class="ag-channel-value">Request via email</p>
              </div>
            </a>
            <a href="https://www.linkedin.com/company/zynteltech" target="_blank" rel="noopener noreferrer" class="ag-channel-card">
              <span class="ag-channel-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-12h4v2" stroke="currentColor" stroke-width="1.75"/><rect x="2" y="9" width="4" height="12" stroke="currentColor" stroke-width="1.75"/><circle cx="4" cy="4" r="2" stroke="currentColor" stroke-width="1.75"/></svg>
              </span>
              <div>
                <p class="ag-channel-label">LinkedIn</p>
                <p class="ag-channel-value">Connect with us</p>
              </div>
            </a>
          </div>

          <blockquote class="ag-contact-quote">
            <p>"At Zyntel, we believe the best products are built through genuine partnership — understanding your business as well as the technology."</p>
            <footer>
              <span class="ag-quote-avatar">ZY</span>
              <div>
                <strong>Zyntel team</strong>
                <small>Kampala, Uganda</small>
              </div>
            </footer>
          </blockquote>
        </aside>

      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = (form.querySelector('#name') as HTMLInputElement).value.trim();
    const email = (form.querySelector('#email') as HTMLInputElement).value.trim();
    const org = (form.querySelector('#organization') as HTMLInputElement).value.trim();
    const interest = (form.querySelector('input[name="interest"]:checked') as HTMLInputElement)?.value ?? 'Other';
    const message = (form.querySelector('#message') as HTMLTextAreaElement).value.trim();

    if (!name || !email || !message) {
      status.textContent = 'Please fill in all required fields.';
      status.className = 'ag-form-status ag-form-status--error';
      return;
    }

    submitBtn.disabled = true;
    status.textContent = '';
    status.className = 'ag-form-status';

    const orgLine = org ? `\nOrganization: ${org}` : '';
    const body = `${message}${orgLine}`;

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, message: `[${interest}] ${body}` }),
      });
      const data = await res.json();
      if (data.ok) {
        status.textContent = "Message sent — we'll be in touch within one business day.";
        status.className = 'ag-form-status ag-form-status--success';
        form.reset();
        const first = form.querySelector('input[name="interest"]') as HTMLInputElement;
        if (first) first.checked = true;
      } else {
        throw new Error(data.error ?? 'unknown');
      }
    } catch {
      status.innerHTML = 'Something went wrong. Email us at <a href="mailto:contact@zyntel.net">contact@zyntel.net</a>.';
      status.className = 'ag-form-status ag-form-status--error';
    } finally {
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  .ag-page {
    background: var(--ag-bg, #08090f);
    color: var(--ag-text, #f1f5f9);
    min-height: 100vh;
  }

  .ag-wrap {
    max-width: 80rem;
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 3rem);
  }

  .ag-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #94a3b8;
    margin-bottom: 1.5rem;
  }

  .ag-dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: #94a3b8;
  }

  .ag-dot--pulse {
    background: #22c55e;
    box-shadow: 0 0 6px rgba(34, 197, 94, 0.8);
    animation: dot-pulse 1.8s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .ag-grad-text {
    background: linear-gradient(135deg, #c084fc 0%, #67e8f9 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .ag-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.85rem 1.75rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.92rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s;
    font-family: inherit;
  }

  .ag-btn:hover { transform: translateY(-2px); }

  .ag-btn--grad {
    background: linear-gradient(135deg, #a855f7, #22d3ee);
    color: #fff;
    box-shadow: 0 8px 28px rgba(168, 85, 247, 0.35);
  }

  .ag-btn--grad:hover { box-shadow: 0 12px 36px rgba(168, 85, 247, 0.5); }

  /* Hero */
  .ag-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(7rem, 14vw, 11rem) 0 clamp(3rem, 6vw, 4rem);
  }

  .ag-hero-glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(80px);
    opacity: 0.5;
  }

  .ag-hero-glow--v {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.5), transparent 70%);
    top: -180px;
    left: 50%;
    transform: translateX(-50%);
  }

  .ag-hero .ag-wrap {
    position: relative;
    z-index: 1;
    max-width: 44rem;
  }

  .ag-hero-title {
    font-size: clamp(2.25rem, 5.5vw, 4rem);
    font-weight: 700;
    line-height: 1.06;
    letter-spacing: -0.035em;
    color: #f1f5f9;
    margin-bottom: 1.25rem;
  }

  .ag-hero-sub {
    font-size: clamp(1rem, 2vw, 1.1rem);
    line-height: 1.7;
    color: #94a3b8;
  }

  /* Contact layout */
  .ag-contact-section {
    padding-bottom: clamp(4rem, 8vw, 6rem);
  }

  .ag-contact-grid {
    display: grid;
    grid-template-columns: 1.25fr 0.75fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* Form */
  .ag-form-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 1.5rem;
    padding: clamp(1.75rem, 3vw, 2.5rem);
  }

  .ag-form-heading {
    font-size: 1.15rem;
    font-weight: 700;
    color: #f1f5f9;
    margin-bottom: 1.75rem;
  }

  .ag-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .ag-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .ag-form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .ag-fieldset {
    border: none;
    margin: 0;
    padding: 0;
  }

  .ag-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #64748b;
  }

  .ag-input {
    width: 100%;
    padding: 0.8rem 1rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    color: #f1f5f9;
    font-family: inherit;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .ag-input::placeholder {
    color: #475569;
  }

  .ag-input:focus {
    border-color: rgba(168, 85, 247, 0.5);
    box-shadow: 0 0 0 3px rgba(168, 85, 247, 0.12);
  }

  .ag-textarea {
    resize: vertical;
    min-height: 7rem;
  }

  .ag-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .ag-pill {
    cursor: pointer;
  }

  .ag-pill input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .ag-pill span {
    display: block;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    font-size: 0.82rem;
    font-weight: 600;
    color: #94a3b8;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }

  .ag-pill:hover span {
    border-color: rgba(168, 85, 247, 0.3);
    color: #f1f5f9;
  }

  .ag-pill input:checked + span {
    background: rgba(168, 85, 247, 0.18);
    border-color: rgba(168, 85, 247, 0.45);
    color: #c084fc;
  }

  .ag-pill input[value*='ZyntForms']:checked + span {
    background: rgba(168, 85, 247, 0.22);
    border-color: rgba(168, 85, 247, 0.5);
    color: #d8b4fe;
  }

  .ag-form-status {
    font-size: 0.9rem;
    border-radius: 0.65rem;
    padding: 0.75rem 1rem;
    display: none;
  }

  .ag-form-status:not(:empty) {
    display: block;
  }

  .ag-form-status--success {
    background: rgba(34, 197, 94, 0.1);
    color: #4ade80;
    border: 1px solid rgba(34, 197, 94, 0.2);
  }

  .ag-form-status--error {
    background: rgba(239, 68, 68, 0.08);
    color: #f87171;
    border: 1px solid rgba(239, 68, 68, 0.2);
  }

  .ag-form-status a {
    color: inherit;
    text-decoration: underline;
  }

  .ag-submit {
    width: 100%;
    justify-content: center;
  }

  .ag-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media (min-width: 480px) {
    .ag-submit {
      width: auto;
    }
  }

  /* Aside */
  .ag-contact-aside {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 6rem;
  }

  .ag-contact-office {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 1.25rem;
    padding: 1.5rem;
  }

  .ag-office-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 0.875rem;
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(168, 85, 247, 0.2);
    color: #a855f7;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .ag-contact-office h2 {
    font-size: 1rem;
    font-weight: 700;
    color: #f1f5f9;
    margin-bottom: 0.5rem;
  }

  .ag-contact-office p {
    font-size: 0.88rem;
    color: #94a3b8;
    line-height: 1.65;
    margin-bottom: 0.75rem;
  }

  .ag-email-link {
    font-size: 0.88rem;
    font-weight: 600;
    color: #a855f7;
    text-decoration: none;
    transition: color 0.2s;
  }

  .ag-email-link:hover {
    color: #c084fc;
  }

  .ag-contact-channels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .ag-channel-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 1rem;
    padding: 1rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    transition: border-color 0.2s, background 0.2s;
  }

  .ag-channel-card:hover {
    border-color: rgba(168, 85, 247, 0.3);
    background: rgba(168, 85, 247, 0.04);
  }

  .ag-channel-icon {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: rgba(168, 85, 247, 0.1);
    color: #a855f7;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ag-channel-icon--wa {
    background: rgba(37, 211, 102, 0.1);
    color: #4ade80;
  }

  .ag-channel-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #64748b;
    margin-bottom: 0.15rem;
  }

  .ag-channel-value {
    font-size: 0.85rem;
    font-weight: 600;
    color: #cbd5e1;
  }

  .ag-contact-quote {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-left: 3px solid rgba(168, 85, 247, 0.5);
    border-radius: 0 1rem 1rem 0;
    padding: 1.25rem;
    margin: 0;
  }

  .ag-contact-quote p {
    font-style: italic;
    font-size: 0.88rem;
    color: #94a3b8;
    line-height: 1.65;
    margin-bottom: 0.85rem;
  }

  .ag-contact-quote footer {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .ag-quote-avatar {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(168, 85, 247, 0.15);
    border: 1px solid rgba(168, 85, 247, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.62rem;
    font-weight: 800;
    color: #c084fc;
  }

  .ag-contact-quote strong {
    display: block;
    font-size: 0.82rem;
    color: #f1f5f9;
    margin-bottom: 0.1rem;
  }

  .ag-contact-quote small {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #a855f7;
  }

  @media (max-width: 900px) {
    .ag-contact-grid {
      grid-template-columns: 1fr;
    }

    .ag-contact-aside {
      position: static;
    }
  }

  @media (max-width: 540px) {
    .ag-form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
