---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Contact — Start a Project"
  ogTitle="Contact Zyntel — Let's build something together"
  description="Get in touch with Zyntel. Based in Kampala, Uganda — building web apps, websites, and mobile products for East African businesses."
  hideStickyCta={true}
>
  <Nav />
  <main class="ag-page">

    <!-- HERO -->
    <div class="ag-hero-wrapper">
    <section class="ag-hero ag-hero--compact">
      <div class="ag-blob ag-blob--1" aria-hidden="true"></div>
      <div class="ag-wrap">
        <h1 class="ag-hero-title">
          Let's build something<br>
          <span class="ag-grad-text">great together.</span>
        </h1>
        <p class="ag-hero-sub">
          Tell us about your project. Whether it's a web app, website, mobile app, or something custom — we'd love to hear it.
        </p>
      </div>
    </section>
    </div>

    <!-- CONTACT GRID -->
    <section class="ag-section">
      <div class="ag-wrap ag-contact-grid">

        <!-- FORM -->
        <div class="ag-form-card">
          <h2 class="ag-form-heading">Send us a message</h2>
          <form id="contact-form" class="ag-form" novalidate>
            <div class="ag-form-row">
              <div class="ag-form-group">
                <label class="ag-label" for="name">Your name</label>
                <input class="ag-input" type="text" id="name" name="name" required autocomplete="name" placeholder="Alex Nakato" />
              </div>
              <div class="ag-form-group">
                <label class="ag-label" for="organization">Company / organization</label>
                <input class="ag-input" type="text" id="organization" name="organization" autocomplete="organization" placeholder="Acme Ltd" />
              </div>
            </div>
            <div class="ag-form-group">
              <label class="ag-label" for="email">Email address</label>
              <input class="ag-input" type="email" id="email" name="email" required autocomplete="email" placeholder="alex@company.com" />
            </div>
            <fieldset class="ag-form-group ag-fieldset">
              <legend class="ag-label">What can we help with?</legend>
              <div class="ag-pills">
                <label class="ag-pill">
                  <input type="radio" name="interest" value="Web application" checked />
                  <span>Web app</span>
                </label>
                <label class="ag-pill">
                  <input type="radio" name="interest" value="Website or landing page" />
                  <span>Website</span>
                </label>
                <label class="ag-pill">
                  <input type="radio" name="interest" value="Mobile app" />
                  <span>Mobile app</span>
                </label>
                <label class="ag-pill">
                  <input type="radio" name="interest" value="ZyntForms product inquiry" />
                  <span>ZyntForms</span>
                </label>
                <label class="ag-pill">
                  <input type="radio" name="interest" value="Custom software" />
                  <span>Custom software</span>
                </label>
                <label class="ag-pill">
                  <input type="radio" name="interest" value="Other" />
                  <span>Other</span>
                </label>
              </div>
            </fieldset>
            <div class="ag-form-group">
              <label class="ag-label" for="message">Tell us about your project</label>
              <textarea class="ag-input ag-textarea" id="message" name="message" required rows="5" placeholder="Describe what you're building, your timeline, and any relevant details…"></textarea>
            </div>
            <div id="form-status" class="ag-form-status" aria-live="polite"></div>
            <button type="submit" class="ag-btn ag-btn--dark ag-submit" id="submit-btn">
              Send message
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </form>
        </div>

        <!-- ASIDE -->
        <aside class="ag-contact-aside">
          <div class="ag-contact-office">
            <div class="ag-office-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 21s7-4.5 7-11a7 7 0 10-14 0c0 6.5 7 11 7 11z" stroke="currentColor" stroke-width="1.75"/><circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.75"/></svg>
            </div>
            <h2>Kampala office</h2>
            <p>Kampala, Uganda<br><strong>Mon – Fri:</strong> 8 AM – 6 PM (EAT)</p>
            <a href="mailto:contact@zyntel.net" class="ag-email-link">contact@zyntel.net →</a>
          </div>

          <div class="ag-contact-channels">
            <a href="mailto:contact@zyntel.net?subject=WhatsApp inquiry" class="ag-channel-card">
              <span class="ag-channel-icon ag-channel-icon--wa">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M21 11.5a8.5 8.5 0 01-12.4 7.5L3 21l2.1-5.5A8.5 8.5 0 1112.5 3 8.5 8.5 0 0121 11.5z" stroke="currentColor" stroke-width="1.75"/></svg>
              </span>
              <div>
                <p class="ag-channel-label">WhatsApp</p>
                <p class="ag-channel-value">Request via email</p>
              </div>
            </a>
            <a href="https://www.linkedin.com/company/zynteltech" target="_blank" rel="noopener noreferrer" class="ag-channel-card">
              <span class="ag-channel-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-12h4v2" stroke="currentColor" stroke-width="1.75"/><rect x="2" y="9" width="4" height="12" stroke="currentColor" stroke-width="1.75"/><circle cx="4" cy="4" r="2" stroke="currentColor" stroke-width="1.75"/></svg>
              </span>
              <div>
                <p class="ag-channel-label">LinkedIn</p>
                <p class="ag-channel-value">Connect with us</p>
              </div>
            </a>
          </div>

          <blockquote class="ag-contact-quote">
            <p>"At Zyntel, we believe the best products are built through genuine partnership — understanding your business as well as the technology."</p>
            <footer>
              <span class="ag-quote-avatar">ZY</span>
              <div>
                <strong>Zyntel team</strong>
                <small>Kampala, Uganda</small>
              </div>
            </footer>
          </blockquote>
        </aside>

      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = (form.querySelector('#name') as HTMLInputElement).value.trim();
    const email = (form.querySelector('#email') as HTMLInputElement).value.trim();
    const org = (form.querySelector('#organization') as HTMLInputElement).value.trim();
    const interest = (form.querySelector('input[name="interest"]:checked') as HTMLInputElement)?.value ?? 'Other';
    const message = (form.querySelector('#message') as HTMLTextAreaElement).value.trim();

    if (!name || !email || !message) {
      status.textContent = 'Please fill in all required fields.';
      status.className = 'ag-form-status ag-form-status--error';
      return;
    }

    submitBtn.disabled = true;
    status.textContent = '';
    status.className = 'ag-form-status';

    const orgLine = org ? `\nOrganization: ${org}` : '';
    const body = `${message}${orgLine}`;

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, message: `[${interest}] ${body}` }),
      });
      const data = await res.json();
      if (data.ok) {
        status.textContent = "Message sent — we'll be in touch within one business day.";
        status.className = 'ag-form-status ag-form-status--success';
        form.reset();
        const first = form.querySelector('input[name="interest"]') as HTMLInputElement;
        if (first) first.checked = true;
      } else {
        throw new Error(data.error ?? 'unknown');
      }
    } catch {
      status.innerHTML = 'Something went wrong. Email us at <a href="mailto:contact@zyntel.net">contact@zyntel.net</a>.';
      status.className = 'ag-form-status ag-form-status--error';
    } finally {
      submitBtn.disabled = false;
    }
  });
</script>
