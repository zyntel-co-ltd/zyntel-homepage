---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="Zyntel home">
          Zyntel<span class="footer-logo-dot">.</span>
        </a>
        <p class="footer-tagline">Building digital products for East Africa.</p>
        <div class="footer-social">
          <a href="https://www.linkedin.com/company/zynteltech" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="footer-social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="https://x.com/ZyntelTech" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="footer-social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.26 5.632 5.904-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="https://github.com/zyntel-co-ltd" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="footer-social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
          </a>
        </div>
      </div>

      <nav class="footer-grid" aria-label="Footer navigation">
        <div class="footer-col">
          <h3>Services</h3>
          <ul>
            <li><a href="/services#web-apps">Web Applications</a></li>
            <li><a href="/services#websites">Websites</a></li>
            <li><a href="/services#mobile">Mobile Apps</a></li>
            <li><a href="/services#custom">Custom Software</a></li>
            <li><a href="/services#design">UI/UX Design</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h3>Products</h3>
          <ul>
            <li><a href="https://zyntforms.com" target="_blank" rel="noopener" class="footer-link--zyntforms">ZyntForms ↗</a></li>
            <li><a href="https://kantahub.com" target="_blank" rel="noopener">Kanta ↗</a></li>
          </ul>
          <h3 style="margin-top: 1.5rem;">Company</h3>
          <ul>
            <li><a href="/about">About</a></li>
            <li><a href="/contact">Contact</a></li>
            <li><a href="/careers">Careers</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h3>Resources</h3>
          <ul>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/legal/privacy">Privacy Policy</a></li>
            <li><a href="/legal/cookies">Cookie Policy</a></li>
            <li><a href="/legal/terms/forms">Terms — ZyntForms</a></li>
            <li><a href="/legal/terms/kanta">Terms — Kanta</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">© {year} Zyntel Co. Limited. Kampala, Uganda.</p>
      <p class="footer-copy footer-copy--muted">Web agency · ZyntForms · Kanta</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #0d1017;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: 4rem 0 2rem;
  }

  .footer-inner {
    max-width: 80rem;
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 3rem);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    margin-bottom: 3rem;
  }

  .footer-logo {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #f1f5f9;
    text-decoration: none;
    display: inline-block;
    margin-bottom: 0.65rem;
  }

  .footer-logo-dot {
    background: linear-gradient(135deg, #a855f7, #22d3ee);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .footer-tagline {
    font-size: 0.88rem;
    color: #64748b;
    line-height: 1.5;
    margin-bottom: 1.25rem;
    max-width: 18rem;
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
  }

  .footer-social-link {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.07);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #64748b;
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .footer-social-link:hover {
    color: #a855f7;
    border-color: rgba(168, 85, 247, 0.3);
    background: rgba(168, 85, 247, 0.06);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .footer-col h3 {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #475569;
    margin-bottom: 0.85rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .footer-col a {
    font-size: 0.88rem;
    color: #64748b;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-col a:hover {
    color: #f1f5f9;
  }

  .footer-link--zyntforms {
    color: #a855f7 !important;
    font-weight: 600;
  }

  .footer-link--zyntforms:hover {
    color: #c084fc !important;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-copy {
    font-size: 0.82rem;
    color: #475569;
  }

  .footer-copy--muted {
    color: #334155;
  }

  @media (max-width: 900px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 420px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
