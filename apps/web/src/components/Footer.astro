---
const year = new Date().getFullYear();
---
<footer class="ag-footer">
  <div class="ag-footer-inner">

    <div class="ag-footer-top">

      <!-- Col 1: Brand -->
      <div class="ag-footer-brand">
        <a href="/" class="ag-footer-logo" aria-label="Zyntel home">
          <span aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 1024 1024" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="512" cy="512" r="512" fill="#9333ea"/>
              <text x="80" y="700" font-family="'Geist Sans','Segoe UI',system-ui,sans-serif" font-weight="700" font-size="1200" fill="#ffffff">}</text>
            </svg>
          </span>
          Zyntel<span class="ag-footer-logo-dot">.</span>
        </a>
        <p class="ag-footer-tagline">Building digital products<br>for East Africa.</p>
        <div class="ag-footer-social">
          <a href="https://www.linkedin.com/company/zynteltech" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="ag-footer-social-link">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://x.com/ZyntelTech" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="ag-footer-social-link">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.26 5.632 5.904-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://github.com/zyntel-co-ltd" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="ag-footer-social-link">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Explore -->
      <div class="ag-footer-col">
        <h3 class="ag-footer-col-title">Explore</h3>
        <ul class="ag-footer-col-list">
          <li><a href="/">Home</a></li>
          <li><a href="/about">About us</a></li>
          <li><a href="/services">Our Services</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <!-- Col 3: Contact -->
      <div class="ag-footer-col">
        <h3 class="ag-footer-col-title">Contact</h3>
        <ul class="ag-footer-col-list ag-footer-contact-list">
          <li>
            <span class="ag-footer-contact-icon" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            Kampala, Uganda<br>
            <span style="padding-left: 1.4rem; display: block; margin-top: 0.15rem; color: rgba(255,255,255,0.4);">East Africa</span>
          </li>
          <li>
            <a href="mailto:contact@zyntel.net" class="ag-footer-contact-link">
              <span class="ag-footer-contact-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </span>
              contact@zyntel.net
            </a>
          </li>
          <li>
            <span class="ag-footer-contact-icon" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.13 6.13l.88-.89a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </span>
            +256 786 421 061
          </li>
        </ul>
      </div>

      <!-- Col 4: Services -->
      <div class="ag-footer-col">
        <h3 class="ag-footer-col-title">Services</h3>
        <ul class="ag-footer-col-list">
          <li><a href="/services#web-apps">Web Applications</a></li>
          <li><a href="/services#websites">Websites</a></li>
          <li><a href="/services#mobile">Mobile Apps</a></li>
          <li><a href="/services#custom">Custom Software</a></li>
          <li><a href="/services#design">UI/UX Design</a></li>
        </ul>
        <h3 class="ag-footer-col-title" style="margin-top: 2rem;">Products</h3>
        <ul class="ag-footer-col-list">
          <li><a href="https://zyntforms.com" target="_blank" rel="noopener" class="ag-footer-link--zf">ZyntForms ↗</a></li>
          <li><a href="https://kantahub.com" target="_blank" rel="noopener">Kanta ↗</a></li>
        </ul>
      </div>

    </div>

    <div class="ag-footer-bottom">
      <p class="ag-footer-copy">© {year} Zyntel Co. Limited. All rights reserved.</p>
      <p class="ag-footer-copy ag-footer-copy--muted">Web agency · ZyntForms · Kanta</p>
    </div>

  </div>
</footer>
