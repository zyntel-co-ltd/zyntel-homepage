---
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '/index.html';
const isServices = currentPath.startsWith('/services');
const isAbout = currentPath.startsWith('/about');
const isBlog = currentPath.startsWith('/blog');
const isContact = currentPath.startsWith('/contact');
---
<header class="ag-nav" id="site-nav">
  <div class="ag-nav-pill">
    <a href="/" class="ag-nav-logo" aria-label="Zyntel home">
      Zyntel<span class="ag-nav-logo-dot">.</span>
    </a>

    <nav class="ag-nav-links" id="nav-links" aria-label="Main">
      <a href="/" class:list={['ag-nav-link', isHome && 'is-active']}>Home</a>
      <a href="/services" class:list={['ag-nav-link', isServices && 'is-active']}>Services</a>
      <a href="/about" class:list={['ag-nav-link', isAbout && 'is-active']}>About</a>
      <a href="/blog" class:list={['ag-nav-link', isBlog && 'is-active']}>Blog</a>
      <a href="/contact" class:list={['ag-nav-link', isContact && 'is-active']}>Contact</a>
    </nav>

    <div class="ag-nav-actions">
      <a href="https://zyntforms.com" target="_blank" rel="noopener" class="ag-nav-product">ZyntForms ↗</a>
      <a href="/contact" class="ag-nav-cta">Start a project</a>
      <button class="ag-nav-toggle" id="nav-toggle" type="button" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const links = document.getElementById('nav-links');
  if (toggle && links) {
    toggle.addEventListener('click', () => {
      const open = links.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(open));
    });
    links.querySelectorAll('a').forEach(a =>
      a.addEventListener('click', () => links.classList.remove('is-open'))
    );
  }
</script>

<style>
  .ag-nav {
    position: fixed;
    top: 1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1000;
    width: calc(100% - 2.5rem);
    max-width: 72rem;
  }

  .ag-nav-pill {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(0, 0, 0, 0.07);
    border-radius: 999px;
    padding: 0.65rem 0.75rem 0.65rem 1.5rem;
    box-shadow: 0 4px 28px rgba(0, 0, 0, 0.1);
  }

  .ag-nav-logo {
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #0f0f14;
    text-decoration: none;
    flex-shrink: 0;
  }

  .ag-nav-logo-dot {
    background: linear-gradient(135deg, #7c3aed, #db2777);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .ag-nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .ag-nav-link {
    font-size: 0.88rem;
    font-weight: 500;
    color: #6b7280;
    text-decoration: none;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    transition: color 0.2s, background 0.2s;
  }

  .ag-nav-link:hover {
    color: #0f0f14;
    background: rgba(0, 0, 0, 0.04);
  }

  .ag-nav-link.is-active {
    color: #0f0f14;
    font-weight: 600;
    background: rgba(0, 0, 0, 0.05);
  }

  .ag-nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .ag-nav-product {
    font-size: 0.8rem;
    font-weight: 600;
    color: #7c3aed;
    text-decoration: none;
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    border: 1.5px solid rgba(124, 58, 237, 0.25);
    background: rgba(124, 58, 237, 0.06);
    transition: background 0.2s, border-color 0.2s;
  }

  .ag-nav-product:hover {
    background: rgba(124, 58, 237, 0.1);
    border-color: rgba(124, 58, 237, 0.4);
  }

  .ag-nav-cta {
    padding: 0.6rem 1.25rem;
    border-radius: 999px;
    background: #0f0f14;
    color: #ffffff;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
    white-space: nowrap;
  }

  .ag-nav-cta:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .ag-nav-toggle {
    display: none;
    flex-direction: column;
    gap: 4.5px;
    padding: 8px;
    background: rgba(0, 0, 0, 0.05);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    width: 2.25rem;
    height: 2.25rem;
    align-items: center;
    justify-content: center;
  }

  .ag-nav-toggle span {
    display: block;
    width: 18px;
    height: 1.5px;
    background: #0f0f14;
    border-radius: 2px;
  }

  @media (max-width: 900px) {
    .ag-nav-product { display: none; }
  }

  @media (max-width: 768px) {
    .ag-nav-toggle { display: flex; }
    .ag-nav-cta { display: none; }

    .ag-nav-links {
      position: fixed;
      top: 5rem;
      left: 1rem;
      right: 1rem;
      flex-direction: column;
      gap: 0;
      padding: 0.5rem;
      background: rgba(255, 255, 255, 0.96);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(0, 0, 0, 0.08);
      border-radius: 1.25rem;
      box-shadow: 0 16px 40px rgba(0, 0, 0, 0.12);
      transform: translateY(-8px);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: opacity 0.25s, transform 0.25s, visibility 0.25s;
    }

    .ag-nav-links.is-open {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateY(0);
    }

    .ag-nav-link {
      display: block;
      width: 100%;
      padding: 0.85rem 1.25rem;
      border-radius: 0.75rem;
    }
  }
</style>
