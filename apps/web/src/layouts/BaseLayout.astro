---
import '../styles/global.css';
import ScrollToTop from '../components/ScrollToTop.astro';
import StickyCTA from '../components/StickyCTA.astro';

interface Props {
  title: string;
  description?: string;
  /** Overrides og:title / twitter:title (defaults to `title | Zyntel`) */
  ogTitle?: string;
  /** Path under site root, e.g. `/og-default.png` */
  ogImage?: string;
  ogType?: 'website' | 'article';
  noIndex?: boolean;
  hideStickyCta?: boolean;
  /** Production canonical URL override (defaults to `site` + current path) */
  canonicalUrl?: string;
  /** Homepage: inject Organization JSON-LD */
  jsonLdOrganization?: boolean;
}

const {
  title,
  description = 'Kanta by Zyntel — hospital equipment and lab operations platform for East Africa. TAT visibility, QC workflows, maintenance intelligence.',
  ogTitle,
  ogImage = '/og-default.png',
  ogType = 'website',
  noIndex = false,
  hideStickyCta = false,
  canonicalUrl: canonicalUrlProp,
  jsonLdOrganization = false,
} = Astro.props;

const siteOrigin = Astro.site?.origin ?? 'https://zyntel.net';
const canonicalURL = canonicalUrlProp
  ? canonicalUrlProp
  : new URL(Astro.url.pathname, siteOrigin).href;
const ogImageURL = new URL(ogImage.startsWith('/') ? ogImage : `/${ogImage}`, siteOrigin).href;
const socialTitle = ogTitle ?? `${title} | Zyntel`;
const iconV = '20260426';

const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Zyntel Co. Limited',
  url: 'https://zyntel.net',
  sameAs: [
    'https://www.linkedin.com/company/zynteltech',
    'https://x.com/ZyntelTech',
    'https://github.com/zyntel-co-ltd',
  ],
};
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      (function(){
        var k='zyntel-theme',s=localStorage.getItem(k);
        var t=s==='light'||s==='dark'?s:'light';
        document.documentElement.setAttribute('data-theme',t);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f8fafc" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="description" content={description} />
    <meta name="robots" content={noIndex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title} | Zyntel</title>

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Zyntel" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    {jsonLdOrganization && (
      <script type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
    )}

    <link rel="icon" href={`/favicon.ico?v=${iconV}`} sizes="any" />
    <link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${iconV}`} sizes="any" id="favicon-svg" />
    <link rel="icon" type="image/png" href={`/favicon-32x32.png?v=${iconV}`} sizes="32x32" />
    <link rel="apple-touch-icon" href={`/apple-touch-icon.png?v=${iconV}`} />
    <link rel="manifest" href={`/manifest.webmanifest?v=${iconV}`} />
    <script is:inline>
      (function(){
        try {
          var k='zyntel-theme', s=localStorage.getItem(k);
          var t=s==='light'||s==='dark'?s:'light';
          var link=document.getElementById('favicon-svg');
          if (link) link.setAttribute('href', t==='dark' ? '/favicon-dark.svg?v=20260426' : '/favicon.svg?v=20260426');
        } catch (e) {}
      })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <ScrollToTop />
    {!hideStickyCta && <StickyCTA />}
  </body>
</html>
