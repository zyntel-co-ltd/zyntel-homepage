---
import '../styles/global.css';
import ScrollToTop from '../components/ScrollToTop.astro';
import StickyCTA from '../components/StickyCTA.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Zyntel — healthcare-focused web development agency building modern SaaS products and client solutions for enterprises.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      (function(){
        var k='zyntel-theme',s=localStorage.getItem(k);
        var t=s==='light'||s==='dark'?s:'light';
        document.documentElement.setAttribute('data-theme',t);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f8fafc" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <title>{title} | Zyntel</title>

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <ScrollToTop />
    <StickyCTA />
  </body>
</html>
