---
import '../styles/global.css';
import '../styles/admin.css';

interface Props {
  title: string;
  showSidebar?: boolean;
}

const { title, showSidebar = true } = Astro.props;
// Admin app is standalone — always use root paths (no /admin prefix)
const base = '';
const path = (p: string) => base ? (base + (p === '/' ? '' : p)) : (p || '/');
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      (function(){
        window.__ADMIN_BASE__='';
        var p=window.location.pathname.replace(/\/$/,'')||'/';
        var isLogin=p==='/login';
        if(!isLogin&&!sessionStorage.getItem('zyntel_invoice_api_key')){
          window.location.replace('/login');
        }
      })();
    </script>
    <script is:inline>
      (function(){
        var k='zyntel-theme',s=localStorage.getItem(k);
        var t=s==='light'||s==='dark'?s:'light';
        document.documentElement.setAttribute('data-theme',t);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} | Zyntel Admin</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800&display=swap" rel="stylesheet" />
  </head>
  <body class="admin-body">
    <div class="admin-app">
      {showSidebar && (
        <aside class="admin-sidebar">
          <header class="admin-sidebar-header">
            <a href={path('/')} class="admin-logo">
              <img src="/logos/zyntel_logo_cyan.png" alt="" class="admin-logo-img" />
              <span class="admin-logo-text">Zyn<span class="admin-logo-accent">tel</span></span>
              <span class="admin-logo-badge">Admin</span>
            </a>
          </header>
          <nav class="admin-nav">
            <a href={path('/')} class="admin-nav-item" data-active={Astro.url.pathname === '/' ? 'true' : 'false'}>
              <svg class="admin-nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7" rx="1"/>
                <rect x="14" y="3" width="7" height="7" rx="1"/>
                <rect x="14" y="14" width="7" height="7" rx="1"/>
                <rect x="3" y="14" width="7" height="7" rx="1"/>
              </svg>
              <span class="admin-nav-text">Dashboard</span>
            </a>
            <a href={path('/invoices')} class="admin-nav-item" data-active={Astro.url.pathname.startsWith('/invoices') && !Astro.url.pathname.includes('/trash') ? 'true' : 'false'}>
              <svg class="admin-nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
              </svg>
              <span class="admin-nav-text">Invoices</span>
            </a>
            <a href={path('/invoices/trash')} class="admin-nav-item" data-active={Astro.url.pathname.includes('/invoices/trash') ? 'true' : 'false'}>
              <svg class="admin-nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3 6 5 6 21 6"/>
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                <line x1="10" y1="11" x2="10" y2="17"/>
                <line x1="14" y1="11" x2="14" y2="17"/>
              </svg>
              <span class="admin-nav-text">Trash</span>
            </a>
            <a href={path('/clients')} class="admin-nav-item" data-active={Astro.url.pathname.startsWith('/clients') ? 'true' : 'false'}>
              <svg class="admin-nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
              <span class="admin-nav-text">Clients</span>
            </a>
            <a href={path('/banks')} class="admin-nav-item" data-active={Astro.url.pathname.startsWith('/banks') ? 'true' : 'false'}>
              <svg class="admin-nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
                <line x1="1" y1="10" x2="23" y2="10"/>
              </svg>
              <span class="admin-nav-text">Bank accounts</span>
            </a>
            <a href={path('/items')} class="admin-nav-item" data-active={Astro.url.pathname.startsWith('/items') ? 'true' : 'false'}>
              <svg class="admin-nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                <line x1="8" y1="6" x2="16" y2="6"/>
                <line x1="8" y1="10" x2="16" y2="10"/>
              </svg>
              <span class="admin-nav-text">Saved items</span>
            </a>
            <a href="/previews" class="admin-nav-item" data-active={Astro.url.pathname.startsWith('/previews') ? 'true' : undefined}>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="1.5" y="3.5" width="13" height="9" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                <path d="M5 7.5h6M5 10h3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
              Previews
            </a>
            <a href="/pitches" class="admin-nav-item" data-active={Astro.url.pathname.startsWith('/pitches') ? 'true' : undefined}>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 12.5V6.2c0-.8.4-1.6 1.1-2.1l2.1-1.5c1.1-.8 2.6-.8 3.7 0l2.1 1.5c.7.5 1.1 1.3 1.1 2.1v6.3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M5.2 7.3h5.6M5.2 9.6h3.8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
              Pitches
            </a>
            <a href="/maintenance" class="admin-nav-item" data-active={Astro.url.pathname.startsWith('/maintenance') ? 'true' : undefined}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
              </svg>
              <span class="admin-nav-text">Maintenance</span>
            </a>
          </nav>
          <div class="admin-sidebar-footer">
            <a href="/help" class="admin-btn admin-btn-ghost" style="width:100%;text-align:left;margin-bottom:0.5rem;font-size:0.8125rem;display:flex;align-items:center;gap:0.5rem;padding:0.5rem 0.75rem;border-radius:6px;text-decoration:none;color:var(--admin-text-muted);">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/>
              </svg>
              Help & Onboarding guide
            </a>
            <button type="button" class="admin-logout" id="admin-logout">Sign out</button>
          </div>
        </aside>
      )}
      <main class="admin-main">
        <slot />
      </main>
    </div>
    <script>
      (function(){
        var p=window.location.pathname.replace(/\/$/,'')||'/';
        if(p==='/login')return;
        window.__adminUnsavedChanges=false;
        window.__adminClearUnsavedChanges=function(){window.__adminUnsavedChanges=false;};
        window.addEventListener('beforeunload',function(e){
          if(window.__adminUnsavedChanges){e.preventDefault();e.returnValue='';}
        });
        document.addEventListener('change',function(e){
          var t=e.target;
          if(t&&(t.tagName==='INPUT'||t.tagName==='SELECT'||t.tagName==='TEXTAREA')&&t.closest('form')){
            window.__adminUnsavedChanges=true;
          }
        },true);
        document.addEventListener('input',function(e){
          var t=e.target;
          if(t&&(t.tagName==='INPUT'||t.tagName==='SELECT'||t.tagName==='TEXTAREA')&&t.closest('form')){
            window.__adminUnsavedChanges=true;
          }
        },true);
      })();
      document.getElementById('admin-logout')?.addEventListener('click', () => {
        window.__adminClearUnsavedChanges?.();
        sessionStorage.removeItem('zyntel_invoice_api_key');
        window.location.href = '/login';
      });
    </script>
  </body>
</html>
