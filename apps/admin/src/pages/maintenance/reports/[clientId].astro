---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getServiceClientById } from '../../../lib/maintenance.ts';
import { getQuarterlyReports } from '../../../lib/reports.ts';

const { clientId } = Astro.params;

const client = clientId ? await getServiceClientById(clientId) : null;
const reports = client ? await getQuarterlyReports(client.id) : [];

const currentYear = new Date().getFullYear();
const currentQuarter = ('Q' + (Math.floor(new Date().getMonth() / 3) + 1)) as 'Q1' | 'Q2' | 'Q3' | 'Q4';

function quarterToMonths(q: string): string {
  const map: Record<string, string> = { Q1: 'Jan–Mar', Q2: 'Apr–Jun', Q3: 'Jul–Sep', Q4: 'Oct–Dec' };
  return map[q] ?? q;
}

function daysStale(cursorDate: string | null): number | null {
  if (!cursorDate) return null;
  const diff = Date.now() - new Date(cursorDate).getTime();
  return Math.floor(diff / (1000 * 60 * 60 * 24));
}
---
<AdminLayout title={client ? `Reports — ${client.name}` : 'Reports'}>
  <div class="rep-root">
    <header class="admin-header rep-header">
      <div>
        <a href="/maintenance" class="rep-back">← Maintenance</a>
        <h1 class="admin-title">
          {client ? `${client.name} — Reports` : 'Reports'}
        </h1>
        {client && (
          <p class="admin-subtitle">{client.productName} · {client.contactName}</p>
        )}
      </div>
      {client && (
        <div style="display:flex;gap:8px;align-items:center;flex-shrink:0;flex-wrap:wrap;">
          <a href={`/case-studies/${client.id}`} class="admin-btn admin-btn-secondary" style="font-size:0.8125rem;">
            Case Studies →
          </a>
          <button id="btn-log-activity" class="admin-btn admin-btn-secondary" type="button">
            + Log Activity
          </button>
          <button id="btn-generate-report" class="admin-btn admin-btn-primary" type="button">
            + Generate Report
          </button>
        </div>
      )}
    </header>

    {!client && (
      <div class="admin-card" style="padding:2rem;text-align:center;color:var(--admin-text-muted);">
        Service client not found. <a href="/maintenance" style="color:var(--admin-accent);">Go back</a>
      </div>
    )}

    {client && (
      <>
        <!-- Quarterly Reports -->
        <section class="rep-section">
          <div class="rep-section-header">
            <h2 class="rep-section-title">Quarterly Reports</h2>
            <span class="rep-count">{reports.length} report{reports.length !== 1 ? 's' : ''}</span>
          </div>

          {reports.length === 0 ? (
            <div class="rep-empty">
              No reports yet. Use "Generate Report" to create one. Reports pull from GitHub commits, Sentry, ROI snapshots, and manually logged activities.
            </div>
          ) : (
            <div class="admin-table-wrap">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>Period</th>
                    <th>Title</th>
                    <th>Data current as of</th>
                    <th>Status</th>
                    <th>Generated</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  {reports.map((r) => {
                    const stale = daysStale(r.dataCursorDate);
                    const needsRefresh = r.status === 'draft' && stale !== null && stale > 0;
                    return (
                      <tr data-report-id={r.id}>
                        <td style="white-space:nowrap;font-weight:600;">{r.quarter} {r.year}</td>
                        <td style="max-width:260px;">{r.title}</td>
                        <td style="font-size:0.75rem;">
                          {r.dataCursorDate ? (
                            <span class={needsRefresh ? 'cursor-stale' : 'cursor-ok'}>
                              {r.dataCursorDate}
                              {needsRefresh && <span class="stale-badge">{stale}d old</span>}
                            </span>
                          ) : (
                            <span style="color:var(--admin-text-muted);">—</span>
                          )}
                        </td>
                        <td>
                          <span class={`rep-badge rep-badge--${r.status}`}>{r.status}</span>
                        </td>
                        <td style="font-size:0.75rem;color:var(--admin-text-muted);white-space:nowrap;">
                          {r.generatedAt.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                        </td>
                        <td>
                          <div style="display:flex;gap:4px;justify-content:flex-end;flex-wrap:wrap;">
                            <button class="act-btn" data-view-report={r.id} type="button">View</button>
                            {r.status === 'draft' && (
                              <button class="act-btn act-btn--refresh" data-refresh-report={r.id}
                                data-quarter={r.quarter} data-year={r.year} type="button">Refresh</button>
                            )}
                            <a class="act-btn" href={`/api/maintenance/report-pdf?reportId=${r.id}`}
                              target="_blank" rel="noopener">PDF</a>
                            <button class="act-btn act-btn--danger" data-del-report={r.id} type="button">Delete</button>
                          </div>
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          )}
        </section>

        <!-- Maintenance Activity Log -->
        <section class="rep-section" style="margin-top:1.5rem;">
          <div class="rep-section-header">
            <h2 class="rep-section-title">Maintenance Activity Log</h2>
            <div style="display:flex;gap:8px;align-items:center;">
              <select id="log-filter-type" class="admin-form-input" style="font-size:0.8rem;padding:4px 8px;height:auto;">
                <option value="">All types</option>
                <option value="incident">Incidents</option>
                <option value="preventive">Preventive</option>
                <option value="support">Support</option>
              </select>
            </div>
          </div>
          <div id="activity-log-body">
            <div class="rep-empty">Loading activity log…</div>
          </div>
        </section>
      </>
    )}

    <div id="toast-root-rep"></div>

    <!-- Modal: Generate report -->
    <div id="modal-gen-report" class="preview-modal-overlay" style="display:none;">
      <div class="modal">
        <h3>Generate Quarterly Report</h3>
        <p style="font-size:0.8125rem;color:var(--admin-text-muted);margin-top:-0.25rem;">
          Pulls from GitHub commits, Sentry errors, ROI snapshots, and logged activities. If a draft already exists for the period it will be refreshed in place.
        </p>
        <div id="gen-existing-warning" style="display:none;background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.3);border-radius:6px;padding:8px 12px;font-size:0.8125rem;color:#92400e;margin-bottom:8px;">
          A draft report already exists for this period — generating will refresh it with the latest data.
        </div>
        <form id="form-gen-report" class="grid-form">
          <div>
            <label>Quarter</label>
            <select id="gen-quarter" class="admin-form-input" required>
              <option value="Q1">Q1 (Jan–Mar)</option>
              <option value="Q2">Q2 (Apr–Jun)</option>
              <option value="Q3">Q3 (Jul–Sep)</option>
              <option value="Q4">Q4 (Oct–Dec)</option>
            </select>
          </div>
          <div>
            <label>Year</label>
            <input id="gen-year" type="number" class="admin-form-input" min="2020" max="2099" value={currentYear} required />
          </div>
          <div class="full" style="background:var(--admin-bg-elevated);border-radius:6px;padding:10px 12px;font-size:0.8125rem;color:var(--admin-text-muted);">
            <strong style="color:var(--admin-text);">Auto-pulled sources:</strong>
            {client?.repoUrl ? `✓ GitHub (${client.repoUrl.replace('https://github.com/', '')})` : '✗ No GitHub repo configured'}
            {' · '}
            {client?.sentryUrl ? '✓ Sentry configured' : '✗ No Sentry URL'}
            {' · '}
            ROI snapshots · Maintenance logs
          </div>
          <div class="modal-actions full">
            <button type="button" class="admin-btn admin-btn-secondary" data-close="modal-gen-report">Cancel</button>
            <button class="admin-btn admin-btn-primary" type="submit" id="btn-gen-submit">Generate</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Modal: Log activity -->
    <div id="modal-log-activity" class="preview-modal-overlay" style="display:none;">
      <div class="modal modal--wide">
        <h3>Log Maintenance Activity</h3>

        <div class="log-templates">
          <span style="font-size:0.75rem;font-weight:600;color:var(--admin-text-muted);text-transform:uppercase;letter-spacing:.04em;">Quick templates</span>
          <div class="log-template-row">
            <button type="button" class="log-tpl-btn" data-tpl="incident"><span class="log-tpl-icon">⚠</span><span>Incident</span></button>
            <button type="button" class="log-tpl-btn" data-tpl="deploy-fix"><span class="log-tpl-icon">⚙</span><span>Deploy Fix</span></button>
            <button type="button" class="log-tpl-btn" data-tpl="preventive-check"><span class="log-tpl-icon">✓</span><span>Health Check</span></button>
            <button type="button" class="log-tpl-btn" data-tpl="db-maintenance"><span class="log-tpl-icon">🗄</span><span>DB Maintenance</span></button>
            <button type="button" class="log-tpl-btn" data-tpl="support"><span class="log-tpl-icon">💬</span><span>Support Request</span></button>
            <button type="button" class="log-tpl-btn" data-tpl="monitoring"><span class="log-tpl-icon">📊</span><span>Monitoring Alert</span></button>
          </div>
        </div>

        <form id="form-log-activity" class="grid-form" style="margin-top:1rem;">
          <div>
            <label>Type *</label>
            <select id="log-type" class="admin-form-input" required>
              <option value="incident">Incident</option>
              <option value="preventive">Preventive</option>
              <option value="support">Support</option>
            </select>
          </div>
          <div>
            <label>Date *</label>
            <input id="log-date" type="date" class="admin-form-input" required />
          </div>
          <div class="full">
            <label>Area / Component *</label>
            <input id="log-area" class="admin-form-input" required placeholder="e.g. Payments, Auth, Deployment, Database" />
          </div>
          <div class="full">
            <label>Summary *</label>
            <textarea id="log-summary" class="admin-form-input" rows="2" required placeholder="What happened or what was done"></textarea>
          </div>
          <div class="full">
            <label>Action Taken</label>
            <textarea id="log-action" class="admin-form-input" rows="2" placeholder="Steps taken to resolve or maintain"></textarea>
          </div>
          <div class="full">
            <label>Outcome</label>
            <textarea id="log-outcome" class="admin-form-input" rows="2" placeholder="Result — resolved, ongoing, monitoring, etc."></textarea>
          </div>
          <div>
            <label>Logged By *</label>
            <input id="log-by" class="admin-form-input" required placeholder="Your name" />
          </div>
          <div class="modal-actions full">
            <button type="button" class="admin-btn admin-btn-secondary" data-close="modal-log-activity">Cancel</button>
            <button class="admin-btn admin-btn-primary" type="submit" id="btn-log-submit">Save activity</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Modal: View / edit report -->
    <div id="modal-view-report" class="preview-modal-overlay" style="display:none;">
      <div class="modal modal--report">
        <div class="rep-modal-header">
          <h3 id="view-report-title">Report</h3>
          <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
            <span id="view-report-status" class="rep-badge"></span>
            <a id="btn-download-pdf" class="admin-btn admin-btn-secondary" href="#" target="_blank" rel="noopener"
              style="font-size:0.75rem;">Download PDF</a>
            <button id="btn-finalize-report" class="admin-btn admin-btn-secondary" type="button" style="font-size:0.75rem;">Mark as Final</button>
            <button type="button" class="admin-btn admin-btn-secondary" data-close="modal-view-report" style="font-size:0.75rem;">Close</button>
          </div>
        </div>
        <div id="view-report-content" class="rep-markdown-body"></div>
        <div class="rep-modal-edit-row">
          <details class="rep-edit-details">
            <summary>Edit Markdown</summary>
            <textarea id="edit-report-md" class="admin-form-input rep-md-editor" rows="20"></textarea>
            <div style="margin-top:8px;display:flex;gap:8px;">
              <button id="btn-save-report-md" class="admin-btn admin-btn-primary" type="button">Save changes</button>
              <button id="btn-preview-md" class="admin-btn admin-btn-secondary" type="button">Preview</button>
            </div>
          </details>
        </div>
      </div>
    </div>

    <!-- Confirm -->
    <div id="modal-confirm-rep" class="preview-modal-overlay" style="display:none;">
      <div class="modal modal--narrow">
        <h3 id="rep-confirm-title"></h3>
        <p id="rep-confirm-message" style="color:var(--admin-text-muted);font-size:0.875rem;margin-top:-0.5rem;"></p>
        <div class="modal-actions">
          <button type="button" class="admin-btn admin-btn-secondary" data-close="modal-confirm-rep">Cancel</button>
          <button id="rep-confirm-btn" type="button" class="admin-btn admin-btn-primary">Confirm</button>
        </div>
      </div>
    </div>
  </div>

  <style>
    .rep-root { margin: 0 auto; max-width: 1120px; }
    .rep-header { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 12px; }
    .rep-back { font-size: 0.875rem; color: var(--admin-text-muted); text-decoration: none; display: inline-flex; align-items: center; gap: 4px; margin-bottom: 6px; }
    .rep-back:hover { color: var(--admin-text); }

    .rep-section { background: var(--admin-card); border: 1px solid var(--admin-border); border-radius: 10px; overflow: hidden; }
    .rep-section-header { display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; border-bottom: 1px solid var(--admin-border); }
    .rep-section-title { font-size: 0.9375rem; font-weight: 700; color: var(--admin-text); margin: 0; }
    .rep-count { font-size: 0.75rem; color: var(--admin-text-muted); font-weight: 600; }
    .rep-empty { padding: 2rem; text-align: center; color: var(--admin-text-muted); font-size: 0.875rem; }

    .rep-badge { display: inline-block; padding: 2px 10px; border-radius: 999px; font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; }
    .rep-badge--draft { background: rgba(245,158,11,.12); color: #92400e; }
    .rep-badge--final { background: rgba(22,163,74,.12); color: #166534; }

    .cursor-ok { color: var(--admin-text-muted); }
    .cursor-stale { color: #92400e; font-weight: 600; }
    .stale-badge { display: inline-block; background: rgba(245,158,11,.18); color: #92400e; border-radius: 999px; font-size: 0.65rem; font-weight: 700; padding: 1px 6px; margin-left: 5px; }

    .act-btn--refresh { background: rgba(99,91,255,.08); color: var(--admin-accent); border-color: rgba(99,91,255,.2); }
    .act-btn--refresh:hover { background: rgba(99,91,255,.15); }

    #activity-log-body .admin-table-wrap { overflow-x: auto; }
    .log-type-badge { display: inline-block; padding: 2px 8px; border-radius: 999px; font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; }
    .log-type-incident { background: rgba(239,68,68,.1); color: #b91c1c; }
    .log-type-preventive { background: rgba(22,163,74,.1); color: #166534; }
    .log-type-support { background: rgba(99,91,255,.1); color: #4338ca; }

    .log-templates { background: var(--admin-bg-elevated); border-radius: 8px; padding: 12px 14px; }
    .log-template-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px; }
    .log-tpl-btn { display: flex; align-items: center; gap: 6px; padding: 6px 12px; border: 1px solid var(--admin-border); border-radius: 6px; background: var(--admin-card); cursor: pointer; font-size: 0.8125rem; color: var(--admin-text); transition: background 0.15s; }
    .log-tpl-btn:hover { background: var(--admin-bg-elevated); border-color: var(--admin-accent); color: var(--admin-accent); }
    .log-tpl-icon { font-size: 1rem; }

    .modal--report { width: min(860px, 98vw); max-height: 90vh; overflow-y: auto; display: flex; flex-direction: column; }
    .modal--wide { width: min(680px, 98vw); }
    .modal--narrow { width: min(440px, 100%); }
    .rep-modal-header { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; flex-shrink: 0; }
    .rep-modal-header h3 { margin: 0; font-size: 1rem; }
    .rep-modal-edit-row { margin-top: 16px; flex-shrink: 0; }
    .rep-edit-details { border: 1px solid var(--admin-border); border-radius: 8px; padding: 10px 14px; }
    .rep-edit-details summary { cursor: pointer; font-size: 0.8125rem; font-weight: 600; color: var(--admin-text); }
    .rep-md-editor { font-family: ui-monospace, SFMono-Regular, monospace; font-size: 0.8125rem; margin-top: 10px; }

    .rep-markdown-body { font-size: 0.9rem; line-height: 1.65; color: var(--admin-text); flex: 1; overflow-y: auto; }
    .rep-markdown-body h1 { font-size: 1.375rem; font-weight: 800; margin: 1.2em 0 0.5em; }
    .rep-markdown-body h2 { font-size: 1.1rem; font-weight: 700; margin: 1.1em 0 0.4em; border-bottom: 1px solid var(--admin-border); padding-bottom: 4px; }
    .rep-markdown-body h3 { font-size: 0.9375rem; font-weight: 700; margin: 0.9em 0 0.3em; }
    .rep-markdown-body p { margin: 0.6em 0; }
    .rep-markdown-body ul, .rep-markdown-body ol { margin: 0.5em 0 0.5em 1.4em; }
    .rep-markdown-body li { margin: 0.25em 0; }
    .rep-markdown-body code { font-family: ui-monospace, SFMono-Regular, monospace; font-size: 0.8125rem; background: var(--admin-bg-elevated); border: 1px solid var(--admin-border); padding: 1px 6px; border-radius: 4px; }
    .rep-markdown-body pre { background: var(--admin-bg-elevated); border: 1px solid var(--admin-border); border-radius: 8px; padding: 12px 14px; overflow-x: auto; }
    .rep-markdown-body pre code { background: none; border: none; padding: 0; }
    .rep-markdown-body blockquote { border-left: 3px solid var(--admin-accent); padding-left: 12px; margin: 0.6em 0; color: var(--admin-text-muted); font-style: italic; }
    .rep-markdown-body hr { border: none; border-top: 1px solid var(--admin-border); margin: 1.2em 0; }
    .rep-markdown-body strong { font-weight: 700; }
    .rep-markdown-body table { width: 100%; border-collapse: collapse; font-size: 0.85rem; margin: 0.8em 0; }
    .rep-markdown-body th { background: var(--admin-bg-elevated); font-weight: 700; text-align: left; padding: 6px 10px; border: 1px solid var(--admin-border); font-size: 0.8rem; }
    .rep-markdown-body td { padding: 6px 10px; border: 1px solid var(--admin-border); vertical-align: top; }
    .rep-markdown-body tr:nth-child(even) td { background: var(--admin-bg-elevated); }

    #toast-root-rep { position: fixed; right: 16px; bottom: 16px; display: flex; flex-direction: column; gap: 8px; z-index: 2000; pointer-events: none; }
    .toast { background: var(--admin-text); color: var(--admin-card); border-radius: 8px; padding: 10px 14px; font-size: 0.8125rem; min-width: 260px; pointer-events: auto; box-shadow: 0 4px 12px rgba(0,0,0,.2); }
    .toast.error { background: #7f1d1d; color: #fff; }
  </style>

  <script define:vars={{ clientId, currentQuarter, currentYear, reportsJson: JSON.stringify(reports.map(r => ({ id: r.id, quarter: r.quarter, year: r.year, status: r.status }))) }}>
    const existingReports = JSON.parse(reportsJson);

    function showToast(msg, type = 'success') {
      const t = document.createElement('div');
      t.className = `toast${type === 'error' ? ' error' : ''}`;
      t.textContent = msg;
      document.getElementById('toast-root-rep').appendChild(t);
      setTimeout(() => t.remove(), 5000);
    }
    function showModal(id) { const el = document.getElementById(id); if (el) el.style.display = 'flex'; }
    function closeModal(id) { const el = document.getElementById(id); if (el) el.style.display = 'none'; }
    document.addEventListener('click', (e) => {
      const c = e.target.closest('[data-close]');
      if (c) closeModal(c.dataset.close);
    });
    document.querySelectorAll('.preview-modal-overlay').forEach((o) =>
      o.addEventListener('click', (e) => { if (e.target === o) closeModal(o.id); })
    );

    let repConfirmCallback = null;
    function openConfirm(opts) {
      document.getElementById('rep-confirm-title').textContent = opts.title;
      document.getElementById('rep-confirm-message').textContent = opts.message;
      document.getElementById('rep-confirm-btn').textContent = opts.label || 'Confirm';
      repConfirmCallback = opts.onConfirm;
      showModal('modal-confirm-rep');
    }
    document.getElementById('rep-confirm-btn').addEventListener('click', async () => {
      if (repConfirmCallback) await repConfirmCallback();
      closeModal('modal-confirm-rep');
    });

    // ── Markdown renderer ──────────────────────────────────────────────────
    function renderMarkdown(md) {
      if (!md) return '';
      const lines = md.split('\n');
      const out = [];
      let inUl = false, inTable = false, tableHeader = false;
      function flushList() { if (inUl) { out.push('</ul>'); inUl = false; } }
      function flushTable() { if (inTable) { out.push('</tbody></table>'); inTable = false; tableHeader = false; } }
      for (let i = 0; i < lines.length; i++) {
        const line = lines[i].trimEnd();
        if (/^---+$/.test(line.trim())) { flushList(); flushTable(); out.push('<hr>'); continue; }
        if (/^\|/.test(line)) {
          flushList();
          if (!inTable) { out.push('<table><thead>'); inTable = true; tableHeader = true; }
          const cells = line.split('|').slice(1, -1).map((c) => c.trim());
          if (cells.every((c) => /^-+$/.test(c))) { out.push('</thead><tbody>'); tableHeader = false; continue; }
          const tag = tableHeader ? 'th' : 'td';
          out.push(`<tr>${cells.map((c) => `<${tag}>${inlineFormat(c)}</${tag}>`).join('')}</tr>`);
          continue;
        }
        flushTable();
        const h3 = line.match(/^### (.+)/); if (h3) { flushList(); out.push(`<h3>${inlineFormat(h3[1])}</h3>`); continue; }
        const h2 = line.match(/^## (.+)/);  if (h2) { flushList(); out.push(`<h2>${inlineFormat(h2[1])}</h2>`); continue; }
        const h1 = line.match(/^# (.+)/);   if (h1) { flushList(); out.push(`<h1>${inlineFormat(h1[1])}</h1>`); continue; }
        const bq = line.match(/^> (.+)/);   if (bq) { flushList(); out.push(`<blockquote><p>${inlineFormat(bq[1])}</p></blockquote>`); continue; }
        const li = line.match(/^- (.+)/);
        if (li) { if (!inUl) { out.push('<ul>'); inUl = true; } out.push(`<li>${inlineFormat(li[1])}</li>`); continue; }
        flushList();
        if (!line.trim()) continue;
        out.push(`<p>${inlineFormat(line)}</p>`);
      }
      flushList(); flushTable();
      return out.join('\n');
    }
    function inlineFormat(text) {
      return text
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        .replace(/(?<!\*)\*(?!\*)([^*]+)(?<!\*)\*(?!\*)/g, '<em>$1</em>')
        .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');
    }

    // ── Activity log ──────────────────────────────────────────────────────
    async function loadActivityLog(typeFilter) {
      const el = document.getElementById('activity-log-body');
      if (!el) return;
      let url = `/api/maintenance/logs?serviceClientId=${encodeURIComponent(clientId)}`;
      if (typeFilter) url += `&type=${typeFilter}`;
      const res = await fetch(url);
      const logs = await res.json().catch(() => []);
      if (!logs.length) {
        el.innerHTML = '<div class="rep-empty">No activity logged yet. Use "Log Activity" to add the first entry.</div>';
        return;
      }
      el.innerHTML = `<div class="admin-table-wrap"><table class="admin-table">
        <thead><tr><th>Date</th><th>Type</th><th>Area</th><th>Summary</th><th>Outcome</th><th>Logged by</th><th></th></tr></thead>
        <tbody>
          ${logs.map((l) => `<tr>
            <td style="white-space:nowrap;font-size:0.8125rem;">${l.logDate}</td>
            <td><span class="log-type-badge log-type-${l.type}">${l.type}</span></td>
            <td style="font-size:0.8125rem;white-space:nowrap;">${l.area}</td>
            <td style="max-width:300px;font-size:0.875rem;">${l.summary}</td>
            <td style="font-size:0.8rem;color:var(--admin-text-muted);max-width:200px;">${l.outcome || l.actionTaken || '—'}</td>
            <td style="font-size:0.8rem;color:var(--admin-text-muted);">${l.loggedBy}</td>
            <td><button class="act-btn act-btn--danger" data-del-log="${l.id}" type="button">Delete</button></td>
          </tr>`).join('')}
        </tbody>
      </table></div>`;
    }
    document.getElementById('log-filter-type').addEventListener('change', (e) => loadActivityLog(e.target.value));
    loadActivityLog('');

    document.addEventListener('click', async (e) => {
      const delLog = e.target.closest('[data-del-log]');
      if (delLog) {
        const id = delLog.dataset.delLog;
        openConfirm({
          title: 'Delete log entry?', message: 'This cannot be undone.', label: 'Delete',
          onConfirm: async () => {
            const res = await fetch(`/api/maintenance/logs?id=${encodeURIComponent(id)}`, { method: 'DELETE' });
            if (!res.ok) { showToast('Failed to delete', 'error'); return; }
            showToast('Log entry deleted');
            loadActivityLog(document.getElementById('log-filter-type').value);
          },
        });
      }
    });

    // ── Log activity modal ────────────────────────────────────────────────
    document.getElementById('btn-log-activity').addEventListener('click', () => {
      document.getElementById('log-date').value = new Date().toISOString().slice(0, 10);
      showModal('modal-log-activity');
    });

    const TEMPLATES = {
      incident: { type: 'incident', area: '', summary: '', action: 'Investigated root cause. ', outcome: 'Resolved — ' },
      'deploy-fix': { type: 'preventive', area: 'Deployment', summary: 'Deployment fix applied — ', action: 'Updated configuration and redeployed.', outcome: 'Resolved — deployment stable.' },
      'preventive-check': { type: 'preventive', area: 'System Health', summary: 'Routine health check performed.', action: 'Verified uptime, error rates, DB connections, and response times.', outcome: 'All systems nominal.' },
      'db-maintenance': { type: 'preventive', area: 'Database', summary: 'Database maintenance — ', action: '', outcome: '' },
      support: { type: 'support', area: '', summary: '', action: 'Assisted client. ', outcome: 'Resolved.' },
      monitoring: { type: 'incident', area: 'Monitoring', summary: 'Monitoring alert triggered — ', action: 'Investigated alert.', outcome: '' },
    };
    document.querySelectorAll('.log-tpl-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const tpl = TEMPLATES[btn.dataset.tpl];
        if (!tpl) return;
        document.getElementById('log-type').value = tpl.type;
        document.getElementById('log-area').value = tpl.area;
        document.getElementById('log-summary').value = tpl.summary;
        document.getElementById('log-action').value = tpl.action;
        document.getElementById('log-outcome').value = tpl.outcome;
        document.getElementById('log-area').focus();
      });
    });

    document.getElementById('form-log-activity').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('btn-log-submit');
      btn.disabled = true;
      try {
        const body = {
          serviceClientId: clientId,
          type: document.getElementById('log-type').value,
          logDate: document.getElementById('log-date').value,
          area: document.getElementById('log-area').value.trim(),
          summary: document.getElementById('log-summary').value.trim(),
          actionTaken: document.getElementById('log-action').value.trim() || null,
          outcome: document.getElementById('log-outcome').value.trim() || null,
          loggedBy: document.getElementById('log-by').value.trim(),
        };
        const res = await fetch('/api/maintenance/logs', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) { showToast(data.error || 'Failed to save', 'error'); return; }
        closeModal('modal-log-activity');
        showToast('Activity logged');
        document.getElementById('form-log-activity').reset();
        loadActivityLog(document.getElementById('log-filter-type').value);
      } finally { btn.disabled = false; }
    });

    // ── Generate report ───────────────────────────────────────────────────
    const genSelect = document.getElementById('gen-quarter');
    if (genSelect) genSelect.value = currentQuarter;

    function updateGenWarning() {
      const q = document.getElementById('gen-quarter').value;
      const y = Number(document.getElementById('gen-year').value);
      const existing = existingReports.find(r => r.quarter === q && r.year === y);
      const warn = document.getElementById('gen-existing-warning');
      if (existing && existing.status === 'draft') {
        warn.style.display = 'block';
        warn.textContent = 'A draft report already exists for this period — generating will refresh it with the latest data.';
      } else if (existing && existing.status === 'final') {
        warn.style.display = 'block';
        warn.textContent = 'This report has been marked as final and cannot be regenerated.';
        warn.style.color = '#b91c1c';
        warn.style.background = 'rgba(239,68,68,.08)';
        warn.style.borderColor = 'rgba(239,68,68,.2)';
      } else {
        warn.style.display = 'none';
      }
    }

    document.getElementById('gen-quarter').addEventListener('change', updateGenWarning);
    document.getElementById('gen-year').addEventListener('input', updateGenWarning);
    document.getElementById('btn-generate-report').addEventListener('click', () => {
      updateGenWarning();
      showModal('modal-gen-report');
    });

    async function runGenerate(quarter, year) {
      const btn = document.getElementById('btn-gen-submit');
      const orig = btn ? btn.textContent : '';
      if (btn) { btn.disabled = true; btn.textContent = 'Generating…'; }
      try {
        const res = await fetch('/api/maintenance/generate-report', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ serviceClientId: clientId, quarter, year }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          showToast(data.error || 'Failed to generate report', 'error');
          return false;
        }
        const src = data._sources ?? {};
        const parts = [];
        if (src.aiGenerated) parts.push('AI-written');
        if (src.commits) parts.push(`${src.commits} commits`);
        if (src.roiSnapshots) parts.push(`${src.roiSnapshots} metrics`);
        if (src.sentryIssues) parts.push(`${src.sentryIssues} Sentry issues`);
        const verb = data.wasUpdated ? 'refreshed' : 'generated';
        showToast(`Report ${verb}${parts.length ? ' (' + parts.join(', ') + ')' : ''} — reloading…`);
        return true;
      } catch {
        showToast('Network error', 'error');
        return false;
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = orig; }
      }
    }

    document.getElementById('form-gen-report').addEventListener('submit', async (e) => {
      e.preventDefault();
      const quarter = document.getElementById('gen-quarter').value;
      const year = Number(document.getElementById('gen-year').value);
      // Block if final
      const existing = existingReports.find(r => r.quarter === quarter && r.year === year);
      if (existing && existing.status === 'final') {
        showToast('This report is final. Delete it first to regenerate.', 'error');
        return;
      }
      const ok = await runGenerate(quarter, year);
      if (ok) { closeModal('modal-gen-report'); setTimeout(() => window.location.reload(), 1200); }
    });

    // ── Refresh report (inline button) ────────────────────────────────────
    document.addEventListener('click', async (e) => {
      const refreshBtn = e.target.closest('[data-refresh-report]');
      if (refreshBtn) {
        const quarter = refreshBtn.dataset.quarter;
        const year = Number(refreshBtn.dataset.year);
        refreshBtn.disabled = true;
        refreshBtn.textContent = '…';
        const ok = await runGenerate(quarter, year);
        if (ok) setTimeout(() => window.location.reload(), 1200);
        else { refreshBtn.disabled = false; refreshBtn.textContent = 'Refresh'; }
      }
    });

    // ── View / edit report ────────────────────────────────────────────────
    let currentReportId = null;
    document.addEventListener('click', async (e) => {
      const viewBtn = e.target.closest('[data-view-report]');
      if (viewBtn) {
        const id = viewBtn.dataset.viewReport;
        currentReportId = id;
        const res = await fetch(`/api/maintenance/reports?id=${encodeURIComponent(id)}`);
        const report = await res.json().catch(() => null);
        if (!report) { showToast('Failed to load report', 'error'); return; }
        document.getElementById('view-report-title').textContent = report.title;
        const statusBadge = document.getElementById('view-report-status');
        statusBadge.textContent = report.status;
        statusBadge.className = `rep-badge rep-badge--${report.status}`;
        document.getElementById('view-report-content').innerHTML = renderMarkdown(report.markdownContent || '');
        document.getElementById('edit-report-md').value = report.markdownContent || '';
        const finalBtn = document.getElementById('btn-finalize-report');
        if (finalBtn) finalBtn.style.display = report.status === 'final' ? 'none' : '';
        const pdfBtn = document.getElementById('btn-download-pdf');
        if (pdfBtn) pdfBtn.href = `/api/maintenance/report-pdf?reportId=${encodeURIComponent(id)}`;
        showModal('modal-view-report');
      }

      const delBtn = e.target.closest('[data-del-report]');
      if (delBtn) {
        const id = delBtn.dataset.delReport;
        openConfirm({
          title: 'Delete report?', message: 'This cannot be undone.', label: 'Delete',
          onConfirm: async () => {
            const res = await fetch(`/api/maintenance/reports?id=${encodeURIComponent(id)}`, { method: 'DELETE' });
            if (!res.ok) { showToast('Failed to delete', 'error'); return; }
            showToast('Report deleted');
            setTimeout(() => window.location.reload(), 800);
          },
        });
      }
    });

    document.getElementById('btn-save-report-md').addEventListener('click', async () => {
      if (!currentReportId) return;
      const markdownContent = document.getElementById('edit-report-md').value;
      const res = await fetch('/api/maintenance/reports', {
        method: 'PATCH', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: currentReportId, markdownContent }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) { showToast(data.error || 'Save failed', 'error'); return; }
      document.getElementById('view-report-content').innerHTML = renderMarkdown(markdownContent);
      showToast('Changes saved');
    });

    document.getElementById('btn-preview-md').addEventListener('click', () => {
      const md = document.getElementById('edit-report-md').value;
      document.getElementById('view-report-content').innerHTML = renderMarkdown(md);
      showToast('Preview updated');
    });

    document.getElementById('btn-finalize-report').addEventListener('click', async () => {
      if (!currentReportId) return;
      const res = await fetch('/api/maintenance/reports', {
        method: 'PATCH', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: currentReportId, status: 'final' }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) { showToast(data.error || 'Failed', 'error'); return; }
      document.getElementById('view-report-status').textContent = 'final';
      document.getElementById('view-report-status').className = 'rep-badge rep-badge--final';
      document.getElementById('btn-finalize-report').style.display = 'none';
      showToast('Report marked as final');
      const row = document.querySelector(`[data-report-id="${currentReportId}"]`);
      if (row) {
        const badge = row.querySelector('.rep-badge');
        if (badge) { badge.textContent = 'final'; badge.className = 'rep-badge rep-badge--final'; }
        const refreshBtn = row.querySelector('[data-refresh-report]');
        if (refreshBtn) refreshBtn.remove();
      }
    });
  </script>
</AdminLayout>
