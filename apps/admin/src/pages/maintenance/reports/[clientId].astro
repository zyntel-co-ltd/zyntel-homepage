---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getServiceClientById } from '../../../lib/maintenance.ts';
import { getQuarterlyReports, getCaseStudies } from '../../../lib/reports.ts';

const { clientId } = Astro.params;

const client = clientId ? await getServiceClientById(clientId) : null;
const reports = client ? await getQuarterlyReports(client.id) : [];
const caseStudies = client ? await getCaseStudies(client.id) : [];

const currentYear = new Date().getFullYear();
const currentQuarter = ('Q' + (Math.floor(new Date().getMonth() / 3) + 1)) as 'Q1' | 'Q2' | 'Q3' | 'Q4';
---
<AdminLayout title={client ? `Reports — ${client.name}` : 'Reports'}>
  <div class="rep-root">
    <header class="admin-header rep-header">
      <div>
        <a href="/maintenance" class="rep-back">← Maintenance</a>
        <h1 class="admin-title">
          {client ? `${client.name} — Reports` : 'Reports'}
        </h1>
        {client && (
          <p class="admin-subtitle">{client.productName} · {client.contactName}</p>
        )}
      </div>
      {client && (
        <div style="display:flex;gap:8px;align-items:center;flex-shrink:0;">
          <button id="btn-generate-report" class="admin-btn admin-btn-primary" type="button">
            + Generate Quarterly Report
          </button>
        </div>
      )}
    </header>

    {!client && (
      <div class="admin-card" style="padding:2rem;text-align:center;color:var(--admin-text-muted);">
        Service client not found. <a href="/maintenance" style="color:var(--admin-accent);">Go back</a>
      </div>
    )}

    {client && (
      <>
        <!-- Quarterly Reports -->
        <section class="rep-section">
          <div class="rep-section-header">
            <h2 class="rep-section-title">Quarterly Reports</h2>
            <span class="rep-count">{reports.length} report{reports.length !== 1 ? 's' : ''}</span>
          </div>

          {reports.length === 0 ? (
            <div class="rep-empty">
              No reports yet. Generate your first quarterly report using the button above.
            </div>
          ) : (
            <div class="admin-table-wrap">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>Period</th>
                    <th>Title</th>
                    <th>Status</th>
                    <th>Generated</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  {reports.map((r) => (
                    <tr data-report-id={r.id}>
                      <td style="white-space:nowrap;font-weight:600;">{r.quarter} {r.year}</td>
                      <td style="max-width:320px;">{r.title}</td>
                      <td>
                        <span class={`rep-badge rep-badge--${r.status}`}>{r.status}</span>
                      </td>
                      <td style="font-size:0.75rem;color:var(--admin-text-muted);white-space:nowrap;">
                        {r.generatedAt.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                      </td>
                      <td style="display:flex;gap:6px;justify-content:flex-end;">
                        <button
                          class="act-btn"
                          data-view-report={r.id}
                          type="button"
                        >View</button>
                        <button
                          class="act-btn act-btn--danger"
                          data-del-report={r.id}
                          type="button"
                        >Delete</button>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </section>

        <!-- Case Studies -->
        <section class="rep-section" style="margin-top:1.5rem;">
          <div class="rep-section-header">
            <h2 class="rep-section-title">Case Studies</h2>
            <button id="btn-new-case-study" class="admin-btn admin-btn-secondary" type="button" style="font-size:0.8125rem;">
              + New Case Study
            </button>
          </div>

          {caseStudies.length === 0 ? (
            <div class="rep-empty">No case studies yet.</div>
          ) : (
            <div class="admin-table-wrap">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>Title</th>
                    <th>Status</th>
                    <th>Tags</th>
                    <th>Created</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  {caseStudies.map((cs) => (
                    <tr data-cs-id={cs.id}>
                      <td style="max-width:280px;font-weight:600;">{cs.title}</td>
                      <td>
                        <span class={`rep-badge rep-badge--${cs.status}`}>{cs.status}</span>
                      </td>
                      <td style="font-size:0.75rem;">
                        {cs.tags.length ? cs.tags.join(', ') : '—'}
                      </td>
                      <td style="font-size:0.75rem;color:var(--admin-text-muted);white-space:nowrap;">
                        {cs.createdAt.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                      </td>
                      <td style="display:flex;gap:6px;justify-content:flex-end;">
                        <button class="act-btn" data-view-cs={cs.id} type="button">View</button>
                        <button class="act-btn act-btn--danger" data-del-cs={cs.id} type="button">Delete</button>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </section>
      </>
    )}

    <!-- Toast -->
    <div id="toast-root-rep"></div>

    <!-- Modal: Generate report -->
    <div id="modal-gen-report" class="preview-modal-overlay" style="display:none;">
      <div class="modal">
        <h3>Generate Quarterly Report</h3>
        <form id="form-gen-report" class="grid-form">
          <div>
            <label>Quarter</label>
            <select id="gen-quarter" class="admin-form-input" required>
              <option value="Q1">Q1 (Jan–Mar)</option>
              <option value="Q2">Q2 (Apr–Jun)</option>
              <option value="Q3">Q3 (Jul–Sep)</option>
              <option value="Q4">Q4 (Oct–Dec)</option>
            </select>
          </div>
          <div>
            <label>Year</label>
            <input id="gen-year" type="number" class="admin-form-input" min="2020" max="2099" value={currentYear} required />
          </div>
          <div class="modal-actions full">
            <button type="button" class="admin-btn admin-btn-secondary" data-close="modal-gen-report">Cancel</button>
            <button class="admin-btn admin-btn-primary" type="submit" id="btn-gen-submit">Generate</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Modal: View / edit report -->
    <div id="modal-view-report" class="preview-modal-overlay" style="display:none;">
      <div class="modal modal--report">
        <div class="rep-modal-header">
          <h3 id="view-report-title">Report</h3>
          <div style="display:flex;gap:8px;align-items:center;">
            <span id="view-report-status" class="rep-badge"></span>
            <button id="btn-finalize-report" class="admin-btn admin-btn-secondary" type="button" style="font-size:0.75rem;">Mark as Final</button>
            <button type="button" class="admin-btn admin-btn-secondary" data-close="modal-view-report" style="font-size:0.75rem;">Close</button>
          </div>
        </div>
        <div id="view-report-content" class="rep-markdown-body"></div>
        <div class="rep-modal-edit-row">
          <details class="rep-edit-details">
            <summary>Edit Markdown</summary>
            <textarea id="edit-report-md" class="admin-form-input rep-md-editor" rows="20"></textarea>
            <div style="margin-top:8px;display:flex;gap:8px;">
              <button id="btn-save-report-md" class="admin-btn admin-btn-primary" type="button">Save changes</button>
              <button id="btn-preview-md" class="admin-btn admin-btn-secondary" type="button">Preview</button>
            </div>
          </details>
        </div>
      </div>
    </div>

    <!-- Modal: New case study -->
    <div id="modal-new-cs" class="preview-modal-overlay" style="display:none;">
      <div class="modal modal--wide">
        <h3>New Case Study</h3>
        <form id="form-new-cs" class="grid-form">
          <div class="full">
            <label>Title</label>
            <input id="cs-title" class="admin-form-input" required placeholder="e.g. How Rentify reduced arrears by 40%" />
          </div>
          <div class="full">
            <label>Summary (1–2 sentences)</label>
            <textarea id="cs-summary" class="admin-form-input" rows="2" placeholder="Short summary for previews"></textarea>
          </div>
          <div class="full">
            <label>Tags (comma-separated)</label>
            <input id="cs-tags" class="admin-form-input" placeholder="property, automation, ROI" />
          </div>
          <div class="full">
            <label>Content (Markdown)</label>
            <textarea id="cs-content" class="admin-form-input rep-md-editor" rows="14" placeholder="## The Challenge&#10;...&#10;&#10;## Our Solution&#10;..."></textarea>
          </div>
          <div class="modal-actions full">
            <button type="button" class="admin-btn admin-btn-secondary" data-close="modal-new-cs">Cancel</button>
            <button class="admin-btn admin-btn-primary" type="submit">Create Draft</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Modal: View case study -->
    <div id="modal-view-cs" class="preview-modal-overlay" style="display:none;">
      <div class="modal modal--report">
        <div class="rep-modal-header">
          <h3 id="view-cs-title">Case Study</h3>
          <div style="display:flex;gap:8px;align-items:center;">
            <span id="view-cs-status" class="rep-badge"></span>
            <button id="btn-publish-cs" class="admin-btn admin-btn-secondary" type="button" style="font-size:0.75rem;">Publish</button>
            <button type="button" class="admin-btn admin-btn-secondary" data-close="modal-view-cs" style="font-size:0.75rem;">Close</button>
          </div>
        </div>
        <div id="view-cs-content" class="rep-markdown-body"></div>
        <div class="rep-modal-edit-row">
          <details class="rep-edit-details">
            <summary>Edit Markdown</summary>
            <textarea id="edit-cs-md" class="admin-form-input rep-md-editor" rows="20"></textarea>
            <div style="margin-top:8px;display:flex;gap:8px;">
              <button id="btn-save-cs-md" class="admin-btn admin-btn-primary" type="button">Save changes</button>
            </div>
          </details>
        </div>
      </div>
    </div>

    <!-- Confirm -->
    <div id="modal-confirm-rep" class="preview-modal-overlay" style="display:none;">
      <div class="modal modal--narrow">
        <h3 id="rep-confirm-title"></h3>
        <p id="rep-confirm-message" style="color:var(--admin-text-muted);font-size:0.875rem;margin-top:-0.5rem;"></p>
        <div class="modal-actions">
          <button type="button" class="admin-btn admin-btn-secondary" data-close="modal-confirm-rep">Cancel</button>
          <button id="rep-confirm-btn" type="button" class="admin-btn admin-btn-primary">Confirm</button>
        </div>
      </div>
    </div>
  </div>

  <style>
    .rep-root { margin: 0 auto; max-width: 1120px; }
    .rep-header { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 12px; }
    .rep-back { font-size: 0.875rem; color: var(--admin-text-muted); text-decoration: none; display: inline-flex; align-items: center; gap: 4px; margin-bottom: 6px; }
    .rep-back:hover { color: var(--admin-text); }

    .rep-section { background: var(--admin-card); border: 1px solid var(--admin-border); border-radius: 10px; overflow: hidden; }
    .rep-section-header { display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; border-bottom: 1px solid var(--admin-border); }
    .rep-section-title { font-size: 0.9375rem; font-weight: 700; color: var(--admin-text); margin: 0; }
    .rep-count { font-size: 0.75rem; color: var(--admin-text-muted); font-weight: 600; }

    .rep-empty { padding: 2rem; text-align: center; color: var(--admin-text-muted); font-size: 0.875rem; }

    .rep-badge { display: inline-block; padding: 2px 10px; border-radius: 999px; font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; }
    .rep-badge--draft { background: rgba(245,158,11,.12); color: #92400e; }
    .rep-badge--final { background: rgba(22,163,74,.12); color: #166534; }
    .rep-badge--published { background: rgba(59,130,246,.12); color: #1d4ed8; }

    /* Modal overrides */
    .modal--report { width: min(860px, 98vw); max-height: 90vh; overflow-y: auto; display: flex; flex-direction: column; }
    .modal--narrow { width: min(440px, 100%); }
    .rep-modal-header { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; flex-shrink: 0; }
    .rep-modal-header h3 { margin: 0; font-size: 1rem; }
    .rep-modal-edit-row { margin-top: 16px; flex-shrink: 0; }
    .rep-edit-details { border: 1px solid var(--admin-border); border-radius: 8px; padding: 10px 14px; }
    .rep-edit-details summary { cursor: pointer; font-size: 0.8125rem; font-weight: 600; color: var(--admin-text); }
    .rep-md-editor { font-family: ui-monospace, SFMono-Regular, monospace; font-size: 0.8125rem; margin-top: 10px; }

    /* Markdown body rendering */
    .rep-markdown-body { font-size: 0.9rem; line-height: 1.65; color: var(--admin-text); flex: 1; overflow-y: auto; }
    .rep-markdown-body h1 { font-size: 1.375rem; font-weight: 800; margin: 1.2em 0 0.5em; color: var(--admin-text); }
    .rep-markdown-body h2 { font-size: 1.1rem; font-weight: 700; margin: 1.1em 0 0.4em; color: var(--admin-text); border-bottom: 1px solid var(--admin-border); padding-bottom: 4px; }
    .rep-markdown-body h3 { font-size: 0.9375rem; font-weight: 700; margin: 0.9em 0 0.3em; color: var(--admin-text); }
    .rep-markdown-body p { margin: 0.6em 0; }
    .rep-markdown-body ul, .rep-markdown-body ol { margin: 0.5em 0 0.5em 1.4em; }
    .rep-markdown-body li { margin: 0.25em 0; }
    .rep-markdown-body code { font-family: ui-monospace, SFMono-Regular, monospace; font-size: 0.8125rem; background: var(--admin-bg-elevated); border: 1px solid var(--admin-border); padding: 1px 6px; border-radius: 4px; }
    .rep-markdown-body pre { background: var(--admin-bg-elevated); border: 1px solid var(--admin-border); border-radius: 8px; padding: 12px 14px; overflow-x: auto; }
    .rep-markdown-body pre code { background: none; border: none; padding: 0; }
    .rep-markdown-body blockquote { border-left: 3px solid var(--admin-accent); padding-left: 12px; margin: 0.6em 0; color: var(--admin-text-muted); font-style: italic; }
    .rep-markdown-body hr { border: none; border-top: 1px solid var(--admin-border); margin: 1.2em 0; }
    .rep-markdown-body strong { font-weight: 700; }
    .rep-markdown-body em { font-style: italic; }
    .rep-markdown-body table { width: 100%; border-collapse: collapse; font-size: 0.85rem; margin: 0.8em 0; }
    .rep-markdown-body th { background: var(--admin-bg-elevated); font-weight: 700; text-align: left; padding: 6px 10px; border: 1px solid var(--admin-border); font-size: 0.8rem; }
    .rep-markdown-body td { padding: 6px 10px; border: 1px solid var(--admin-border); vertical-align: top; }
    .rep-markdown-body tr:nth-child(even) td { background: var(--admin-bg-elevated); }

    /* Toast */
    #toast-root-rep { position: fixed; right: 16px; bottom: 16px; display: flex; flex-direction: column; gap: 8px; z-index: 2000; pointer-events: none; }
    .toast { background: var(--admin-text); color: var(--admin-card); border-radius: 8px; padding: 10px 14px; font-size: 0.8125rem; min-width: 260px; pointer-events: auto; box-shadow: 0 4px 12px rgba(0,0,0,.2); }
    .toast.error { background: #7f1d1d; color: #fff; }
  </style>

  <script define:vars={{ clientId, currentQuarter, currentYear }}>
    // ── Helpers ──────────────────────────────────────────────────────────────
    function showToast(msg, type = 'success') {
      const t = document.createElement('div');
      t.className = `toast${type === 'error' ? ' error' : ''}`;
      t.textContent = msg;
      document.getElementById('toast-root-rep').appendChild(t);
      setTimeout(() => t.remove(), 5000);
    }
    function showModal(id) { const el = document.getElementById(id); if (el) el.style.display = 'flex'; }
    function closeModal(id) { const el = document.getElementById(id); if (el) el.style.display = 'none'; }
    document.addEventListener('click', (e) => {
      const c = e.target.closest('[data-close]');
      if (c) closeModal(c.dataset.close);
    });
    document.querySelectorAll('.preview-modal-overlay').forEach((o) =>
      o.addEventListener('click', (e) => { if (e.target === o) closeModal(o.id); })
    );

    let repConfirmCallback = null;
    function openConfirm(opts) {
      document.getElementById('rep-confirm-title').textContent = opts.title;
      document.getElementById('rep-confirm-message').textContent = opts.message;
      document.getElementById('rep-confirm-btn').textContent = opts.label || 'Confirm';
      repConfirmCallback = opts.onConfirm;
      showModal('modal-confirm-rep');
    }
    document.getElementById('rep-confirm-btn').addEventListener('click', async () => {
      if (repConfirmCallback) await repConfirmCallback();
      closeModal('modal-confirm-rep');
    });

    // ── Markdown renderer ──────────────────────────────────────────────────
    function renderMarkdown(md) {
      if (!md) return '';
      const lines = md.split('\n');
      const out = [];
      let inUl = false;
      let inTable = false;
      let tableHeader = false;

      function flushList() { if (inUl) { out.push('</ul>'); inUl = false; } }
      function flushTable() { if (inTable) { out.push('</tbody></table>'); inTable = false; tableHeader = false; } }

      for (let i = 0; i < lines.length; i++) {
        const raw = lines[i];
        const line = raw.trimEnd();

        // Horizontal rule
        if (/^---+$/.test(line.trim())) {
          flushList(); flushTable();
          out.push('<hr>');
          continue;
        }

        // Table row
        if (/^\|/.test(line)) {
          flushList();
          if (!inTable) {
            out.push('<table><thead>');
            inTable = true;
            tableHeader = true;
          }
          const cells = line.split('|').slice(1, -1).map((c) => c.trim());
          // separator row
          if (cells.every((c) => /^-+$/.test(c))) {
            out.push('</thead><tbody>');
            tableHeader = false;
            continue;
          }
          const tag = tableHeader ? 'th' : 'td';
          out.push(`<tr>${cells.map((c) => `<${tag}>${inlineFormat(c)}</${tag}>`).join('')}</tr>`);
          continue;
        }
        flushTable();

        // Headings
        const h3 = line.match(/^### (.+)/);
        if (h3) { flushList(); out.push(`<h3>${inlineFormat(h3[1])}</h3>`); continue; }
        const h2 = line.match(/^## (.+)/);
        if (h2) { flushList(); out.push(`<h2>${inlineFormat(h2[1])}</h2>`); continue; }
        const h1 = line.match(/^# (.+)/);
        if (h1) { flushList(); out.push(`<h1>${inlineFormat(h1[1])}</h1>`); continue; }

        // Blockquote
        const bq = line.match(/^> (.+)/);
        if (bq) { flushList(); out.push(`<blockquote><p>${inlineFormat(bq[1])}</p></blockquote>`); continue; }

        // Unordered list
        const li = line.match(/^- (.+)/);
        if (li) {
          if (!inUl) { out.push('<ul>'); inUl = true; }
          out.push(`<li>${inlineFormat(li[1])}</li>`);
          continue;
        }
        flushList();

        // Blank line
        if (!line.trim()) {
          continue;
        }

        // Paragraph
        out.push(`<p>${inlineFormat(line)}</p>`);
      }

      flushList();
      flushTable();
      return out.join('\n');
    }

    function inlineFormat(text) {
      return text
        // Inline code: `code`
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        // Bold: **text**
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        // Italic: *text* (not preceded/followed by another *)
        .replace(/(?<!\*)\*(?!\*)([^*]+)(?<!\*)\*(?!\*)/g, '<em>$1</em>')
        // Links: [text](url)
        .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');
    }

    // ── State ─────────────────────────────────────────────────────────────
    let currentReportId = null;
    let currentCsId = null;

    // ── Generate report ───────────────────────────────────────────────────
    const genSelect = document.getElementById('gen-quarter');
    if (genSelect) genSelect.value = currentQuarter;

    document.getElementById('btn-generate-report')?.addEventListener('click', () => {
      showModal('modal-gen-report');
    });

    document.getElementById('form-gen-report')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const quarter = document.getElementById('gen-quarter').value;
      const year = Number(document.getElementById('gen-year').value);
      const btn = document.getElementById('btn-gen-submit');
      btn.disabled = true;
      const orig = btn.textContent;
      btn.textContent = 'Generating…';
      try {
        const res = await fetch('/api/maintenance/generate-report', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ serviceClientId: clientId, quarter, year }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) { showToast(data.error || 'Failed to generate report', 'error'); return; }
        closeModal('modal-gen-report');
        showToast('Report generated — reloading…');
        setTimeout(() => window.location.reload(), 1000);
      } catch { showToast('Network error', 'error'); }
      finally { btn.disabled = false; btn.textContent = orig; }
    });

    // ── View / edit report ────────────────────────────────────────────────
    document.addEventListener('click', async (e) => {
      const viewBtn = e.target.closest('[data-view-report]');
      if (viewBtn) {
        const id = viewBtn.dataset.viewReport;
        currentReportId = id;
        const res = await fetch(`/api/maintenance/reports?id=${encodeURIComponent(id)}`);
        const report = await res.json().catch(() => null);
        if (!report) { showToast('Failed to load report', 'error'); return; }
        document.getElementById('view-report-title').textContent = report.title;
        const statusBadge = document.getElementById('view-report-status');
        statusBadge.textContent = report.status;
        statusBadge.className = `rep-badge rep-badge--${report.status}`;
        document.getElementById('view-report-content').innerHTML = renderMarkdown(report.markdownContent || '');
        document.getElementById('edit-report-md').value = report.markdownContent || '';
        const finalBtn = document.getElementById('btn-finalize-report');
        if (finalBtn) finalBtn.style.display = report.status === 'final' ? 'none' : '';
        showModal('modal-view-report');
      }

      const delBtn = e.target.closest('[data-del-report]');
      if (delBtn) {
        const id = delBtn.dataset.delReport;
        openConfirm({
          title: 'Delete report?',
          message: 'This cannot be undone.',
          label: 'Delete',
          onConfirm: async () => {
            const res = await fetch(`/api/maintenance/reports?id=${encodeURIComponent(id)}`, { method: 'DELETE' });
            if (!res.ok) { showToast('Failed to delete', 'error'); return; }
            showToast('Report deleted');
            setTimeout(() => window.location.reload(), 800);
          },
        });
      }
    });

    document.getElementById('btn-save-report-md')?.addEventListener('click', async () => {
      if (!currentReportId) return;
      const markdownContent = document.getElementById('edit-report-md').value;
      const res = await fetch('/api/maintenance/reports', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: currentReportId, markdownContent }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) { showToast(data.error || 'Save failed', 'error'); return; }
      document.getElementById('view-report-content').innerHTML = renderMarkdown(markdownContent);
      showToast('Changes saved');
    });

    document.getElementById('btn-preview-md')?.addEventListener('click', () => {
      const md = document.getElementById('edit-report-md').value;
      document.getElementById('view-report-content').innerHTML = renderMarkdown(md);
      showToast('Preview updated');
    });

    document.getElementById('btn-finalize-report')?.addEventListener('click', async () => {
      if (!currentReportId) return;
      const res = await fetch('/api/maintenance/reports', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: currentReportId, status: 'final' }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) { showToast(data.error || 'Failed', 'error'); return; }
      document.getElementById('view-report-status').textContent = 'final';
      document.getElementById('view-report-status').className = 'rep-badge rep-badge--final';
      document.getElementById('btn-finalize-report').style.display = 'none';
      showToast('Report marked as final');
      // Update the row badge in the table
      const row = document.querySelector(`[data-report-id="${currentReportId}"]`);
      if (row) {
        const badge = row.querySelector('.rep-badge');
        if (badge) { badge.textContent = 'final'; badge.className = 'rep-badge rep-badge--final'; }
      }
    });

    // ── New case study ────────────────────────────────────────────────────
    document.getElementById('btn-new-case-study')?.addEventListener('click', () => showModal('modal-new-cs'));

    document.getElementById('form-new-cs')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const title = document.getElementById('cs-title').value.trim();
      const summary = document.getElementById('cs-summary').value.trim() || null;
      const tagsRaw = document.getElementById('cs-tags').value.trim();
      const tags = tagsRaw ? tagsRaw.split(',').map((t) => t.trim()).filter(Boolean) : [];
      const markdownContent = document.getElementById('cs-content').value.trim();
      if (!title || !markdownContent) { showToast('Title and content are required', 'error'); return; }
      const res = await fetch('/api/maintenance/case-study', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ serviceClientId: clientId, title, summary, tags, markdownContent }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) { showToast(data.error || 'Failed to create', 'error'); return; }
      closeModal('modal-new-cs');
      showToast('Case study created');
      setTimeout(() => window.location.reload(), 800);
    });

    // ── View / edit case study ────────────────────────────────────────────
    document.addEventListener('click', async (e) => {
      const viewBtn = e.target.closest('[data-view-cs]');
      if (viewBtn) {
        const id = viewBtn.dataset.viewCs;
        currentCsId = id;
        const res = await fetch(`/api/maintenance/case-study?id=${encodeURIComponent(id)}`);
        const cs = await res.json().catch(() => null);
        if (!cs) { showToast('Failed to load case study', 'error'); return; }
        document.getElementById('view-cs-title').textContent = cs.title;
        const statusBadge = document.getElementById('view-cs-status');
        statusBadge.textContent = cs.status;
        statusBadge.className = `rep-badge rep-badge--${cs.status}`;
        document.getElementById('view-cs-content').innerHTML = renderMarkdown(cs.markdownContent || '');
        document.getElementById('edit-cs-md').value = cs.markdownContent || '';
        const pubBtn = document.getElementById('btn-publish-cs');
        if (pubBtn) pubBtn.style.display = cs.status === 'published' ? 'none' : '';
        showModal('modal-view-cs');
      }

      const delCsBtn = e.target.closest('[data-del-cs]');
      if (delCsBtn) {
        const id = delCsBtn.dataset.delCs;
        openConfirm({
          title: 'Delete case study?',
          message: 'This cannot be undone.',
          label: 'Delete',
          onConfirm: async () => {
            const res = await fetch(`/api/maintenance/case-study?id=${encodeURIComponent(id)}`, { method: 'DELETE' });
            if (!res.ok) { showToast('Failed to delete', 'error'); return; }
            showToast('Case study deleted');
            setTimeout(() => window.location.reload(), 800);
          },
        });
      }
    });

    document.getElementById('btn-save-cs-md')?.addEventListener('click', async () => {
      if (!currentCsId) return;
      const markdownContent = document.getElementById('edit-cs-md').value;
      const res = await fetch('/api/maintenance/case-study', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: currentCsId, markdownContent }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) { showToast(data.error || 'Save failed', 'error'); return; }
      document.getElementById('view-cs-content').innerHTML = renderMarkdown(markdownContent);
      showToast('Changes saved');
    });

    document.getElementById('btn-publish-cs')?.addEventListener('click', async () => {
      if (!currentCsId) return;
      const res = await fetch('/api/maintenance/case-study', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: currentCsId, status: 'published', publishedAt: new Date().toISOString() }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) { showToast(data.error || 'Failed', 'error'); return; }
      document.getElementById('view-cs-status').textContent = 'published';
      document.getElementById('view-cs-status').className = 'rep-badge rep-badge--published';
      document.getElementById('btn-publish-cs').style.display = 'none';
      showToast('Case study published');
      const row = document.querySelector(`[data-cs-id="${currentCsId}"]`);
      if (row) {
        const badge = row.querySelector('.rep-badge');
        if (badge) { badge.textContent = 'published'; badge.className = 'rep-badge rep-badge--published'; }
      }
    });
  </script>
</AdminLayout>
