---
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="Maintenance Clients">
  <header class="admin-header">
    <div>
      <h1 class="admin-title">Maintenance Clients</h1>
      <p class="admin-subtitle">Apps built and maintained by Zyntel — track status, retainers, and ROI impact.</p>
    </div>
    <button class="admin-btn admin-btn-primary" id="btn-new">+ Add client</button>
  </header>

  <!-- Summary cards -->
  <div id="summary-cards" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem;margin-bottom:1.5rem;"></div>

  <div class="admin-card">
    <div class="admin-table-wrap">
      <table class="admin-table" id="mc-table">
        <thead>
          <tr>
            <th>Client</th>
            <th>App</th>
            <th>Status</th>
            <th>Monthly retainer</th>
            <th>Start date</th>
            <th>Tech</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="mc-tbody">
          <tr><td colspan="7"><div class="admin-empty"><div class="admin-empty-icon">Loading…</div></div></td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- New client slide-in form -->
  <div id="new-panel" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.35);z-index:100;align-items:flex-start;justify-content:flex-end;">
    <div style="background:var(--admin-card);width:min(520px,100%);height:100%;overflow-y:auto;padding:2rem;box-shadow:-4px 0 24px rgba(0,0,0,.15);">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
        <h2 style="margin:0;font-size:1.125rem;">Add Maintenance Client</h2>
        <button id="close-panel" style="background:none;border:none;cursor:pointer;font-size:1.25rem;color:var(--admin-text-muted);">✕</button>
      </div>
      <form id="new-form" style="display:flex;flex-direction:column;gap:1rem;">
        <div class="admin-field-group">
          <label class="admin-label">Client / Business Name *</label>
          <input class="admin-input" name="name" required placeholder="e.g. Five S Investments SMC Ltd" />
        </div>
        <div class="admin-field-group">
          <label class="admin-label">App Name *</label>
          <input class="admin-input" name="app_name" required placeholder="e.g. Property Management System" />
        </div>
        <div class="admin-field-group">
          <label class="admin-label">App URL</label>
          <input class="admin-input" name="app_url" type="url" placeholder="https://fives.zyntel.net" />
        </div>
        <div class="admin-field-group">
          <label class="admin-label">Tech Stack</label>
          <input class="admin-input" name="tech_stack" placeholder="Django, PostgreSQL, Railway" />
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
          <div class="admin-field-group">
            <label class="admin-label">Monthly Retainer</label>
            <input class="admin-input" name="monthly_retainer" type="number" min="0" placeholder="0" />
          </div>
          <div class="admin-field-group">
            <label class="admin-label">Currency</label>
            <select class="admin-input" name="currency">
              <option value="UGX" selected>UGX</option>
              <option value="USD">USD</option>
              <option value="KES">KES</option>
            </select>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
          <div class="admin-field-group">
            <label class="admin-label">Original Dev Cost</label>
            <input class="admin-input" name="original_dev_cost" type="number" min="0" placeholder="1500000" />
          </div>
          <div class="admin-field-group">
            <label class="admin-label">Start Date</label>
            <input class="admin-input" name="start_date" type="date" />
          </div>
        </div>
        <div class="admin-field-group">
          <label class="admin-label">Contact Name</label>
          <input class="admin-input" name="contact_name" placeholder="Mariam K." />
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
          <div class="admin-field-group">
            <label class="admin-label">Contact Email</label>
            <input class="admin-input" name="contact_email" type="email" />
          </div>
          <div class="admin-field-group">
            <label class="admin-label">Contact Phone</label>
            <input class="admin-input" name="contact_phone" placeholder="+256..." />
          </div>
        </div>
        <div class="admin-field-group">
          <label class="admin-label">Metrics API URL <span style="color:var(--admin-text-muted);font-weight:400;">(optional)</span></label>
          <input class="admin-input" name="metrics_api_url" type="url" placeholder="https://app.example.com/api/zyntel-metrics/" />
        </div>
        <div class="admin-field-group">
          <label class="admin-label">Metrics API Key <span style="color:var(--admin-text-muted);font-weight:400;">(optional)</span></label>
          <input class="admin-input" name="metrics_api_key" type="password" placeholder="secret key" />
        </div>
        <div class="admin-field-group">
          <label class="admin-label">App Description / Notes</label>
          <textarea class="admin-input" name="notes" rows="3" placeholder="What does this app do? Any context."></textarea>
        </div>
        <div id="form-error" style="color:var(--admin-danger);font-size:0.875rem;display:none;"></div>
        <div style="display:flex;gap:0.75rem;justify-content:flex-end;padding-top:0.5rem;">
          <button type="button" class="admin-btn" id="cancel-btn">Cancel</button>
          <button type="submit" class="admin-btn admin-btn-primary">Save client</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  const API_KEY = sessionStorage.getItem('zyntel_invoice_api_key') ?? '';
  const B = (window as unknown as {__ADMIN_BASE__?:string}).__ADMIN_BASE__ ?? '';

  function fmt(n: number, cur = 'UGX') {
    return cur === 'UGX'
      ? 'UGX ' + n.toLocaleString('en-UG', {minimumFractionDigits:0, maximumFractionDigits:0})
      : cur + ' ' + n.toLocaleString();
  }
  function badge(s: string) {
    const map: Record<string, string> = { active: '#0d9488', paused: '#f59e0b', churned: '#dc2626' };
    return `<span style="background:${map[s]??'#697386'}20;color:${map[s]??'#697386'};border-radius:4px;padding:2px 8px;font-size:11px;font-weight:600;text-transform:uppercase;">${s}</span>`;
  }

  async function load() {
    const tbody = document.getElementById('mc-tbody')!;
    const cardsEl = document.getElementById('summary-cards')!;
    const r = await fetch('/api/maintenance/list', { headers: { 'x-api-key': API_KEY } });
    if (r.status === 401) { sessionStorage.removeItem('zyntel_invoice_api_key'); window.location.href = B + '/login'; return; }
    const { clients } = await r.json();
    const list = clients ?? [];

    // Summary
    const active = list.filter((c: {status:string}) => c.status === 'active').length;
    const retainerTotal = list.filter((c:{status:string}) => c.status==='active').reduce((s: number, c:{monthly_retainer:number}) => s + (c.monthly_retainer || 0), 0);
    cardsEl.innerHTML = [
      { label: 'Total apps', value: list.length, color: '#635bff' },
      { label: 'Active', value: active, color: '#0d9488' },
      { label: 'Monthly retainer', value: retainerTotal ? fmt(retainerTotal) : '—', color: '#10b981' },
    ].map(c => `<div class="admin-card" style="padding:1rem;border-top:3px solid ${c.color};">
      <div style="font-size:1.5rem;font-weight:700;">${c.value}</div>
      <div style="font-size:0.8125rem;color:var(--admin-text-muted);margin-top:2px;">${c.label}</div>
    </div>`).join('');

    if (!list.length) {
      tbody.innerHTML = `<tr><td colspan="7"><div class="admin-empty">
        <div class="admin-empty-icon">🛠️</div>
        <div class="admin-empty-title">No maintenance clients yet</div>
        <div class="admin-empty-desc">Add your first app to start tracking ROI and health.</div>
      </div></td></tr>`;
      return;
    }
    tbody.innerHTML = list.map((c: {id:number;name:string;app_name:string;status:string;monthly_retainer:number;currency:string;start_date:string|null;tech_stack:string|null}) => `
      <tr>
        <td><strong>${c.name}</strong></td>
        <td>${c.app_name}</td>
        <td>${badge(c.status)}</td>
        <td>${c.monthly_retainer ? fmt(c.monthly_retainer, c.currency) : '<span style="color:var(--admin-text-muted)">—</span>'}</td>
        <td>${c.start_date ? new Date(c.start_date).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'}) : '—'}</td>
        <td style="font-size:0.8125rem;color:var(--admin-text-muted);">${c.tech_stack ?? '—'}</td>
        <td><a href="${B}/maintenance/${c.id}" class="admin-btn admin-btn-ghost" style="padding:0.25rem 0.5rem;font-size:0.875rem;">View →</a></td>
      </tr>
    `).join('');
  }
  load();

  // Panel logic
  const panel = document.getElementById('new-panel')!;
  const openPanel = () => { panel.style.display = 'flex'; };
  const closePanel = () => { panel.style.display = 'none'; };
  document.getElementById('btn-new')!.addEventListener('click', openPanel);
  document.getElementById('close-panel')!.addEventListener('click', closePanel);
  document.getElementById('cancel-btn')!.addEventListener('click', closePanel);
  panel.addEventListener('click', (e) => { if (e.target === panel) closePanel(); });

  document.getElementById('new-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target as HTMLFormElement);
    const body: Record<string, unknown> = {};
    fd.forEach((v, k) => { if (v !== '') body[k] = v; });
    if (body.monthly_retainer) body.monthly_retainer = parseFloat(body.monthly_retainer as string);
    if (body.original_dev_cost) body.original_dev_cost = parseFloat(body.original_dev_cost as string);
    const errEl = document.getElementById('form-error')!;
    errEl.style.display = 'none';
    const r = await fetch('/api/maintenance/create', {
      method: 'POST',
      headers: { 'x-api-key': API_KEY, 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const d = await r.json();
    if (!d.ok) { errEl.textContent = d.error ?? 'Failed'; errEl.style.display = 'block'; return; }
    closePanel();
    window.location.href = `${B}/maintenance/${d.client.id}`;
  });
</script>
