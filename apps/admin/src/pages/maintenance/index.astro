---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAllServiceClients } from '../../lib/maintenance.ts';

const serviceClients = await getAllServiceClients();
---
<AdminLayout title="Maintenance">
  <div data-admin-skip-unsaved class="maint-root">
  <header class="admin-header maint-header">
    <div>
      <h1 class="admin-title">Maintenance</h1>
      <p class="admin-subtitle">Select a service client to view logs, connection info, and ROI metrics. Manage work orders from the <a href="/work-orders">Work Orders</a> page.</p>
    </div>
    <div style="display:flex;gap:8px;align-items:center;flex-shrink:0;">
      <a href="/work-orders" class="admin-btn admin-btn-secondary">Work Orders →</a>
      <button id="btn-new-client" class="admin-btn admin-btn-primary" type="button">New Service Client</button>
    </div>
  </header>

  <!-- Single page card -->
  <div class="admin-card maint-page-card">

    <!-- ── Client selector ── -->
    <section class="maint-section">
      <label class="maint-selector-label">Service Client</label>
      <select id="client-select" class="admin-form-input maint-client-select">
        <option value="">— Select a client to view maintenance logs —</option>
        {serviceClients.map((c) => (
          <option
            value={c.id}
            data-product={c.productName}
            data-contact={c.contactName}
            data-health={c.healthCheckUrl ?? ''}
            data-api={c.apiUrl ?? ''}
            data-repo={c.repoUrl ?? ''}
            data-sentry={c.sentryUrl ?? ''}
            data-cronitor={c.cronitorUrl ?? ''}
            data-roi-last={c.roiLastSyncedAt ? c.roiLastSyncedAt.toISOString() : ''}
            data-roi-err={c.roiLastSyncError ?? ''}
          >{c.name} — {c.productName}</option>
        ))}
      </select>
    </section>

    <!-- ── Stats bar (hidden until client selected) ── -->
    <div id="stats-bar" class="maint-stats-row" style="display:none">
      <div class="maint-stat"><div class="maint-stat-label">Logs (QTR)</div><div class="maint-stat-value" id="stat-total">0</div></div>
      <div class="maint-stat"><div class="maint-stat-label">Incidents</div><div class="maint-stat-value" id="stat-incidents">0</div></div>
      <div class="maint-stat"><div class="maint-stat-label">Preventive</div><div class="maint-stat-value" id="stat-preventive">0</div></div>
      <div class="maint-stat"><div class="maint-stat-label">Support</div><div class="maint-stat-value" id="stat-support">0</div></div>
      <div class="maint-stat">
        <div class="maint-stat-label">Open WOs</div>
        <div class="maint-stat-value" id="stat-open-wo">0</div>
        <a href="/work-orders" class="maint-stat-link">View →</a>
      </div>
      <a id="btn-reports-link" href="#" class="admin-btn admin-btn-secondary maint-report-btn" style="display:none;">
        Reports →
      </a>
      <button id="btn-download-report" class="admin-btn admin-btn-secondary maint-report-btn" type="button">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Quarterly Report PDF
      </button>
    </div>

    <!-- ── Connection & API ── -->
    <section id="connection-panel" class="maint-section" style="display:none">
      <div class="maint-section-header">
        <h2 class="maint-section-title">Connection &amp; API access</h2>
      </div>
      <p class="maint-help">Use the property app's public base URL, then append <code>/health</code> or <code>/api/healthcheck</code> (plain <code>OK</code>). For JSON with DB status, use <code>/health/detailed</code>.</p>
      <div class="maint-connection-grid">
        <div>
          <span class="maint-kicker">Health check URL</span>
          <div id="conn-health-display" class="maint-connection-value">—</div>
        </div>
        <div>
          <span class="maint-kicker">API base URL</span>
          <div id="conn-api-display" class="maint-connection-value">—</div>
        </div>
        <div>
          <span class="maint-kicker">Repository link(s)</span>
          <div id="conn-repo-display" class="maint-connection-value">—</div>
        </div>
        <div>
          <span class="maint-kicker">Observability</span>
          <div id="conn-obs-display" class="maint-connection-value">—</div>
        </div>
      </div>
      <div class="maint-connection-grid" style="margin-top:0;">
        <div>
          <span class="maint-kicker">Service Client ID <span style="font-size:0.6875rem;font-weight:400;text-transform:none;letter-spacing:0;">(ZYNTEL_SERVICE_CLIENT_ID)</span></span>
          <div style="display:flex;gap:8px;align-items:center;">
            <code id="conn-client-id" class="maint-connection-value" style="font-family:ui-monospace,monospace;font-size:0.75rem;">—</code>
            <button type="button" id="btn-copy-scid" class="admin-btn admin-btn-secondary" style="padding:3px 10px;font-size:0.6875rem;display:none;">Copy</button>
          </div>
        </div>
      </div>
      <div class="maint-connection-actions">
        <button type="button" id="btn-gen-api-key" class="admin-btn admin-btn-primary">Generate / rotate API key</button>
        <span class="maint-hint">Shown once — update <code>ZYNTEL_API_KEY</code> on the client server.</span>
      </div>
      <div class="maint-roi-inset">
        <h3>ROI auto-sync (recommended)</h3>
        <p>
          After you implement the product's <code>/zyntel/v1/snapshot</code> + <code>/zyntel/v1/push-snapshot</code> endpoints, schedule snapshots (Cronitor or system cron).
          The product will push metrics to <code>admin.zyntel.net</code> automatically — no manual ROI logging.
        </p>
        <div class="maint-connection-grid">
          <div class="full">
            <span class="maint-kicker">Suggested Cronitor URL</span>
            <div id="roi-cronitor-url" class="maint-connection-value">—</div>
          </div>
          <div class="full">
            <span class="maint-kicker">Admin ingest endpoint</span>
            <div class="maint-connection-value"><code>POST /api/roi/ingest</code> (header: <code>X-Zyntel-Key</code>)</div>
          </div>
          <div class="full">
            <span class="maint-kicker">Last ROI sync</span>
            <div id="roi-last-sync" class="maint-connection-value">—</div>
          </div>
        </div>
        <div class="maint-connection-actions">
          <button type="button" id="btn-pull-roi" class="admin-btn admin-btn-secondary">Test pull now</button>
          <span id="roi-pull-hint" class="maint-hint">Pull uses encrypted key (if stored) and <code>apiUrl</code>.</span>
        </div>
        <p id="roi-pull-error" style="display:none;margin:8px 0 0;color:var(--admin-danger);font-size:12px;"></p>
      </div>
    </section>

    <!-- ── Log Entry ── -->
    <section id="log-panel" class="maint-section" style="display:none">
      <div class="maint-section-header">
        <h2 class="maint-section-title">New Log Entry</h2>
      </div>
      <form id="form-log" class="log-form">
        <div class="log-form-row">
          <div>
            <label>Date</label>
            <input id="log-date" type="date" class="admin-form-input" />
          </div>
          <div>
            <label>Area</label>
            <input id="log-area" class="admin-form-input" placeholder="e.g. Backend, Database, Frontend" required />
          </div>
          <div>
            <label>Logged by</label>
            <input id="log-by" class="admin-form-input" placeholder="Your name" required autocomplete="name" />
          </div>
        </div>
        <div class="type-chips">
          <button type="button" class="type-chip type-chip--incident" data-type="incident">Incident</button>
          <button type="button" class="type-chip type-chip--preventive" data-type="preventive">Preventive</button>
          <button type="button" class="type-chip type-chip--support" data-type="support">Support</button>
        </div>
        <input type="hidden" id="log-type" required />
        <div class="log-form-row log-form-row--full">
          <label>Summary <span class="char-counter" id="summary-counter">0 / 200</span></label>
          <input id="log-summary" class="admin-form-input" maxlength="200" placeholder="Brief description (max 200 chars)" required />
        </div>
        <div class="log-form-row">
          <div>
            <label>Action Taken</label>
            <textarea id="log-action" class="admin-form-input" rows="2" placeholder="What was done?"></textarea>
          </div>
          <div>
            <label>Outcome</label>
            <textarea id="log-outcome" class="admin-form-input" rows="2" placeholder="Result / resolution"></textarea>
          </div>
        </div>
        <button class="admin-btn admin-btn-primary" type="submit">Save Log Entry</button>
      </form>
    </section>

    <!-- ── Maintenance Logs ── -->
    <section id="logs-panel" class="maint-section" style="display:none">
      <div class="maint-section-header">
        <h2 class="maint-section-title">Maintenance Logs</h2>
        <div class="filter-tabs" id="log-filter-tabs">
          <button class="tab active" data-filter="all">All</button>
          <button class="tab" data-filter="incident">Incidents</button>
          <button class="tab" data-filter="preventive">Preventive</button>
          <button class="tab" data-filter="support">Support</button>
        </div>
      </div>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Type</th>
              <th>Area</th>
              <th>Summary</th>
              <th>Action Taken</th>
              <th>Logged By</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="logs-tbody"></tbody>
        </table>
      </div>
    </section>

    <!-- ── ROI Metrics ── -->
    <section id="roi-panel" class="maint-section" style="display:none">
      <div class="maint-section-header">
        <div>
          <h2 class="maint-section-title">ROI — first snapshot vs latest</h2>
          <p class="maint-roi-sub">Log numbers from the <strong>property / ops</strong> app. "Better" is green when the metric improves.</p>
        </div>
        <button id="btn-log-metrics" class="admin-btn admin-btn-secondary" type="button">Log metrics</button>
      </div>
      <div id="roi-comparison" class="roi-comparison"></div>
    </section>

    <!-- ── Database Migrations (developer tool — collapsed by default) ── -->
    <section class="maint-section" style="padding:0;">
      <details class="maint-dev-tools">
        <summary class="maint-dev-tools-summary">Developer tools</summary>
        <div class="maint-migration-grid" style="padding:16px 24px 20px;">
          <div class="maint-migration-item">
            <div class="maint-kicker">Reports schema</div>
            <p class="maint-help" style="margin:4px 0 8px;">Adds <code>data_cursor_date</code>, <code>last_refreshed_at</code>, <code>source_data</code> + unique index to quarterly_reports. Run once after deploy.</p>
            <button type="button" id="btn-migrate-reports" class="admin-btn admin-btn-secondary">Run Report Migrations</button>
            <span id="mig-reports-status" class="maint-mig-status"></span>
          </div>
          <div class="maint-migration-item">
            <div class="maint-kicker">App events log schema</div>
            <p class="maint-help" style="margin:4px 0 8px;">Creates <code>app_events</code> table + 5 indexes. Run once after deploy.</p>
            <button type="button" id="btn-migrate-logs" class="admin-btn admin-btn-secondary">Run Log Migrations</button>
            <span id="mig-logs-status" class="maint-mig-status"></span>
          </div>
        </div>
      </details>
    </section>

  </div><!-- end maint-page-card -->

  <!-- ── Modals ── -->

  <!-- New Service Client -->
  <div id="modal-new-client" class="preview-modal-overlay" style="display:none">
    <div class="modal">
      <h3>New Service Client</h3>
      <form id="form-new-client" class="grid-form">
        <div class="full">
          <label>Client (from Clients directory)</label>
          <select id="nc-client-id" class="admin-form-input" required>
            <option value="">— Loading… —</option>
          </select>
          <p style="font-size:0.6875rem;color:var(--admin-text-muted);margin:4px 0 0;">
            Clients are created/managed in <a href="/clients">Clients</a>. Maintenance always links to a single universal client record.
          </p>
        </div>
        <div class="full"><label>Client / Company Name</label><input id="nc-name" class="admin-form-input" required readonly /></div>
        <div><label>Product Name</label><input id="nc-product-name" class="admin-form-input" required /></div>
        <div>
          <label>Product Type</label>
          <select id="nc-product-type" class="admin-form-input">
            <option value="dashboard">Dashboard</option>
            <option value="web-app">Web App</option>
            <option value="saas">SaaS</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div><label>Contact Name</label><input id="nc-contact-name" class="admin-form-input" required /></div>
        <div><label>Contact Email</label><input id="nc-contact-email" type="email" class="admin-form-input" required /></div>
        <div class="full"><label>Health Check URL (optional)</label><input id="nc-health-url" class="admin-form-input" placeholder="https://tenant.example.com/health" /></div>
        <div class="full"><label>API URL (optional)</label><input id="nc-api-url" class="admin-form-input" placeholder="https://tenant.example.com/api" /></div>
        <div class="full"><label>Repository URL(s) (optional)</label><textarea id="nc-repo-url" class="admin-form-input" rows="2" placeholder="https://github.com/org/repo&#10;https://github.com/org/another-repo"></textarea></div>
        <div class="full"><label>Sentry URL (optional)</label><input id="nc-sentry-url" class="admin-form-input" placeholder="https://sentry.io/organizations/.../projects/..." /></div>
        <div class="full"><label>Cronitor URL (optional)</label><input id="nc-cronitor-url" class="admin-form-input" placeholder="https://cronitor.io/..." /></div>
        <div class="full maint-checkbox-row">
          <label class="maint-inline-check"><input type="checkbox" id="nc-generate-key" /> Generate API key now (shown once after create)</label>
        </div>
        <div class="full"><label>Notes</label><textarea id="nc-notes" class="admin-form-input" rows="2"></textarea></div>
        <div class="modal-actions full">
          <button type="button" class="admin-btn admin-btn-secondary" data-close="modal-new-client">Cancel</button>
          <button class="admin-btn admin-btn-primary">Create</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Log Metrics -->
  <div id="modal-log-metrics" class="preview-modal-overlay" style="display:none">
    <div class="modal modal--wide">
      <h3>Log metrics snapshot</h3>
      <form id="form-log-metrics" class="grid-form">
        <div class="full"><label>Snapshot date</label><input id="metrics-date" type="date" class="admin-form-input" /></div>
        <div class="full maint-metric-section-title">Property &amp; operations (recommended)</div>
        <div><label>Active tenants</label><input id="m-active-tenants" class="admin-form-input" type="number" min="0" step="1" placeholder="Count" /></div>
        <div><label>Properties managed</label><input id="m-total-properties" class="admin-form-input" type="number" min="0" step="1" /></div>
        <div><label>Landlords / owners</label><input id="m-total-landlords" class="admin-form-input" type="number" min="0" step="1" /></div>
        <div><label>Payments recorded (this month)</label><input id="m-payments-month" class="admin-form-input" type="number" min="0" step="1" placeholder="Count of payments" /></div>
        <div><label>Revenue tracked (UGX)</label><input id="m-revenue-tracked" class="admin-form-input" type="number" min="0" step="1" placeholder="Period total in app" /></div>
        <details class="full maint-details">
          <summary>Other metrics (lab / dashboard)</summary>
          <div class="grid-form grid-form--nested">
            <div><label>Avg TAT (minutes)</label><input id="m-avg-tat" class="admin-form-input" type="number" step="0.01" /></div>
            <div><label>Total tests</label><input id="m-total-tests" class="admin-form-input" type="number" /></div>
            <div><label>Delay rate (%)</label><input id="m-delay-rate" class="admin-form-input" type="number" step="0.01" /></div>
            <div><label>Revenue — legacy key (UGX)</label><input id="m-revenue-legacy" class="admin-form-input" type="number" placeholder="Only if you used revenue_ugx before" /></div>
          </div>
        </details>
        <div class="modal-actions full">
          <button type="button" class="admin-btn admin-btn-secondary" data-close="modal-log-metrics">Cancel</button>
          <button class="admin-btn admin-btn-primary" type="submit">Save snapshot</button>
        </div>
      </form>
    </div>
  </div>

  <!-- One-time API key -->
  <div id="modal-api-key-result" class="preview-modal-overlay" style="display:none">
    <div class="modal">
      <h3>API key generated</h3>
      <p class="maint-help">Copy both values now. The key will not be shown again.</p>
      <div id="api-key-client-id-row" style="display:none;margin-bottom:10px;">
        <label class="maint-kicker" style="margin-bottom:4px;display:block;">Service Client ID <span style="font-size:0.6875rem;font-weight:400;text-transform:none;letter-spacing:0;">(paste as ZYNTEL_SERVICE_CLIENT_ID)</span></label>
        <div style="display:flex;gap:8px;align-items:center;">
          <input id="api-key-client-id-text" class="admin-form-input maint-api-key-text" readonly style="font-family:ui-monospace,monospace;font-size:0.6875rem;" />
          <button type="button" class="admin-btn admin-btn-secondary" id="btn-copy-client-id" style="flex-shrink:0;">Copy</button>
        </div>
      </div>
      <label class="maint-kicker" style="margin-bottom:4px;display:block;">API Key <span style="font-size:0.6875rem;font-weight:400;text-transform:none;letter-spacing:0;">(paste as ZYNTEL_API_KEY)</span></label>
      <div style="display:flex;gap:8px;align-items:center;">
        <textarea id="api-key-result-text" class="admin-form-input maint-api-key-text" readonly rows="2" style="flex:1;"></textarea>
        <button type="button" class="admin-btn admin-btn-secondary" id="btn-copy-api-key" style="flex-shrink:0;">Copy</button>
      </div>
      <div class="modal-actions" style="margin-top:12px;">
        <button type="button" class="admin-btn admin-btn-primary" id="btn-api-key-done">Done</button>
      </div>
    </div>
  </div>

  <!-- Confirm -->
  <div id="modal-confirm" class="preview-modal-overlay" style="display:none">
    <div class="modal modal--narrow">
      <h3 id="confirm-title"></h3>
      <p id="confirm-message" style="color:var(--admin-text-muted);font-size:0.875rem;margin-top:-0.5rem;"></p>
      <div class="modal-actions">
        <button type="button" class="admin-btn admin-btn-secondary" data-close="modal-confirm">Cancel</button>
        <button id="confirm-btn" type="button" class="admin-btn admin-btn-primary">Confirm</button>
      </div>
    </div>
  </div>

  <div id="toast-root"></div>
  </div>

  <style>
    .maint-root { margin: 0 auto; max-width: 1120px; }
    .maint-header { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 12px; }

    /* ── Single page card ── */
    .maint-page-card { padding: 0; }
    .maint-section { padding: 20px 24px; }
    .maint-section + .maint-section { border-top: 1px solid var(--admin-border); }
    .maint-section-header { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; margin-bottom: 16px; }

    /* ── Stats row (inside card) ── */
    .maint-stats-row { display: flex; flex-wrap: wrap; align-items: center; gap: 0; border-top: 1px solid var(--admin-border); }
    .maint-stat { flex: 1; min-width: 100px; padding: 14px 20px; border-right: 1px solid var(--admin-border); }
    .maint-stat:last-of-type { border-right: none; }
    .maint-stat-label { font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: var(--admin-text-muted); }
    .maint-stat-value { font-size: 1.5rem; font-weight: 800; color: var(--admin-text); line-height: 1.2; margin-top: 2px; }
    .maint-stat-link { font-size: 0.6875rem; color: var(--admin-accent); text-decoration: none; }
    .maint-report-btn { margin-left: auto; margin-right: 16px; align-self: center; white-space: nowrap; flex-shrink: 0; }
    @media (max-width: 640px) { .maint-stat { flex: 0 0 50%; } .maint-report-btn { margin: 8px 16px; } }

    /* ── Help text ── */
    .maint-help { font-size: 0.75rem; color: var(--admin-text-muted); margin: 8px 0 12px; line-height: 1.55; }
    .maint-help code { font-size: 0.6875rem; background: var(--admin-bg-elevated); border: 1px solid var(--admin-border); padding: 1px 6px; border-radius: 4px; font-family: ui-monospace, monospace; }

    /* ── Connection grid ── */
    .maint-connection-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
    @media (max-width: 720px) { .maint-connection-grid { grid-template-columns: 1fr; } }
    .maint-kicker { font-size: 0.6875rem; font-weight: 700; color: var(--admin-text-muted); text-transform: uppercase; letter-spacing: .04em; display: block; margin-bottom: 4px; }
    .maint-connection-value { font-size: 0.8125rem; color: var(--admin-text); word-break: break-all; }
    .maint-connection-value a { color: var(--admin-accent); }
    .maint-connection-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 12px; margin-top: 4px; }
    .maint-hint { font-size: 0.6875rem; color: var(--admin-text-muted); max-width: 440px; line-height: 1.4; }
    .maint-roi-inset { margin-top: 14px; border-top: 1px solid var(--admin-border); padding-top: 14px; }
    .maint-roi-inset h3 { margin: 0 0 6px; font-size: 0.8125rem; color: var(--admin-text); }
    .maint-roi-inset p { margin: 0 0 10px; color: var(--admin-text-muted); font-size: 0.75rem; line-height: 1.5; }

    /* ── Log form ── */
    .maint-selector-label { font-size: 0.75rem; font-weight: 700; color: var(--admin-text); display: block; margin-bottom: 6px; }
    .maint-client-select { max-width: 480px; }
    .maint-section-title { font-size: 0.875rem; font-weight: 700; color: var(--admin-text); margin: 0; }
    .log-form { display: flex; flex-direction: column; gap: 12px; }
    .log-form-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
    @media (max-width: 600px) { .log-form-row { grid-template-columns: 1fr; } }
    .log-form-row--full { grid-template-columns: 1fr !important; }
    .log-form-row label { font-size: 0.75rem; font-weight: 600; color: var(--admin-text); display: block; margin-bottom: 4px; }

    /* ── Type chips ── */
    .type-chips { display: flex; gap: 10px; flex-wrap: wrap; }
    .type-chip { padding: 9px 18px; border-radius: 8px; font-size: 0.8125rem; font-weight: 700; border: 2px solid transparent; cursor: pointer; transition: all .12s; }
    .type-chip--incident   { background: rgba(239,68,68,.08);  color: #b91c1c; border-color: #fca5a5; }
    .type-chip--preventive { background: rgba(22,163,74,.08);  color: #166534; border-color: #86efac; }
    .type-chip--support    { background: rgba(59,130,246,.08); color: #1d4ed8; border-color: #93c5fd; }
    .type-chip.active { box-shadow: 0 0 0 3px rgba(0,0,0,.12); }
    .type-chip--incident.active   { background: #b91c1c; color: #fff; border-color: #b91c1c; }
    .type-chip--preventive.active { background: #166534; color: #fff; border-color: #166534; }
    .type-chip--support.active    { background: #1d4ed8; color: #fff; border-color: #1d4ed8; }
    .char-counter { font-size: 0.6875rem; color: var(--admin-text-muted); font-weight: 400; float: right; }

    /* ── Log type badges ── */
    .badge-incident   { background: rgba(239,68,68,.12);  color: #b91c1c; padding: 2px 8px; border-radius: 999px; font-size: 0.6875rem; font-weight: 700; }
    .badge-preventive { background: rgba(22,163,74,.12);  color: #166534; padding: 2px 8px; border-radius: 999px; font-size: 0.6875rem; font-weight: 700; }
    .badge-support    { background: rgba(59,130,246,.12); color: #1d4ed8; padding: 2px 8px; border-radius: 999px; font-size: 0.6875rem; font-weight: 700; }

    /* ── ROI comparison ── */
    .maint-roi-sub { font-size: 0.75rem; color: var(--admin-text-muted); margin: 4px 0 0; line-height: 1.45; }
    .roi-comparison { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 10px; margin-top: 12px; }
    .roi-metric-card { border: 1px solid var(--admin-border); border-radius: 8px; padding: 12px; background: var(--admin-bg-elevated); }
    .roi-metric-label { font-size: 0.6875rem; color: var(--admin-text-muted); font-weight: 700; text-transform: uppercase; letter-spacing: .05em; }
    .roi-metric-vals { display: flex; gap: 8px; align-items: baseline; margin-top: 4px; }
    .roi-val-old { font-size: 0.6875rem; color: var(--admin-text-muted); text-decoration: line-through; }
    .roi-val-new { font-size: 1rem; font-weight: 800; color: var(--admin-text); }
    .roi-change { font-size: 0.6875rem; font-weight: 700; padding: 2px 6px; border-radius: 4px; }
    .roi-change--good { background: rgba(22,163,74,.12);  color: #166534; }
    .roi-change--bad  { background: rgba(239,68,68,.12);  color: #b91c1c; }

    /* ── Misc modal helpers ── */
    .modal--wide   { width: min(720px, 100%); }
    .modal--narrow { width: min(440px, 100%); }
    .maint-api-key-text { font-family: ui-monospace, SFMono-Regular, monospace; font-size: 0.6875rem; }
    .maint-metric-section-title { font-size: 0.6875rem; font-weight: 700; color: var(--admin-accent); text-transform: uppercase; letter-spacing: .06em; margin-top: 4px; }
    .maint-details { border: 1px solid var(--admin-border); border-radius: 8px; padding: 10px 12px; background: var(--admin-bg-elevated); }
    .maint-details summary { cursor: pointer; font-size: 0.75rem; font-weight: 600; color: var(--admin-text); }
    .grid-form--nested { margin-top: 10px; }
    .maint-checkbox-row { margin-top: 6px; }
    .maint-inline-check { font-size: 0.75rem; font-weight: 500; color: var(--admin-text); display: flex; align-items: center; gap: 8px; cursor: pointer; }

    /* ── Migrations / Dev tools ── */
    .maint-dev-tools { border: none; }
    .maint-dev-tools-summary { padding: 12px 24px; font-size: 0.75rem; font-weight: 600; color: var(--admin-text-muted); cursor: pointer; list-style: none; border-top: 1px solid var(--admin-border); user-select: none; }
    .maint-dev-tools-summary::before { content: '▶ '; font-size: 0.625rem; }
    .maint-dev-tools[open] .maint-dev-tools-summary::before { content: '▼ '; }
    .maint-dev-tools-summary:hover { color: var(--admin-text); }
    .maint-migration-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    @media (max-width: 640px) { .maint-migration-grid { grid-template-columns: 1fr; } }
    .maint-migration-item { border: 1px solid var(--admin-border); border-radius: 8px; padding: 14px 16px; background: var(--admin-bg-elevated); }
    .maint-mig-status { font-size: 0.75rem; margin-left: 10px; font-weight: 600; }
    .maint-mig-status.ok   { color: #166534; }
    .maint-mig-status.err  { color: #b91c1c; }
    .maint-mig-status.running { color: var(--admin-text-muted); }

    /* ── Toast ── */
    #toast-root { position: fixed; right: 16px; bottom: 16px; display: flex; flex-direction: column; gap: 8px; z-index: 2000; pointer-events: none; }
    .toast { background: var(--admin-text); color: var(--admin-card); border-radius: 8px; padding: 10px 14px; font-size: 0.8125rem; min-width: 260px; pointer-events: auto; box-shadow: 0 4px 12px rgba(0,0,0,.2); }
    .toast.error { background: #7f1d1d; color: #fff; }
  </style>

  <script>
    let selectedClientId = '';
    let logFilter = 'all';
    let allLogs = [];
    let confirmCallback = null;

    function showToast(msg, type = 'success') {
      const t = document.createElement('div'); t.className = `toast ${type === 'error' ? 'error' : ''}`;
      t.textContent = msg;
      document.getElementById('toast-root').appendChild(t);
      setTimeout(() => t.remove(), 5000);
    }
    function showModal(id) { const el = document.getElementById(id); if (el) el.style.display = 'flex'; }
    function closeModal(id) { const el = document.getElementById(id); if (el) el.style.display = 'none'; }
    document.addEventListener('click', (e) => { const c = e.target.closest('[data-close]'); if (c) closeModal(c.dataset.close); });
    document.querySelectorAll('.preview-modal-overlay').forEach((o) => o.addEventListener('click', (e) => { if (e.target === o) closeModal(o.id); }));
    document.getElementById('confirm-btn').addEventListener('click', async () => { if (confirmCallback) await confirmCallback(); closeModal('modal-confirm'); });

    function showApiKeyOnce(key, reloadOnDone, clientId) {
      const ta = document.getElementById('api-key-result-text');
      if (ta) ta.value = key;
      const idRow = document.getElementById('api-key-client-id-row');
      const idInput = document.getElementById('api-key-client-id-text');
      const resolvedId = clientId || selectedClientId || '';
      if (idRow && idInput && resolvedId) {
        idInput.value = resolvedId;
        idRow.style.display = '';
      } else if (idRow) {
        idRow.style.display = 'none';
      }
      window.__apiKeyReloadOnDone = !!reloadOnDone;
      showModal('modal-api-key-result');
    }
    document.getElementById('btn-copy-client-id')?.addEventListener('click', async () => {
      const inp = document.getElementById('api-key-client-id-text');
      if (inp?.value) {
        try { await navigator.clipboard.writeText(inp.value); showToast('Service client ID copied'); }
        catch (_) { showToast('Copy failed — select and copy manually', 'error'); }
      }
    });
    document.getElementById('btn-copy-api-key')?.addEventListener('click', async () => {
      const ta = document.getElementById('api-key-result-text');
      if (ta?.value) {
        try { await navigator.clipboard.writeText(ta.value); showToast('API key copied'); }
        catch (_) { showToast('Copy failed — select and copy manually', 'error'); }
      }
    });
    document.getElementById('btn-api-key-done')?.addEventListener('click', () => {
      closeModal('modal-api-key-result');
      if (window.__apiKeyReloadOnDone) window.location.reload();
    });

    function renderConnectionFromSelect() {
      const sel = document.getElementById('client-select');
      const opt = sel?.selectedOptions?.[0];
      const health = (opt?.dataset?.health ?? '').trim();
      const api = (opt?.dataset?.api ?? '').trim();
      const repo = (opt?.dataset?.repo ?? '').trim();
      const sentry = (opt?.dataset?.sentry ?? '').trim();
      const cronitor = (opt?.dataset?.cronitor ?? '').trim();
      const hEl = document.getElementById('conn-health-display');
      const aEl = document.getElementById('conn-api-display');
      const rEl = document.getElementById('conn-repo-display');
      const oEl = document.getElementById('conn-obs-display');
      const cronUrlEl = document.getElementById('roi-cronitor-url');
      const lastEl = document.getElementById('roi-last-sync');
      if (!hEl || !aEl || !rEl || !oEl || !cronUrlEl || !lastEl) return;
      if (health) { const a = document.createElement('a'); a.href = health; a.target = '_blank'; a.rel = 'noopener noreferrer'; a.textContent = health; hEl.replaceChildren(a); }
      else { hEl.textContent = 'Not set — add in service client settings.'; }
      if (api) { const a = document.createElement('a'); a.href = api; a.target = '_blank'; a.rel = 'noopener noreferrer'; a.textContent = api; aEl.replaceChildren(a); }
      else { aEl.textContent = 'Not set'; }
      if (repo) {
        const urls = repo.split(/[\n,]+/g).map(s => s.trim()).filter(Boolean);
        rEl.replaceChildren();
        urls.forEach((u, idx) => { const a = document.createElement('a'); a.href = u; a.target = '_blank'; a.rel = 'noopener noreferrer'; a.textContent = u; rEl.appendChild(a); if (idx !== urls.length - 1) rEl.appendChild(document.createElement('br')); });
      } else { rEl.textContent = 'Not set'; }
      const obsLinks = [];
      if (sentry) obsLinks.push({ label: 'Sentry', url: sentry });
      if (cronitor) obsLinks.push({ label: 'Cronitor', url: cronitor });
      if (obsLinks.length) {
        oEl.replaceChildren();
        obsLinks.forEach((l, idx) => { const a = document.createElement('a'); a.href = l.url; a.target = '_blank'; a.rel = 'noopener noreferrer'; a.textContent = l.label; oEl.appendChild(a); if (idx !== obsLinks.length - 1) { const sep = document.createElement('span'); sep.textContent = ' · '; oEl.appendChild(sep); } });
      } else { oEl.textContent = 'Not set'; }
      if (api) { const url = api.replace(/\/$/, '') + '/zyntel/v1/push-snapshot'; const a = document.createElement('a'); a.href = url; a.target = '_blank'; a.rel = 'noopener noreferrer'; a.textContent = url; cronUrlEl.replaceChildren(a); }
      else { cronUrlEl.textContent = 'Set API URL first'; }
      const last = (opt?.dataset)?.roiLast || '';
      const err = (opt?.dataset)?.roiErr || '';
      lastEl.textContent = last ? (err ? `${last} (error: ${err})` : last) : '—';
      const scidEl = document.getElementById('conn-client-id');
      const scidCopyBtn = document.getElementById('btn-copy-scid');
      if (scidEl) scidEl.textContent = selectedClientId || '—';
      if (scidCopyBtn) scidCopyBtn.style.display = selectedClientId ? '' : 'none';
    }

    document.getElementById('btn-copy-scid')?.addEventListener('click', async () => {
      try { await navigator.clipboard.writeText(selectedClientId); showToast('Service client ID copied'); }
      catch (_) { showToast('Copy failed', 'error'); }
    });

    function openConfirm(opts) {
      document.getElementById('confirm-title').textContent = opts.title;
      document.getElementById('confirm-message').textContent = opts.message;
      document.getElementById('confirm-btn').textContent = opts.label || 'Confirm';
      confirmCallback = opts.onConfirm;
      showModal('modal-confirm');
    }

    const today = new Date().toISOString().slice(0, 10);
    document.getElementById('log-date').value = today;
    document.getElementById('metrics-date').value = today;

    document.getElementById('log-summary').addEventListener('input', (e) => {
      document.getElementById('summary-counter').textContent = `${e.target.value.length} / 200`;
    });

    let selectedType = '';
    document.querySelectorAll('.type-chip').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.type-chip').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        selectedType = btn.dataset.type;
        document.getElementById('log-type').value = selectedType;
      });
    });

    document.getElementById('log-filter-tabs').addEventListener('click', (e) => {
      const btn = e.target.closest('[data-filter]'); if (!btn) return;
      logFilter = btn.dataset.filter;
      document.querySelectorAll('#log-filter-tabs .tab').forEach((t) => t.classList.remove('active'));
      btn.classList.add('active');
      renderLogs();
    });

    function renderLogs() {
      const tbody = document.getElementById('logs-tbody');
      const filtered = logFilter === 'all' ? allLogs : allLogs.filter((l) => l.type === logFilter);
      if (!filtered.length) {
        tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--admin-text-muted);padding:24px;font-size:13px;">No logs yet.</td></tr>';
        return;
      }
      tbody.innerHTML = filtered.map((log) => `
        <tr data-id="${log.id}">
          <td style="white-space:nowrap;font-size:0.75rem;">${log.logDate}</td>
          <td><span class="badge-${log.type}">${log.type}</span></td>
          <td style="font-size:0.75rem;">${log.area}</td>
          <td style="font-size:0.75rem;max-width:200px;">${log.summary}</td>
          <td style="font-size:0.75rem;max-width:180px;color:var(--admin-text-muted);">${log.actionTaken || '—'}</td>
          <td style="font-size:0.75rem;">${log.loggedBy}</td>
          <td><button class="act-btn act-btn--danger" data-del-log="${log.id}" type="button">Delete</button></td>
        </tr>
      `).join('');
    }

    async function loadClientData(clientId) {
      if (!clientId) {
        selectedClientId = '';
        ['stats-bar', 'connection-panel', 'log-panel', 'logs-panel', 'roi-panel'].forEach((id) => {
          const el = document.getElementById(id); if (el) el.style.display = 'none';
        });
        const reportsLink = document.getElementById('btn-reports-link');
        if (reportsLink) reportsLink.style.display = 'none';
        return;
      }
      selectedClientId = clientId;
      document.getElementById('stats-bar').style.display = '';
      document.getElementById('connection-panel').style.display = '';
      document.getElementById('log-panel').style.display = '';
      document.getElementById('logs-panel').style.display = '';
      document.getElementById('roi-panel').style.display = '';
      const reportsLink = document.getElementById('btn-reports-link');
      if (reportsLink) {
        reportsLink.href = `/maintenance/reports/${encodeURIComponent(clientId)}`;
        reportsLink.style.display = '';
      }
      renderConnectionFromSelect();

      const [logsRes, woRes] = await Promise.all([
        fetch(`/api/maintenance/logs?serviceClientId=${encodeURIComponent(clientId)}`),
        fetch(`/api/maintenance/work-orders?serviceClientId=${encodeURIComponent(clientId)}`),
      ]);
      allLogs = await logsRes.json().catch(() => []);
      const wos = await woRes.json().catch(() => []);
      renderLogs();

      const now = new Date();
      const q = Math.floor(now.getMonth() / 3);
      const qStart = new Date(now.getFullYear(), q * 3, 1);
      const qEnd = new Date(now.getFullYear(), q * 3 + 3, 0);
      const qLogs = allLogs.filter((l) => l.logDate >= qStart.toISOString().slice(0, 10) && l.logDate <= qEnd.toISOString().slice(0, 10));
      document.getElementById('stat-total').textContent = String(qLogs.length);
      document.getElementById('stat-incidents').textContent = String(qLogs.filter((l) => l.type === 'incident').length);
      document.getElementById('stat-preventive').textContent = String(qLogs.filter((l) => l.type === 'preventive').length);
      document.getElementById('stat-support').textContent = String(qLogs.filter((l) => l.type === 'support').length);
      document.getElementById('stat-open-wo').textContent = String(wos.filter((w) => !['completed','invoiced'].includes(w.status)).length);

      loadROI(clientId);
    }

    async function loadROI(clientId) {
      const res = await fetch(`/api/roi/comparison?serviceClientId=${encodeURIComponent(clientId)}`);
      if (!res.ok) return;
      const data = await res.json().catch(() => null);
      if (!data) return;
      const container = document.getElementById('roi-comparison');
      const metricLabels = {
        active_tenants: 'Active tenants', total_properties: 'Properties managed',
        total_landlords: 'Landlords / owners', payments_month: 'Payments (month)',
        revenue_tracked_ugx: 'Revenue tracked (UGX)', avg_tat_minutes: 'Avg TAT (min)',
        total_tests: 'Total tests', delay_rate_pct: 'Delay rate (%)',
        revenue_ugx: 'Revenue — legacy (UGX)',
      };
      const lowerIsBetter = ['avg_tat_minutes', 'delay_rate_pct'];
      const entries = Object.entries(data);
      if (!entries.length) {
        container.innerHTML = '<p style="color:var(--admin-text-muted);font-size:13px;">No snapshots yet. Use <strong>Log metrics</strong> to record numbers.</p>';
        return;
      }
      container.innerHTML = entries.map(([key, val]) => {
        const v = val;
        const label = metricLabels[key] || key;
        if (!v.baseline && !v.current) return '';
        const hasChange = v.baseline != null && v.current != null;
        const pct = hasChange ? ((v.current - v.baseline) / Math.abs(v.baseline) * 100).toFixed(1) : null;
        const improved = lowerIsBetter.includes(key) ? (v.current < v.baseline) : (v.current > v.baseline);
        return `<div class="roi-metric-card">
          <div class="roi-metric-label">${label}</div>
          <div class="roi-metric-vals">
            ${v.baseline != null ? `<span class="roi-val-old">${Number(v.baseline).toLocaleString()}</span>` : ''}
            <span class="roi-val-new">${v.current != null ? Number(v.current).toLocaleString() : '—'}</span>
            ${pct !== null ? `<span class="roi-change ${improved ? 'roi-change--good' : 'roi-change--bad'}">${improved ? '▲' : '▼'} ${Math.abs(Number(pct))}%</span>` : ''}
          </div>
        </div>`;
      }).join('');
    }

    document.getElementById('client-select').addEventListener('change', (e) => { loadClientData(e.target.value); });

    document.getElementById('btn-pull-roi')?.addEventListener('click', async () => {
      const errEl = document.getElementById('roi-pull-error');
      errEl.style.display = 'none';
      if (!selectedClientId) return;
      const btn = document.getElementById('btn-pull-roi');
      btn.disabled = true; const old = btn.textContent; btn.textContent = 'Pulling…';
      try {
        const API_KEY = sessionStorage.getItem('zyntel_invoice_api_key') ?? '';
        const r = await fetch(`/api/roi/pull?serviceClientId=${encodeURIComponent(selectedClientId)}`, { headers: { 'x-api-key': API_KEY } });
        const d = await r.json().catch(() => ({}));
        if (!r.ok) { errEl.textContent = d.error || 'Pull failed'; errEl.style.display = 'block'; return; }
        showToast('ROI snapshot pulled and stored');
        window.__adminClearUnsavedChanges?.();
        window.location.reload();
      } catch { errEl.textContent = 'Pull failed'; errEl.style.display = 'block'; }
      finally { btn.disabled = false; btn.textContent = old; }
    });

    document.getElementById('form-log').addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!selectedClientId) { showToast('Select a service client first', 'error'); return; }
      if (!selectedType) { showToast('Select a log type (Incident / Preventive / Support)', 'error'); return; }
      const payload = {
        serviceClientId: selectedClientId,
        logDate: document.getElementById('log-date').value,
        type: selectedType,
        area: document.getElementById('log-area').value.trim(),
        summary: document.getElementById('log-summary').value.trim(),
        actionTaken: document.getElementById('log-action').value.trim(),
        outcome: document.getElementById('log-outcome').value.trim(),
        loggedBy: document.getElementById('log-by').value.trim(),
      };
      if (!payload.loggedBy) { showToast('Enter who is logging this entry', 'error'); return; }
      const res = await fetch('/api/maintenance/logs', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
      if (!res.ok) { const d = await res.json().catch(()=>({})); showToast(d.error || 'Failed to save log', 'error'); return; }
      const newLog = await res.json();
      allLogs.unshift(newLog);
      renderLogs();
      document.getElementById('form-log').reset();
      document.getElementById('log-date').value = today;
      document.querySelectorAll('.type-chip').forEach((b) => b.classList.remove('active'));
      selectedType = '';
      document.getElementById('log-type').value = '';
      document.getElementById('summary-counter').textContent = '0 / 200';
      showToast('Log entry saved');
    });

    document.getElementById('logs-tbody').addEventListener('click', async (e) => {
      const delBtn = e.target.closest('[data-del-log]'); if (!delBtn) return;
      const id = delBtn.dataset.delLog;
      openConfirm({ title: 'Delete log entry?', message: 'This cannot be undone.', label: 'Delete', onConfirm: async () => {
        const res = await fetch(`/api/maintenance/logs?id=${encodeURIComponent(id)}`, { method: 'DELETE' });
        if (!res.ok) { showToast('Failed to delete', 'error'); return; }
        allLogs = allLogs.filter((l) => l.id !== id);
        renderLogs();
        showToast('Log deleted');
      }});
    });

    const API_KEY = sessionStorage.getItem('zyntel_invoice_api_key') ?? '';
    async function fillCanonicalClientSelect() {
      const sel = document.getElementById('nc-client-id');
      if (!sel || sel.dataset.ready === '1') return;
      sel.innerHTML = '<option value="">— Select a client —</option>';
      try {
        const r = await fetch('/api/clients/list', { headers: { 'x-api-key': API_KEY } });
        if (!r.ok) return;
        const { clients } = await r.json();
        for (const c of clients || []) {
          const o = document.createElement('option');
          o.value = String(c.id); o.textContent = `${c.name} (${c.email})`;
          o.dataset.name = c.name || ''; o.dataset.email = c.email || '';
          sel.appendChild(o);
        }
      } catch (_) {}
      sel.dataset.ready = '1';
    }

    document.getElementById('btn-new-client').addEventListener('click', async () => {
      await fillCanonicalClientSelect(); showModal('modal-new-client');
    });
    document.getElementById('nc-client-id')?.addEventListener('change', (e) => {
      const opt = e.target.selectedOptions?.[0];
      if (!opt) return;
      const nameEl = document.getElementById('nc-name');
      const emailEl = document.getElementById('nc-contact-email');
      if (nameEl) nameEl.value = (opt.dataset?.name ?? '').trim();
      if (emailEl && !emailEl.value?.trim()) emailEl.value = (opt.dataset?.email ?? '').trim();
    });
    document.getElementById('form-new-client').addEventListener('submit', async (e) => {
      e.preventDefault();
      const inv = document.getElementById('nc-client-id').value;
      const payload = {
        name: document.getElementById('nc-name').value.trim(),
        productName: document.getElementById('nc-product-name').value.trim(),
        productType: document.getElementById('nc-product-type').value,
        contactName: document.getElementById('nc-contact-name').value.trim(),
        contactEmail: document.getElementById('nc-contact-email').value.trim(),
        invoiceClientId: inv ? Number(inv) : null,
        healthCheckUrl: document.getElementById('nc-health-url').value.trim() || null,
        apiUrl: document.getElementById('nc-api-url').value.trim() || null,
        repoUrl: document.getElementById('nc-repo-url').value.trim() || null,
        sentryUrl: document.getElementById('nc-sentry-url').value.trim() || null,
        cronitorUrl: document.getElementById('nc-cronitor-url').value.trim() || null,
        notes: document.getElementById('nc-notes').value.trim() || null,
        generateApiKey: !!document.getElementById('nc-generate-key')?.checked,
      };
      const res = await fetch('/api/maintenance/clients', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) { showToast(data.error || 'Failed to create client', 'error'); return; }
      closeModal('modal-new-client');
      if (data.apiKey) { showToast('Service client created'); showApiKeyOnce(data.apiKey, true, data.client?.id); }
      else { window.location.reload(); }
    });

    document.getElementById('btn-log-metrics').addEventListener('click', () => showModal('modal-log-metrics'));
    document.getElementById('form-log-metrics').addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!selectedClientId) return;
      const date = document.getElementById('metrics-date').value || today;
      const metrics = [
        { key: 'active_tenants', el: 'm-active-tenants' }, { key: 'total_properties', el: 'm-total-properties' },
        { key: 'total_landlords', el: 'm-total-landlords' }, { key: 'payments_month', el: 'm-payments-month' },
        { key: 'revenue_tracked_ugx', el: 'm-revenue-tracked' }, { key: 'avg_tat_minutes', el: 'm-avg-tat' },
        { key: 'total_tests', el: 'm-total-tests' }, { key: 'delay_rate_pct', el: 'm-delay-rate' },
        { key: 'revenue_ugx', el: 'm-revenue-legacy' },
      ];
      const payloads = metrics.filter(({ el }) => document.getElementById(el).value !== '').map(({ key, el }) => ({
        serviceClientId: selectedClientId, snapshotDate: date, metricKey: key,
        metricValue: Number(document.getElementById(el).value),
      }));
      if (!payloads.length) { showToast('Enter at least one metric', 'error'); return; }
      for (const p of payloads) {
        const r = await fetch('/api/roi/snapshots', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(p) });
        if (!r.ok) { showToast('Failed to save metrics', 'error'); return; }
      }
      closeModal('modal-log-metrics'); showToast('Snapshot saved'); loadROI(selectedClientId);
    });

    document.getElementById('btn-gen-api-key')?.addEventListener('click', async () => {
      if (!selectedClientId) { showToast('Select a service client first', 'error'); return; }
      const res = await fetch('/api/maintenance/rotate-key', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ serviceClientId: selectedClientId }) });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) { showToast(data.error || 'Failed to generate key', 'error'); return; }
      showApiKeyOnce(data.apiKey, false);
    });

    document.getElementById('btn-download-report')?.addEventListener('click', () => {
      if (!selectedClientId) { showToast('Select a service client first', 'error'); return; }
      const now = new Date();
      const q = 'Q' + (Math.floor(now.getMonth() / 3) + 1);
      const year = now.getFullYear();
      window.open(`/api/maintenance/report-pdf?clientId=${encodeURIComponent(selectedClientId)}&quarter=${q}&year=${year}`, '_blank');
    });

    async function runMigration(endpoint, statusId, btnId) {
      const statusEl = document.getElementById(statusId);
      const btn = document.getElementById(btnId);
      if (!btn || !statusEl) return;
      btn.disabled = true;
      statusEl.textContent = 'Running…';
      statusEl.className = 'maint-mig-status running';
      try {
        const res = await fetch(endpoint, { method: 'POST' });
        const d = await res.json().catch(() => ({}));
        if (!res.ok) {
          statusEl.textContent = d.error || `Error ${res.status}`;
          statusEl.className = 'maint-mig-status err';
          showToast(d.error || `Migration failed (${res.status})`, 'error');
        } else {
          statusEl.textContent = d.message ?? 'Done ✓';
          statusEl.className = 'maint-mig-status ok';
          showToast(d.message ?? 'Migration applied');
        }
      } catch (e) {
        statusEl.textContent = 'Network error';
        statusEl.className = 'maint-mig-status err';
        showToast('Network error', 'error');
      } finally {
        btn.disabled = false;
      }
    }

    document.getElementById('btn-migrate-reports')?.addEventListener('click', () =>
      runMigration('/api/maintenance/apply-report-migrations', 'mig-reports-status', 'btn-migrate-reports')
    );
    document.getElementById('btn-migrate-logs')?.addEventListener('click', () =>
      runMigration('/api/maintenance/apply-log-migrations', 'mig-logs-status', 'btn-migrate-logs')
    );
  </script>
</AdminLayout>
