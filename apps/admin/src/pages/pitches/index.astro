---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { loadPitchSessionsPageData } from '../../lib/pitches.ts';

const SITE = import.meta.env.SITE_URL ?? 'https://admin.zyntel.net';

const { sessions, viewStatsById: statsById, error: pitchesLoadError } = await loadPitchSessionsPageData();

const sessionsWithMeta = sessions.map((s) => {
  const vs = statsById.get(s.id) ?? { viewsCount: 0, lastViewedAt: null };
  const isExpired = s.status === 'active' && s.expiryDate ? s.expiryDate.getTime() < Date.now() : false;
  const displayStatus = s.status === 'disabled' ? 'disabled' : isExpired ? 'expired' : 'active';
  return {
    ...s,
    pitchLink: `${SITE}/p/pitch/${s.token}`,
    displayStatus,
    expiryFormatted: s.expiryDate
      ? new Date(s.expiryDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
      : 'Never',
    viewsCount: vs.viewsCount,
    lastViewedFormatted: vs.lastViewedAt
      ? vs.lastViewedAt.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) +
        ' ' +
        vs.lastViewedAt.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' })
      : '—',
  };
});
---

<AdminLayout title="Pitches">
  <header class="admin-header previews-header">
    <h1 class="admin-title">Pitches</h1>
    <button id="btn-new-session" class="admin-btn admin-btn-primary" type="button" disabled={!!pitchesLoadError}>New Pitch Session</button>
  </header>

  {pitchesLoadError && (
    <div class="admin-card" style="border-color:#f59e0b;background:#fffbeb;margin-bottom:1rem;">
      <p style="margin:0 0 8px;font-weight:700;color:#92400e;">Pitches database not ready</p>
      <p style="margin:0;font-size:13px;color:#78350f;line-height:1.55;">
        Run <code style="background:#fef3c7;padding:2px 6px;border-radius:4px;">apps/admin/migrations/002_pitch_sessions.sql</code> in the Neon SQL Editor, then redeploy or refresh this page.
      </p>
      <p style="margin:8px 0 0;font-size:12px;color:#a16207;font-family:ui-monospace,monospace;word-break:break-all;">{pitchesLoadError}</p>
    </div>
  )}

  <div class="admin-card">
    <div class="admin-card-header previews-toolbar">
      <div class="filter-tabs" id="filter-tabs">
        <button class="tab active" data-filter="all" type="button">All</button>
        <button class="tab" data-filter="active" type="button">Active</button>
        <button class="tab" data-filter="expired" type="button">Expired</button>
        <button class="tab" data-filter="disabled" type="button">Disabled</button>
      </div>
      <input id="search-input" class="admin-form-input" placeholder="Search..." />
    </div>

    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Label</th>
            <th>Audience</th>
            <th>Event/Context</th>
            <th>Deck</th>
            <th>Status</th>
            <th>Expiry</th>
            <th>Views</th>
            <th>Last Viewed</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="pitches-tbody">
          {sessionsWithMeta.map((s) => (
            <tr
              data-id={s.id}
              data-status={s.displayStatus}
              data-search={`${s.label} ${s.audienceName} ${s.eventContext} ${s.deckFolder}`.toLowerCase()}
              data-token={s.token}
            >
              <td>
                <div class="preview-client-name">{s.label}</div>
              </td>
              <td>{s.audienceName}</td>
              <td>{s.eventContext}</td>
              <td><span class="admin-badge admin-badge-ghost">{s.deckFolder}</span></td>
              <td><span class={`admin-badge status-${s.displayStatus}`}>{s.displayStatus}</span></td>
              <td>{s.expiryFormatted}</td>
              <td>{s.viewsCount}</td>
              <td>{s.lastViewedFormatted}</td>
              <td class="preview-actions">
                <button class="act-btn" data-action="copy" data-link={s.pitchLink} type="button">Copy Link</button>
                <button class="act-btn" data-action="upload" data-token={s.token} type="button">Upload Deck</button>
                <button class="act-btn" data-action="history" data-id={s.id} type="button">View History</button>
                <button class="act-btn" data-action="edit" data-session={JSON.stringify({
                  id: s.id,
                  label: s.label,
                  audienceName: s.audienceName,
                  eventContext: s.eventContext,
                  deckFolder: s.deckFolder,
                  deckFile: s.deckFile,
                  status: s.status,
                  expiryDate: s.expiryDate
                })} type="button">Edit</button>
                {s.displayStatus !== 'disabled'
                  ? <button class="act-btn act-btn--warn" data-action="disable" data-id={s.id} type="button">Disable</button>
                  : <button class="act-btn act-btn--ok" data-action="enable" data-id={s.id} type="button">Enable</button>}
                <button class="act-btn act-btn--danger" data-action="delete" data-id={s.id} data-label={s.label} type="button">Delete</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <div id="modal-new" class="preview-modal-overlay" style="display:none">
    <div class="modal">
      <h3>New Pitch Session</h3>
      <form id="form-new" class="grid-form"></form>
    </div>
  </div>

  <div id="modal-edit" class="preview-modal-overlay" style="display:none">
    <div class="modal">
      <h3>Edit Pitch Session</h3>
      <form id="form-edit" class="grid-form"></form>
    </div>
  </div>

  <div id="modal-history" class="preview-modal-overlay" style="display:none">
    <div class="modal">
      <h3>View History</h3>
      <div id="history-body" style="margin-top:10px"></div>
      <div class="modal-actions">
        <button type="button" class="admin-btn admin-btn-secondary" data-close="modal-history">Close</button>
      </div>
    </div>
  </div>

  <div id="modal-confirm" class="preview-modal-overlay" style="display:none"><div class="modal"><h3 id="confirm-title"></h3><p id="confirm-message"></p><div class="modal-actions"><button type="button" class="admin-btn admin-btn-secondary" data-close="modal-confirm">Cancel</button><button id="confirm-btn" type="button" class="admin-btn admin-btn-primary">Confirm</button></div></div></div>
  <div id="toast-root"></div>
  <input id="file-deck" type="file" accept=".zip,text/html,.html" style="display:none" />

  <style>
    .previews-header{display:flex;justify-content:space-between;align-items:center;}
    .previews-toolbar{gap:1rem;flex-wrap:wrap;}
    .filter-tabs{display:flex;gap:.5rem;flex-wrap:wrap;}
    .tab{border:1px solid var(--admin-border);background:#fff;border-radius:999px;padding:.35rem .7rem;font-size:12px;cursor:pointer;}
    .tab.active{background:rgba(99,91,255,.12);border-color:#635bff;color:#635bff;}
    .preview-client-name{font-weight:700;display:flex;gap:6px;align-items:center;}
    .status-active{background:rgba(13,148,136,.15);color:#0d9488}
    .status-expired{background:rgba(245,158,11,.2);color:#b45309}
    .status-disabled{background:rgba(107,114,128,.2);color:#374151}
    .preview-actions{display:flex;flex-wrap:wrap;gap:6px}
    .act-btn{font-size:11px;padding:4px 8px;border:1px solid var(--admin-border);background:#fff;border-radius:6px;cursor:pointer}
    .act-btn--warn{color:#b45309}.act-btn--ok{color:#15803d}.act-btn--danger{color:#b91c1c}
    .preview-modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.35);align-items:center;justify-content:center;z-index:1200;padding:16px}
    .modal{width:min(860px,100%);max-height:90vh;overflow:auto;background:#fff;border-radius:12px;padding:18px}
    .grid-form{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .grid-form .full{grid-column:1/-1}
    .modal-actions{display:flex;justify-content:flex-end;gap:8px;grid-column:1/-1;margin-top:6px}
    #toast-root{position:fixed;right:16px;bottom:16px;display:flex;flex-direction:column;gap:8px;z-index:2000}
    .toast{background:#111;color:#fff;border-radius:8px;padding:10px 12px;font-size:12px;min-width:260px}
    .toast.error{background:#7f1d1d}
  </style>

  <script>
    const DECK_FOLDERS = ['kanta-seed']; // add new pitch deck folders here

    let activeFilter = 'all';
    let activeSearch = '';
    let confirmCallback = null;
    const tbody = document.getElementById('pitches-tbody');

    function escapeHtml(v){return String(v??'').replace(/[&<>"']/g,(m)=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));}

    function applyFilters(){
      [...tbody.querySelectorAll('tr')].forEach((row)=>{
        const status=row.dataset.status;
        const search=(row.dataset.search||'');
        const passTab=activeFilter==='all' || status===activeFilter;
        const passSearch=!activeSearch||search.includes(activeSearch);
        row.hidden=!(passTab&&passSearch);
      });
    }

    document.getElementById('filter-tabs').addEventListener('click',(e)=>{
      const btn=e.target.closest('[data-filter]'); if(!btn) return;
      activeFilter=btn.dataset.filter;
      document.querySelectorAll('#filter-tabs .tab').forEach((t)=>t.classList.remove('active'));
      btn.classList.add('active');
      applyFilters();
    });
    document.getElementById('search-input').addEventListener('input',(e)=>{activeSearch=e.target.value.toLowerCase().trim();applyFilters();});

    function showToast(message,type='success'){
      const toast=document.createElement('div'); toast.className=`toast ${type==='error'?'error':''}`;
      toast.textContent=message;
      document.getElementById('toast-root').appendChild(toast);
      setTimeout(()=>toast.remove(),5000);
    }
    function showModal(id){var el=document.getElementById(id); if(el) el.style.display='flex';}
    function closeModal(id){var el=document.getElementById(id); if(el) el.style.display='none';}
    document.addEventListener('click',(e)=>{const c=e.target.closest('[data-close]'); if(c) closeModal(c.dataset.close);});
    document.querySelectorAll('.preview-modal-overlay').forEach(function(overlay){
      overlay.addEventListener('click', function(e){
        if(e.target===overlay) closeModal(overlay.id);
      });
    });
    document.addEventListener('keydown', function(e){
      if(e.key!=='Escape') return;
      var modals=document.querySelectorAll('.preview-modal-overlay');
      for(var i=modals.length-1;i>=0;i--){
        if(modals[i].style.display!=='none'){
          closeModal(modals[i].id);
          break;
        }
      }
    });

    function openConfirm(opts){
      document.getElementById('confirm-title').textContent=opts.title;
      document.getElementById('confirm-message').textContent=opts.message;
      const btn=document.getElementById('confirm-btn');
      btn.textContent=opts.label||'Confirm';
      confirmCallback=opts.onConfirm||null;
      showModal('modal-confirm');
    }
    document.getElementById('confirm-btn').addEventListener('click', async ()=>{
      try{ await confirmCallback?.(); } finally { closeModal('modal-confirm'); confirmCallback=null; }
    });

    function createFormHtml(prefix, existing){
      const v=(k,def='')=>existing&&existing[k]!=null?existing[k]:def;
      const expiryIso=v('expiryDate', null);
      const never = expiryIso===null;
      return `
        <div class="full">
          <label class="admin-form-label">Label</label>
          <input class="admin-form-input" id="${prefix}-label" value="${escapeHtml(v('label'))}" placeholder="STI Hackathon Demo Day" required />
        </div>
        <div>
          <label class="admin-form-label">Audience name</label>
          <input class="admin-form-input" id="${prefix}-audience" value="${escapeHtml(v('audienceName'))}" placeholder="STI Judges" required />
        </div>
        <div>
          <label class="admin-form-label">Event/context</label>
          <input class="admin-form-input" id="${prefix}-context" value="${escapeHtml(v('eventContext'))}" placeholder="Future Makers Hackathon 2026" required />
        </div>
        <div>
          <label class="admin-form-label">Deck folder</label>
          <select class="admin-form-input" id="${prefix}-deckFolder">
            ${DECK_FOLDERS.map(f=>`<option value="${f}" ${v('deckFolder')===f?'selected':''}>${f}</option>`).join('')}
          </select>
        </div>
        <div>
          <label class="admin-form-label">Deck file</label>
          <input class="admin-form-input" id="${prefix}-deckFile" value="${escapeHtml(v('deckFile','pitch-deck.html'))}" />
        </div>
        <div class="full" style="display:flex;gap:10px;align-items:center;margin-top:4px;">
          <label style="display:flex;gap:8px;align-items:center;font-size:12px;">
            <input type="checkbox" id="${prefix}-never" ${never?'checked':''} />
            Never expires
          </label>
          <label style="display:flex;gap:8px;align-items:center;font-size:12px;">
            Expiry (days)
            <input type="number" class="admin-form-input" style="width:120px" id="${prefix}-expiryDays" min="1" placeholder="30" ${never?'disabled':''} />
          </label>
        </div>
        <div class="modal-actions">
          <button type="button" class="admin-btn admin-btn-secondary" data-close="modal-${prefix==='new'?'new':'edit'}">Cancel</button>
          <button class="admin-btn admin-btn-primary">${prefix==='new'?'Create':'Save'}</button>
        </div>
      `;
    }

    document.getElementById('btn-new-session').addEventListener('click', ()=>{
      const f=document.getElementById('form-new');
      f.innerHTML=createFormHtml('new', {deckFolder: DECK_FOLDERS[0], deckFile:'pitch-deck.html', expiryDate:null});
      f.querySelector('#new-never').addEventListener('change', (e)=>{
        f.querySelector('#new-expiryDays').disabled = e.target.checked;
      });
      showModal('modal-new');
    });

    document.getElementById('form-new').addEventListener('submit', async (e)=>{
      e.preventDefault();
      const payload={
        label: document.getElementById('new-label').value.trim(),
        audienceName: document.getElementById('new-audience').value.trim(),
        eventContext: document.getElementById('new-context').value.trim(),
        deckFolder: document.getElementById('new-deckFolder').value,
        deckFile: document.getElementById('new-deckFile').value.trim() || 'pitch-deck.html',
        neverExpires: document.getElementById('new-never').checked,
        expiryDays: Number(document.getElementById('new-expiryDays').value || 0) || null,
      };
      const r=await fetch('/api/pitches/sessions',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
      if(!r.ok){ showToast('Failed to create session','error'); return; }
      closeModal('modal-new');
      location.reload();
    });

    document.getElementById('form-edit').addEventListener('submit', async (e)=>{
      e.preventDefault();
      const id=document.getElementById('edit-id').value;
      const never=document.getElementById('edit-never').checked;
      const days=Number(document.getElementById('edit-expiryDays').value||0)||null;
      const expiryDate = never ? null : (days? new Date(Date.now()+days*24*60*60*1000).toISOString() : null);
      const payload={
        id,
        label: document.getElementById('edit-label').value.trim(),
        audienceName: document.getElementById('edit-audience').value.trim(),
        eventContext: document.getElementById('edit-context').value.trim(),
        deckFolder: document.getElementById('edit-deckFolder').value,
        deckFile: document.getElementById('edit-deckFile').value.trim() || 'pitch-deck.html',
        expiryDate,
      };
      const r=await fetch('/api/pitches/sessions',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
      if(!r.ok){ showToast('Failed to update session','error'); return; }
      closeModal('modal-edit');
      location.reload();
    });

    function copyToClipboard(text){
      navigator.clipboard?.writeText(text).then(()=>showToast('Link copied'));
    }

    async function openHistory(id){
      const el=document.getElementById('history-body');
      el.innerHTML='Loading...';
      showModal('modal-history');
      const r=await fetch(`/api/pitches/views?sessionId=${encodeURIComponent(id)}`);
      if(!r.ok){ el.innerHTML='<p>Failed to load history.</p>'; return; }
      const views=await r.json();
      if(!views.length){ el.innerHTML='<p style="color:#6b7280">No views yet.</p>'; return; }
      el.innerHTML = '<div style="display:flex;flex-direction:column;gap:8px">' + views.map(v=>{
        const dt=new Date(v.viewedAt);
        const ts=dt.toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})+' at '+dt.toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});
        const dur = v.durationSeconds==null ? '' : ` · ${Math.floor(v.durationSeconds/60)} min ${String(v.durationSeconds%60).padStart(2,'0')} sec`;
        return `<div style="border:1px solid #e5e7eb;border-radius:10px;padding:10px 12px;font-size:12px">Opened ${ts}${dur}</div>`;
      }).join('') + '</div>';
    }

    document.addEventListener('click', (e)=>{
      const btn=e.target.closest('[data-action]'); if(!btn) return;
      const action=btn.dataset.action;
      const row=btn.closest('tr');
      if(action==='copy'){ copyToClipboard(btn.dataset.link); return; }
      if(action==='upload'){
        const token = btn.dataset.token;
        const input = document.getElementById('file-deck');
        input.value = '';
        input.onchange = async () => {
          const f = input.files && input.files[0];
          if (!f) return;
          const fd = new FormData();
          fd.append('token', token);
          fd.append('file', f);
          showToast('Uploading deck…');
          const r = await fetch('/api/pitches/upload-deck', { method: 'POST', body: fd });
          const d = await r.json().catch(() => ({}));
          if (!r.ok) { showToast(d.error || 'Upload failed', 'error'); return; }
          showToast('Deck uploaded. Your pitch link now serves the uploaded deck.');
        };
        input.click();
        return;
      }
      if(action==='history'){ openHistory(btn.dataset.id); return; }
      if(action==='edit'){
        const s=JSON.parse(btn.dataset.session);
        const f=document.getElementById('form-edit');
        f.innerHTML = '<input type="hidden" id="edit-id" value="'+escapeHtml(s.id)+'" />' + createFormHtml('edit', s);
        f.querySelector('#edit-never').addEventListener('change',(e)=>{
          f.querySelector('#edit-expiryDays').disabled = e.target.checked;
        });
        showModal('modal-edit');
        return;
      }
      if(action==='disable'){
        openConfirm({title:'Disable pitch link?',message:'This pitch link will stop working immediately.',onConfirm:async()=>{
          const r=await fetch('/api/pitches/sessions',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:btn.dataset.id,status:'disabled'})});
          if(!r.ok) return showToast('Failed to disable','error');
          location.reload();
        }});
        return;
      }
      if(action==='enable'){
        openConfirm({title:'Enable pitch link?',message:'Re-enable this pitch link.',onConfirm:async()=>{
          const r=await fetch('/api/pitches/sessions',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:btn.dataset.id,status:'active'})});
          if(!r.ok) return showToast('Failed to enable','error');
          location.reload();
        }});
        return;
      }
      if(action==='delete'){
        openConfirm({title:'Delete pitch session?',message:`Delete "${btn.dataset.label}"? This cannot be undone.`,label:'Delete',onConfirm:async()=>{
          const r=await fetch(`/api/pitches/sessions?id=${encodeURIComponent(btn.dataset.id)}`,{method:'DELETE'});
          if(!r.ok) return showToast('Failed to delete','error');
          row.remove();
          showToast('Deleted');
        }});
        return;
      }
    });

    applyFilters();
  </script>
</AdminLayout>

