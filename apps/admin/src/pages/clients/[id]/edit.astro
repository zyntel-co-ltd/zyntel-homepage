---
import AdminLayout from '../../../layouts/AdminLayout.astro';
export const prerender = false;
---
<AdminLayout title="Edit Client">
  <header class="admin-header">
    <a href="/clients" class="admin-btn admin-btn-ghost" style="margin-bottom: 1rem;">← Back</a>
    <h1 class="admin-title">Edit client</h1>
    <p class="admin-subtitle" id="edit-subtitle">Loading...</p>
  </header>

  <div class="admin-card" id="links-card" style="max-width: 720px; margin-bottom: 1rem;">
    <h2 style="font-size: 0.9375rem; margin: 0 0 0.5rem;">Connected products</h2>
    <p class="admin-form-hint" style="margin: 0 0 0.75rem; font-size: 0.8125rem;">
      Maintenance service products and property ROI profiles that reference this client ID — keep one billing identity everywhere.
    </p>
    <div id="links-body" style="font-size: 0.875rem; color: var(--admin-text-muted);">Loading…</div>
  </div>

  <div class="admin-card" style="max-width: 520px;">
    <div class="admin-modal-body">
      <form id="edit-client-form">
        <input type="hidden" name="client_id" id="client-id" />
        <div class="admin-form-group">
          <label class="admin-form-label">Name *</label>
          <input type="text" name="name" class="admin-form-input" required placeholder="Acme Ltd" />
        </div>
        <div class="admin-form-group">
          <label class="admin-form-label">Contacts *</label>
          <p class="admin-form-hint" style="font-size: 0.8125rem; color: var(--admin-text-muted); margin: 0 0 0.5rem 0;">
            Add one or more contacts. Mark one as default — that address is used by default when sending quotes/invoices.
          </p>
          <div id="client-contacts-rows"></div>
          <button type="button" class="admin-btn admin-btn-secondary" id="add-client-contact" style="margin-top: 0.25rem;">+ Add contact</button>
        </div>
        <div class="admin-form-group">
          <label class="admin-form-label">Phone</label>
          <input type="text" name="phone" class="admin-form-input" placeholder="+256..." />
        </div>
        <div class="admin-form-group">
          <label class="admin-form-label">Address</label>
          <input type="text" name="address" class="admin-form-input" placeholder="Kampala, Uganda" />
        </div>
        <button type="submit" class="admin-btn admin-btn-primary" id="save-btn">Save</button>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  const API_KEY = sessionStorage.getItem('zyntel_invoice_api_key');
  const B = (window as unknown as { __ADMIN_BASE__?: string }).__ADMIN_BASE__ ?? '';
  if (!API_KEY) window.location.href = B + '/login';

  const parts = window.location.pathname.split('/').filter(Boolean);
  const clientsIdx = parts.indexOf('clients');
  const id = clientsIdx >= 0 && parts[clientsIdx + 1] ? parts[clientsIdx + 1] : null;
  if (!id) window.location.href = B + '/clients';

  const contactsRows = document.getElementById('client-contacts-rows')!;

  function gatherContacts(): Array<{ name: string | null; email: string; phone: string | null; isDefault: boolean }> {
    const rows = Array.from(document.querySelectorAll('#client-contacts-rows [data-contact-row]')) as HTMLElement[];
    const out = rows.map((row) => {
      const name = (row.querySelector('.contact-name') as HTMLInputElement)?.value?.trim() || '';
      const email = (row.querySelector('.contact-email') as HTMLInputElement)?.value?.trim() || '';
      const phone = (row.querySelector('.contact-phone') as HTMLInputElement)?.value?.trim() || '';
      const isDefault = (row.querySelector('.contact-default') as HTMLInputElement)?.checked || false;
      return { name: name || null, email, phone: phone || null, isDefault };
    }).filter((c) => c.email);
    if (!out.length) return [];
    const idx = out.findIndex((c) => c.isDefault);
    const def = idx >= 0 ? idx : 0;
    return out.map((c, i) => ({ ...c, isDefault: i === def }));
  }

  function renderContacts(list: Array<{ name?: string | null; email: string; phone?: string | null; isDefault?: boolean | null }>) {
    const items = list?.length ? list : [{ name: null, email: '', phone: null, isDefault: true }];
    const defIdx = items.findIndex((c) => c.isDefault);
    const defaultIndex = defIdx >= 0 ? defIdx : 0;
    contactsRows.innerHTML = '';
    items.forEach((c, i) => {
      const row = document.createElement('div');
      row.dataset.contactRow = '1';
      row.style.cssText = 'display:grid;grid-template-columns: 28px 1.2fr 1.4fr 1fr 90px;gap:0.5rem;align-items:center;margin-bottom:0.5rem;';

      const radioWrap = document.createElement('div');
      radioWrap.style.display = 'flex';
      radioWrap.style.justifyContent = 'center';
      const radio = document.createElement('input');
      radio.type = 'radio';
      radio.name = 'contact-default';
      radio.className = 'contact-default';
      radio.checked = i === defaultIndex;
      radio.title = 'Default';
      radioWrap.appendChild(radio);

      const nameInp = document.createElement('input');
      nameInp.type = 'text';
      nameInp.className = 'admin-form-input contact-name';
      nameInp.placeholder = 'Name';
      nameInp.value = (c.name ?? '') as string;

      const emailInp = document.createElement('input');
      emailInp.type = 'email';
      emailInp.className = 'admin-form-input contact-email';
      emailInp.placeholder = 'email@company.com';
      emailInp.required = i === defaultIndex;
      emailInp.value = c.email ?? '';

      const phoneInp = document.createElement('input');
      phoneInp.type = 'text';
      phoneInp.className = 'admin-form-input contact-phone';
      phoneInp.placeholder = 'Phone (optional)';
      phoneInp.value = (c.phone ?? '') as string;

      const rm = document.createElement('button');
      rm.type = 'button';
      rm.className = 'admin-btn admin-btn-ghost';
      rm.textContent = 'Remove';
      rm.style.fontSize = '0.8125rem';
      rm.disabled = items.length <= 1;
      rm.addEventListener('click', () => {
        const cur = gatherContacts();
        cur.splice(i, 1);
        renderContacts(cur.length ? cur : [{ name: null, email: '', phone: null, isDefault: true }]);
      });

      row.appendChild(radioWrap);
      row.appendChild(nameInp);
      row.appendChild(emailInp);
      row.appendChild(phoneInp);
      row.appendChild(rm);
      contactsRows.appendChild(row);
    });
  }

  document.getElementById('add-client-contact')?.addEventListener('click', () => {
    renderContacts([...gatherContacts(), { name: null, email: '', phone: null, isDefault: false }]);
  });

  async function load() {
    const res = await fetch(`/api/clients/${id}?links=1`, { headers: { 'x-api-key': API_KEY! } });
    if (res.status === 401) {
      sessionStorage.removeItem('zyntel_invoice_api_key');
      window.location.href = B + '/login';
      return;
    }
    if (!res.ok) {
      document.getElementById('edit-subtitle')!.textContent = 'Client not found';
      return;
    }
    const { client, links } = await res.json();
    if (!client) {
      document.getElementById('edit-subtitle')!.textContent = 'Client not found';
      return;
    }
    document.getElementById('edit-subtitle')!.textContent = client.name;
    (document.getElementById('client-id') as HTMLInputElement).value = String(client.id);
    (document.querySelector('[name="name"]') as HTMLInputElement).value = client.name || '';
    (document.querySelector('[name="phone"]') as HTMLInputElement).value = client.phone || '';
    (document.querySelector('[name="address"]') as HTMLInputElement).value = client.address || '';
    const contacts =
      client.contacts?.length
        ? client.contacts
        : ((client.emails?.length ? client.emails : [client.email]).filter(Boolean) as string[]).map((e: string, idx: number) => ({
            name: null,
            email: e,
            phone: null,
            isDefault: idx === 0,
          }));
    renderContacts(contacts);

    const lb = document.getElementById('links-body')!;
    if (links) {
      const sp = links.serviceProducts || [];
      const rp = links.roiProfiles || [];
      const parts = [];
      if (sp.length) {
        parts.push(
          '<strong style="color:var(--admin-text)">Maintenance products:</strong> ' +
            sp.map((p: { productName: string }) => p.productName).join(', ')
        );
      }
      if (rp.length) {
        parts.push(
          '<strong style="color:var(--admin-text)">ROI profiles:</strong> ' +
            rp.map((p: { appName: string }) => p.appName).join(', ')
        );
      }
      lb.innerHTML =
        parts.length > 0
          ? parts.join('<br/><br/>')
          : 'Nothing linked yet. In <a href="/maintenance">Maintenance</a> → New Service Client, select this client under “Client (from Clients directory)”. For property ROI metrics, set <code>client_id</code> when editing that ROI profile.';
    } else {
      lb.textContent = '';
    }
  }

  document.getElementById('edit-client-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
    const contacts = gatherContacts();
    if (contacts.length === 0) {
      alert('Add at least one contact email.');
      return;
    }
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';
    try {
      const res = await fetch(`/api/clients/${id}/update`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', 'x-api-key': API_KEY },
        body: JSON.stringify({
          name: (form.querySelector('[name="name"]') as HTMLInputElement).value.trim(),
          contacts,
          phone: (form.querySelector('[name="phone"]') as HTMLInputElement).value.trim() || null,
          address: (form.querySelector('[name="address"]') as HTMLInputElement).value.trim() || null,
        }),
      });
      const data = await res.json();
      if (!res.ok) {
        alert(data.error || 'Failed to save');
        return;
      }
      window.__adminClearUnsavedChanges?.();
      window.location.href = B + '/clients';
    } catch {
      alert('Failed to save');
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save';
    }
  });

  load();
</script>
