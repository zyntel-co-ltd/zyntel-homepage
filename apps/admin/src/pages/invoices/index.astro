---
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="Invoices">
  <header class="admin-header">
    <h1 class="admin-title">Invoices</h1>
    <p class="admin-subtitle">Manage and track all your invoices</p>
  </header>

  <div class="admin-card">
    <div class="admin-card-header">
      <h2 class="admin-card-title">All invoices</h2>
      <a href="/admin/invoices/new" class="admin-btn admin-btn-primary">New invoice</a>
    </div>
    <div class="admin-table-wrap">
      <table class="admin-table" id="invoices-table">
        <thead>
          <tr>
            <th>Invoice</th>
            <th>Client</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Date</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="invoices-tbody">
          <tr><td colspan="6"><div class="admin-empty"><div class="admin-empty-icon">Loading...</div></div></td></tr>
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script>
  const API_KEY = sessionStorage.getItem('zyntel_invoice_api_key');
  const B = (window as unknown as { __ADMIN_BASE__?: string }).__ADMIN_BASE__ ?? '/admin';
  if (!API_KEY) window.location.href = B + '/login';

  async function load() {
    const tbody = document.getElementById('invoices-tbody');
    const res = await fetch('/api/invoices/list?limit=100', { headers: { 'x-api-key': API_KEY } });
    if (res.status === 401) { sessionStorage.removeItem('zyntel_invoice_api_key'); window.location.href = B + '/login'; return; }
    const data = await res.json();
    const invoices = data.invoices ?? [];

    if (invoices.length === 0) {
      tbody!.innerHTML = `<tr><td colspan="6"><div class="admin-empty"><div class="admin-empty-icon">📄</div><div class="admin-empty-title">No invoices</div><div class="admin-empty-desc">Create your first invoice.</div><a href="${B}/invoices/new" class="admin-btn admin-btn-primary">New invoice</a></div></td></tr>`;
    } else {
      tbody!.innerHTML = invoices.map((inv: { id: number; invoice_number: string; client_name: string; total: number; currency: string; status: string; created_at: string }) => {
        const statusClass = `admin-badge-${inv.status}`;
        const date = new Date(inv.created_at).toLocaleDateString();
        const amount = `${inv.currency || ''} ${Number(inv.total).toLocaleString()}`.trim();
        return `<tr>
          <td><a href="${B}/invoices/${inv.id}" class="admin-invoice-link">${inv.invoice_number}</a></td>
          <td>${inv.client_name}</td>
          <td>${amount}</td>
          <td><span class="admin-badge ${statusClass}">${inv.status}</span></td>
          <td>${date}</td>
          <td><div class="admin-actions-cell"><a href="/api/invoices/${inv.id}/pdf" target="_blank" class="admin-btn admin-btn-ghost">PDF</a><a href="${B}/invoices/${inv.id}" class="admin-btn admin-btn-ghost">View</a></div></td>
        </tr>`;
      }).join('');
    }
  }
  load();
</script>
