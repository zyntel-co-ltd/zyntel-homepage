---
import AdminLayout from '../../layouts/AdminLayout.astro';

export const prerender = false;
---
<AdminLayout title="Invoice">
  <header class="admin-header">
    <a href="/invoices" class="admin-btn admin-btn-ghost" style="margin-bottom: 1rem;">← Back to invoices</a>
    <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
      <div>
        <h1 class="admin-title" id="invoice-number">—</h1>
        <p class="admin-subtitle" id="invoice-client">—</p>
      </div>
      <div class="admin-actions-cell" id="actions-cell">
        <a href="#" id="pdf-link" class="admin-btn admin-btn-secondary" target="_blank" style="display: none;">Download PDF</a>
        <button type="button" class="admin-btn admin-btn-primary" id="send-invoice-btn" style="display: none;">Send invoice</button>
        <button type="button" class="admin-btn admin-btn-secondary" id="finalize-btn" style="display: none;">Finalize</button>
        <a href="#" id="edit-link" class="admin-btn admin-btn-secondary" style="display: none;">Edit</a>
        <button type="button" class="admin-btn admin-btn-primary" id="record-payment-btn">Record payment</button>
        <button type="button" class="admin-btn admin-btn-ghost" id="delete-invoice-btn" style="color: var(--admin-danger, #dc3545);">Delete</button>
        <button type="button" class="admin-btn admin-btn-primary" id="restore-invoice-btn" style="display: none;">Restore</button>
      </div>
    </div>
  </header>

  <div style="display: grid; grid-template-columns: 1fr 340px; gap: 2rem;" class="invoice-layout">
    <div class="admin-card">
      <div class="admin-card-header">
        <h2 class="admin-card-title">Invoice details</h2>
        <span class="admin-badge" id="status-badge">—</span>
      </div>
      <div style="padding: 1.5rem;">
        <div id="invoice-details"></div>
        <hr style="border: none; border-top: 1px solid var(--admin-border); margin: 1.5rem 0;" />
        <div id="invoice-items"></div>
        <div style="margin-top: 1.5rem; text-align: right;" id="invoice-totals"></div>
      </div>
    </div>

    <div>
      <div class="admin-card">
        <div class="admin-card-header">
          <h2 class="admin-card-title">Payments</h2>
        </div>
        <div style="padding: 1rem;" id="payments-list">
          <div class="admin-empty"><div class="admin-empty-icon">Loading...</div></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Record payment modal -->
  <div class="admin-modal-overlay" id="payment-modal" style="display: none;">
    <div class="admin-modal">
      <div class="admin-modal-header">
        <h3 class="admin-modal-title">Record payment</h3>
      </div>
      <form id="record-payment-form">
        <div class="admin-modal-body">
          <div class="admin-form-group">
            <label class="admin-form-label">Amount *</label>
            <input type="number" name="amount" class="admin-form-input" required min="0.01" step="0.01" placeholder="0.00" />
            <p class="invoice-meta" id="payment-remaining-hint" style="margin-top: 0.35rem; display: none;"></p>
          </div>
          <div class="admin-form-group">
            <label class="admin-form-label">Payment method</label>
            <select name="payment_method" class="admin-form-input">
              <option value="cash">Cash</option>
              <option value="bank_transfer">Bank transfer</option>
              <option value="mobile_money">Mobile money</option>
              <option value="flutterwave">Flutterwave</option>
              <option value="cheque">Cheque</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="admin-form-group">
            <label class="admin-form-label">Payment date</label>
            <input type="date" name="paid_at" class="admin-form-input" id="paid-at-input" />
          </div>
          <div class="admin-form-group">
            <label class="admin-form-label">Reference</label>
            <input type="text" name="reference" class="admin-form-input" placeholder="e.g. Cash received at office" />
          </div>
          <p class="admin-login-error" id="payment-error" style="display: none;"></p>
        </div>
        <div class="admin-modal-footer">
          <button type="button" class="admin-btn admin-btn-secondary" id="close-payment-modal">Cancel</button>
          <button type="submit" class="admin-btn admin-btn-primary" id="payment-submit-btn">Record payment</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Send invoice: edit client emails & pick recipient -->
  <div class="admin-modal-overlay" id="send-invoice-modal" style="display: none;">
    <div class="admin-modal" style="max-width: 440px;">
      <div class="admin-modal-header">
        <h3 class="admin-modal-title">Send invoice</h3>
      </div>
      <div class="admin-modal-body">
        <p class="invoice-meta" style="margin-bottom: 1rem;">Set contact emails (saved to the client when linked), choose where to send, then send.</p>
        <div class="admin-form-group">
          <label class="admin-form-label">Email 1 (primary)</label>
          <input type="email" class="admin-form-input" id="send-email-1" autocomplete="email" />
        </div>
        <div class="admin-form-group">
          <label class="admin-form-label">Email 2 (optional)</label>
          <input type="email" class="admin-form-input" id="send-email-2" autocomplete="email" placeholder="second@…" />
        </div>
        <div class="admin-form-group">
          <label class="admin-form-label">Send to</label>
          <select id="send-email-target" class="admin-form-input">
            <option value="0">Email 1</option>
            <option value="1">Email 2</option>
          </select>
        </div>
        <p class="admin-login-error" id="send-invoice-error" style="display: none;"></p>
      </div>
      <div class="admin-modal-footer">
        <button type="button" class="admin-btn admin-btn-secondary" id="close-send-modal">Cancel</button>
        <button type="button" class="admin-btn admin-btn-primary" id="confirm-send-invoice">Send</button>
      </div>
    </div>
  </div>

  <div id="admin-sent-toast" class="admin-sent-toast" role="status" aria-live="polite" hidden></div>
</AdminLayout>

<style>
  .invoice-layout { }
  @media (max-width: 900px) {
    .invoice-layout { grid-template-columns: 1fr; }
  }
  .invoice-meta { font-size: 0.9375rem; color: var(--admin-text-muted); }
  .invoice-meta p { margin-bottom: 0.25rem; }
  .payment-row { display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 0; border-bottom: 1px solid var(--admin-border); font-size: 0.9375rem; }
  .payment-row:last-child { border-bottom: none; }
  .admin-sent-toast {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 10000;
    max-width: min(22rem, calc(100vw - 2rem));
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-size: 0.9375rem;
    line-height: 1.4;
    color: var(--admin-text, #e2e8f0);
    background: var(--admin-card-bg, #1e293b);
    border: 1px solid var(--admin-success, #0d9488);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.35);
    opacity: 0;
    transform: translateY(0.5rem);
    pointer-events: none;
    transition: opacity 0.22s ease, transform 0.22s ease;
  }
  .admin-sent-toast.admin-sent-toast--visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const API_KEY = sessionStorage.getItem('zyntel_invoice_api_key');
  const B = '';
  if (!API_KEY) window.location.href = '/login';

  const headers = { 'x-api-key': API_KEY };
  const parts = document.location.pathname.split('/').filter(Boolean);
  const invoicesIdx = parts.indexOf('invoices');
  const id = invoicesIdx >= 0 && parts[invoicesIdx + 1] ? parts[invoicesIdx + 1] : null;
  if (!id || id === 'invoices') window.location.href = '/invoices';

  let invoice: Record<string, unknown> | null = null;
  let payments: Array<Record<string, unknown>> = [];
  let totalPaid = 0;
  let balance = 0;

  function formatMoney(n: number, currency: string) {
    return (currency ? `${currency} ` : '') + Number(n).toLocaleString('en-US', { minimumFractionDigits: 2 });
  }

  /** Remaining balance after payments already recorded (deposit / partial pay). */
  function computeRemaining(inv: { total: unknown }, paid: number): number {
    const t = Number(inv.total);
    if (Number.isNaN(t)) return 0;
    return Math.max(0, Math.round((t - paid) * 100) / 100);
  }

  let sentToastTimer: ReturnType<typeof setTimeout> | null = null;
  let sentToastHideTimer: ReturnType<typeof setTimeout> | null = null;
  function showSentNotification(message: string) {
    const el = document.getElementById('admin-sent-toast');
    if (!el) return;
    el.textContent = message;
    el.removeAttribute('hidden');
    requestAnimationFrame(() => el.classList.add('admin-sent-toast--visible'));
    if (sentToastTimer) clearTimeout(sentToastTimer);
    if (sentToastHideTimer) clearTimeout(sentToastHideTimer);
    sentToastTimer = window.setTimeout(() => {
      el.classList.remove('admin-sent-toast--visible');
      sentToastHideTimer = window.setTimeout(() => {
        el.setAttribute('hidden', '');
        el.textContent = '';
      }, 240);
    }, 4200);
  }

  function statusClass(s: string) {
    return `admin-badge admin-badge-${s}`;
  }

  function renderInvoice() {
    if (!invoice) return;
    const inv = invoice as {
      invoice_number: string;
      client_name: string;
      client_email: string;
      client_phone?: string;
      client_address?: string;
      items: Array<{ description: string; quantity: number; unitPrice: number; amount: number }>;
      subtotal: number;
      tax_rate: number;
      tax_amount: number;
      total: number;
      currency: string;
      status: string;
      due_date?: string;
      notes?: string;
      created_at: string;
    };

    document.getElementById('invoice-number')!.textContent = inv.invoice_number;
    document.getElementById('invoice-client')!.textContent = inv.client_email ? `${inv.client_name} · ${inv.client_email}` : inv.client_name;
    const pdfLink = document.getElementById('pdf-link') as HTMLAnchorElement;
    pdfLink.href = `/api/invoices/${id}/pdf`;
    pdfLink.style.display = inv.status === 'draft' ? 'none' : 'inline-flex';
    (document.getElementById('send-invoice-btn') as HTMLButtonElement).style.display = inv.status === 'draft' ? 'none' : 'inline-flex';
    (document.getElementById('finalize-btn') as HTMLButtonElement).style.display = inv.status === 'draft' ? 'inline-flex' : 'none';
    (document.getElementById('edit-link') as HTMLAnchorElement).href = `/invoices/${id}/edit`;
    const isDeleted = !!(invoice as { deleted_at?: string }).deleted_at;
    (document.getElementById('delete-invoice-btn') as HTMLElement).style.display = isDeleted ? 'none' : 'inline-flex';
    (document.getElementById('record-payment-btn') as HTMLElement).style.display = isDeleted ? 'none' : 'inline-flex';
    (document.getElementById('finalize-btn') as HTMLElement).style.display = isDeleted ? 'none' : (inv.status === 'draft' ? 'inline-flex' : 'none');
    (document.getElementById('send-invoice-btn') as HTMLElement).style.display = isDeleted ? 'none' : (inv.status === 'draft' ? 'none' : 'inline-flex');
    (document.getElementById('edit-link') as HTMLElement).style.display = isDeleted ? 'none' : (inv.status === 'draft' ? 'inline-flex' : 'none');
    (document.getElementById('restore-invoice-btn') as HTMLElement).style.display = isDeleted ? 'inline-flex' : 'none';
    const displayStatus = totalPaid >= inv.total ? 'paid' : totalPaid > 0 ? 'partial' : inv.status;
    document.getElementById('status-badge')!.className = statusClass(displayStatus);
    document.getElementById('status-badge')!.textContent = displayStatus;

    const invAny = inv as { invoice_date?: string; invoice_type?: string };
    document.getElementById('invoice-details')!.innerHTML = `
      <div class="invoice-meta">
        <p><strong>Client:</strong> ${inv.client_name}</p>
        ${inv.client_email ? `<p><strong>Email:</strong> ${inv.client_email}</p>` : ''}
        ${inv.client_phone ? `<p><strong>Phone:</strong> ${inv.client_phone}</p>` : ''}
        ${inv.client_address ? `<p><strong>Address:</strong> ${inv.client_address}</p>` : ''}
        <p><strong>Invoice date:</strong> ${(invAny.invoice_date ? new Date(invAny.invoice_date) : new Date(inv.created_at)).toLocaleDateString()}</p>
        ${inv.due_date ? `<p><strong>Due:</strong> ${new Date(inv.due_date).toLocaleDateString()}</p>` : ''}
        ${invAny.invoice_type ? `<p><strong>Type:</strong> ${invAny.invoice_type}</p>` : ''}
      </div>
    `;

    const items = Array.isArray(inv.items) ? inv.items : [];
    document.getElementById('invoice-items')!.innerHTML = `
      <table class="admin-table">
        <thead><tr><th>Description</th><th>Qty</th><th>Unit price</th><th>Amount</th></tr></thead>
        <tbody>
          ${items.map((i: { description: string; quantity: number; unitPrice: number; amount: number }) => `
            <tr>
              <td>${i.description}</td>
              <td>${i.quantity}</td>
              <td>${formatMoney(i.unitPrice, inv.currency)}</td>
              <td>${formatMoney(i.amount, inv.currency)}</td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    `;

    document.getElementById('invoice-totals')!.innerHTML = `
      <p style="margin-bottom: 0.25rem;"><strong>Subtotal:</strong> ${formatMoney(inv.subtotal, inv.currency)}</p>
      ${inv.tax_rate ? `<p style="margin-bottom: 0.25rem;"><strong>Tax (${inv.tax_rate}%):</strong> ${formatMoney(inv.tax_amount, inv.currency)}</p>` : ''}
      <p style="font-size: 1.125rem; font-weight: 700;"><strong>Total:</strong> ${formatMoney(inv.total, inv.currency)}</p>
      ${totalPaid > 0 ? `
        <p style="margin-top: 0.75rem; margin-bottom: 0.25rem; color: var(--admin-success);"><strong>Amount paid:</strong> ${formatMoney(totalPaid, inv.currency)}</p>
        <p style="font-size: 1rem; font-weight: 600;"><strong>Balance due:</strong> ${formatMoney(balance, inv.currency)}</p>
      ` : ''}
    `;
  }

  function renderPayments() {
    const el = document.getElementById('payments-list')!;
    if (payments.length === 0) {
      el.innerHTML = '<div class="admin-empty"><div class="admin-empty-icon">No payments yet</div><div class="admin-empty-desc">Record a payment when the client pays.</div></div>';
    } else {
      const inv = invoice as { currency: string };
      el.innerHTML = payments.map((p: Record<string, unknown>) => `
        <div class="payment-row">
          <div>
            <strong>${formatMoney(Number(p.amount), inv?.currency || '')}</strong>
            <span style="color: var(--admin-text-muted); font-size: 0.8125rem;"> · ${String(p.payment_method).replace('_', ' ')}</span>
          </div>
          <div>
            <a href="/api/receipts/${p.id}/pdf" target="_blank" class="admin-btn admin-btn-ghost" style="padding: 0.25rem 0.5rem; font-size: 0.8125rem;">Receipt</a>
            <button type="button" class="admin-btn admin-btn-ghost send-receipt-btn" data-payment-id="${p.id}" style="padding: 0.25rem 0.5rem; font-size: 0.8125rem;">Email</button>
          </div>
        </div>
      `).join('');
      el.querySelectorAll('.send-receipt-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const pid = (btn as HTMLElement).dataset.paymentId;
          (btn as HTMLButtonElement).disabled = true;
          (btn as HTMLButtonElement).textContent = 'Sending...';
          try {
            const res = await fetch(`/api/receipts/${pid}/send`, { method: 'POST', headers });
            if (res.ok) {
              (btn as HTMLButtonElement).textContent = 'Sent';
              const ce = (invoice as { client_email?: string } | null)?.client_email?.trim();
              showSentNotification(ce ? `Receipt sent to ${ce}.` : 'Receipt email sent.');
              window.setTimeout(() => {
                (btn as HTMLButtonElement).textContent = 'Email';
              }, 3200);
            } else (btn as HTMLButtonElement).textContent = 'Failed';
          } catch {
            (btn as HTMLButtonElement).textContent = 'Failed';
          }
        });
      });
    }
  }

  async function loadInvoice() {
    const res = await fetch(`/api/invoices/${id}`, { headers });
    if (res.status === 401) { sessionStorage.removeItem('zyntel_invoice_api_key'); window.location.href = '/login'; return; }
    if (!res.ok) { document.getElementById('payments-list')!.innerHTML = '<div class="admin-empty"><div class="admin-empty-desc">Invoice not found</div></div>'; return; }
    const data = await res.json();
    invoice = data.invoice;
    payments = data.payments ?? [];
    let tp = Number(data.total_paid);
    if (Number.isNaN(tp)) {
      tp = payments.reduce((s: number, p: { amount: unknown }) => s + Number(p.amount), 0);
    }
    totalPaid = tp;
    const invTotal = Number((invoice as { total?: unknown })?.total);
    let bal = data.balance != null ? Number(data.balance) : NaN;
    if (Number.isNaN(bal)) bal = computeRemaining({ total: invTotal }, totalPaid);
    balance = bal;
    renderInvoice();
    renderPayments();
  }

  // Finalize
  document.getElementById('finalize-btn')?.addEventListener('click', async () => {
    if (!confirm('Finalize this invoice? It will become read-only and you can then download or send it.')) return;
    const btn = document.getElementById('finalize-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Finalizing...';
    try {
      const res = await fetch(`/api/invoices/${id}/finalize`, { method: 'POST', headers });
      const text = await res.text();
      let data: { error?: string; invoice?: unknown } = {};
      try { data = JSON.parse(text); } catch { data = { error: text.slice(0, 120) || `HTTP ${res.status}` }; }
      if (res.ok) {
        invoice = data.invoice as Record<string, unknown>;
        renderInvoice();
        renderPayments();
      } else alert(data.error || `Failed (${res.status})`);
    } catch (e) { alert('Failed: ' + (e instanceof Error ? e.message : 'Unknown error')); }
    btn.disabled = false;
    btn.textContent = 'Finalize';
  });

  const sendModal = document.getElementById('send-invoice-modal') as HTMLElement;
  const sendEmail1 = document.getElementById('send-email-1') as HTMLInputElement;
  const sendEmail2 = document.getElementById('send-email-2') as HTMLInputElement;
  const sendTarget = document.getElementById('send-email-target') as HTMLSelectElement;
  const sendErr = document.getElementById('send-invoice-error') as HTMLElement;

  function syncSendTargetOptions() {
    const has2 = !!sendEmail2.value.trim();
    sendTarget.options[1]!.disabled = !has2;
    if (!has2 && sendTarget.value === '1') sendTarget.value = '0';
  }

  sendEmail2?.addEventListener('input', syncSendTargetOptions);

  async function openSendInvoiceModal() {
    sendErr.style.display = 'none';
    let emails: string[] = [];
    const inv = invoice as { client_id?: number | null; client_email?: string | null } | null;
    if (inv?.client_id) {
      try {
        const r = await fetch(`/api/clients/${inv.client_id}`, { headers });
        if (r.ok) {
          const d = await r.json();
          const raw = d.client?.emails;
          if (Array.isArray(raw) && raw.length) emails = raw.map((e: string) => String(e).trim()).filter(Boolean);
        }
      } catch {
        /* use invoice snapshot */
      }
    }
    if (!emails.length && inv?.client_email?.trim()) emails = [inv.client_email.trim()];
    sendEmail1.value = emails[0] ?? '';
    sendEmail2.value = emails[1] ?? '';
    syncSendTargetOptions();
    sendModal.style.display = 'flex';
  }

  document.getElementById('close-send-modal')?.addEventListener('click', () => {
    sendModal.style.display = 'none';
  });
  sendModal.addEventListener('click', (e) => {
    if (e.target === sendModal) sendModal.style.display = 'none';
  });

  // Send invoice (opens modal first)
  document.getElementById('send-invoice-btn')?.addEventListener('click', () => {
    void openSendInvoiceModal();
  });

  document.getElementById('confirm-send-invoice')?.addEventListener('click', async () => {
    const btn = document.getElementById('confirm-send-invoice') as HTMLButtonElement;
    sendErr.style.display = 'none';
    const e1 = sendEmail1.value.trim();
    const e2 = sendEmail2.value.trim();
    const list = [e1, e2].filter(Boolean);
    if (!list.length) {
      sendErr.textContent = 'Enter at least one email.';
      sendErr.style.display = 'block';
      return;
    }
    const useSecond = sendTarget.value === '1' && !!e2;
    const to = useSecond ? e2 : list[0];
    btn.disabled = true;
    btn.textContent = 'Scheduled...';
    sendModal.style.display = 'none';
    let timer: ReturnType<typeof setTimeout> | null = null;
    showSentNotification(`Scheduled: sending in 10s to ${to}.`);
    timer = window.setTimeout(async () => {
      timer = null;
      try {
        const res = await fetch(`/api/invoices/${id}/send`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', ...headers },
          body: JSON.stringify({ to, client_emails: list }),
        });
        const text = await res.text();
        let data: { error?: string; ok?: boolean; invoice?: { client_email?: string | null } } = {};
        try {
          data = JSON.parse(text);
        } catch {
          data = { error: text.slice(0, 120) || `HTTP ${res.status}` };
        }
        if (res.ok) {
          if (data.invoice) invoice = { ...invoice, ...data.invoice } as Record<string, unknown>;
          showSentNotification(`Invoice sent to ${to}.`);
          renderInvoice();
        } else {
          showSentNotification(data.error || `Failed (${res.status})`);
        }
      } catch (e) {
        showSentNotification(e instanceof Error ? e.message : 'Send failed');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Send';
      }
    }, 10000);
  });

  // Record payment modal
  const modal = document.getElementById('payment-modal')!;
  const form = document.getElementById('record-payment-form')!;
  const amountInput = form.querySelector('[name="amount"]') as HTMLInputElement;

  document.getElementById('record-payment-btn')?.addEventListener('click', () => {
    const hint = document.getElementById('payment-remaining-hint') as HTMLElement;
    if (invoice) {
      const inv = invoice as { total: unknown; currency?: string };
      const paid = Number(totalPaid);
      const remaining = computeRemaining(inv, paid);
      if (remaining > 0) {
        amountInput.value = String(remaining);
        hint.style.display = 'block';
        hint.textContent = `Outstanding (invoice total minus payments recorded): ${formatMoney(remaining, inv.currency ?? '')}`;
      } else {
        amountInput.value = '';
        hint.style.display = 'block';
        hint.textContent = 'Balance is fully paid. Enter an amount only if you are correcting a mistake.';
      }
    } else {
      amountInput.value = '';
      hint.style.display = 'none';
    }
    (form.querySelector('[name="reference"]') as HTMLInputElement).value = '';
    const paidAtInput = document.getElementById('paid-at-input') as HTMLInputElement;
    if (paidAtInput) paidAtInput.value = new Date().toISOString().slice(0, 10);
    (document.getElementById('payment-error') as HTMLElement).style.display = 'none';
    modal.style.display = 'flex';
  });

  document.getElementById('close-payment-modal')?.addEventListener('click', () => {
    modal.style.display = 'none';
  });

  modal.addEventListener('click', (e) => {
    if (e.target === modal) modal.style.display = 'none';
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const errorEl = document.getElementById('payment-error') as HTMLElement;
    const submitBtn = document.getElementById('payment-submit-btn') as HTMLButtonElement;
    errorEl.style.display = 'none';
    submitBtn.disabled = true;
    submitBtn.textContent = 'Recording...';

    try {
      const res = await fetch(`/api/invoices/${id}/record-payment`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', ...headers },
        body: JSON.stringify({
          amount: Number(amountInput.value),
          payment_method: (form.querySelector('[name="payment_method"]') as HTMLSelectElement).value,
          paid_at: (form.querySelector('[name="paid_at"]') as HTMLInputElement)?.value || undefined,
          reference: (form.querySelector('[name="reference"]') as HTMLInputElement).value.trim() || undefined,
        }),
      });
      const data = await res.json();
      if (res.ok) {
        modal.style.display = 'none';
        payments.push(data.payment);
        invoice = data.invoice ? { ...invoice, ...data.invoice } : invoice;
        totalPaid += Number(data.payment?.amount ?? 0);
        balance = Math.max(0, ((invoice?.total as number) ?? 0) - totalPaid);
        window.__adminClearUnsavedChanges?.();
        renderInvoice();
        renderPayments();
      } else {
        errorEl.textContent = data.error || 'Failed';
        errorEl.style.display = 'block';
      }
    } catch {
      errorEl.textContent = 'Connection failed';
      errorEl.style.display = 'block';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Record payment';
    }
  });

  // Restore from trash
  document.getElementById('restore-invoice-btn')?.addEventListener('click', async () => {
    if (!confirm('Restore this invoice?')) return;
    const btn = document.getElementById('restore-invoice-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Restoring...';
    try {
      const res = await fetch(`/api/invoices/${id}/restore`, { method: 'POST', headers });
      const data = await res.json();
      if (res.ok) window.location.href = '/invoices';
      else alert(data.error || 'Failed to restore');
    } catch { alert('Connection failed'); }
    finally { btn.disabled = false; btn.textContent = 'Restore'; }
  });

  // Delete (move to trash)
  document.getElementById('delete-invoice-btn')?.addEventListener('click', async () => {
    if (!confirm(`Move invoice ${invoice?.invoice_number} to trash?`)) return;
    const btn = document.getElementById('delete-invoice-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Deleting...';
    try {
      const res = await fetch(`/api/invoices/${id}`, { method: 'DELETE', headers });
      const data = await res.json();
      if (res.ok) {
        window.location.href = '/invoices';
      } else {
        alert(data.error || 'Failed to delete');
      }
    } catch (e) {
      alert('Connection failed');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Delete';
    }
  });

  loadInvoice();
</script>
