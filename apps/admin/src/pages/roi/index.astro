---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAllServiceClients } from '../../lib/maintenance.ts';
import { listROIMetricDefinitions } from '../../lib/roi-metrics.ts';

const clients = await getAllServiceClients();
const defs = await listROIMetricDefinitions();
---
<AdminLayout title="ROI Dashboard">
  <header class="admin-header" style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap;">
    <div>
      <h1 class="admin-title">ROI Dashboard</h1>
      <p class="admin-subtitle">Track value created per product over time. Baseline is the first snapshot; current is the latest snapshot for each metric.</p>
    </div>
    <button class="admin-btn admin-btn-secondary" id="btn-add-metric" type="button">+ Add metric key</button>
  </header>

  <div class="admin-card" style="padding:14px 16px;">
    <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
      <label style="font-size:12px;font-weight:700;color:#374151;">Metric</label>
      <select id="metric-select" class="admin-form-input" style="max-width:420px;">
        {defs.length
          ? defs.map((d) => <option value={d.key}>{d.label} ({d.key})</option>)
          : <option value="revenue_ugx">Revenue tracked (revenue_ugx)</option>}
      </select>
      <span style="font-size:12px;color:#6b7280">Tip: use different metric keys for different products. Keep units consistent.</span>
    </div>
  </div>

  <div class="admin-card">
    <div class="admin-table-wrap">
      <table class="admin-table" id="roi-table">
        <thead>
          <tr>
            <th>Client</th>
            <th>Product</th>
            <th>Baseline</th>
            <th>Current</th>
            <th>Change</th>
            <th>Last updated</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="roi-tbody">
          {clients.map((c) => (
            <tr data-service-client-id={c.id} data-name={c.name} data-product={c.productName}>
              <td><strong>{c.name}</strong></td>
              <td>{c.productName}</td>
              <td class="cell-baseline">—</td>
              <td class="cell-current">—</td>
              <td class="cell-change">—</td>
              <td class="cell-updated">—</td>
              <td><a class="admin-btn admin-btn-ghost" style="padding:.25rem .5rem;font-size:.85rem;" href={`/maintenance?client=${c.id}`}>Open</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <div id="modal-add-metric" class="preview-modal-overlay" style="display:none">
    <div class="modal">
      <h3>Add metric key</h3>
      <form id="form-add-metric" class="grid-form">
        <div class="full"><label>Key</label><input id="m-key" class="admin-form-input" placeholder="e.g. revenue_ugx, mrr_usd, uptime_pct" required /></div>
        <div class="full"><label>Label</label><input id="m-label" class="admin-form-input" placeholder="Human-friendly name" required /></div>
        <div><label>Unit (optional)</label><input id="m-unit" class="admin-form-input" placeholder="UGX / USD / %" /></div>
        <div>
          <label>Direction</label>
          <select id="m-direction" class="admin-form-input">
            <option value="higher_is_better">Higher is better</option>
            <option value="lower_is_better">Lower is better</option>
            <option value="neutral">Neutral</option>
          </select>
        </div>
        <div>
          <label>Format</label>
          <select id="m-format" class="admin-form-input">
            <option value="number">Number</option>
            <option value="currency">Currency</option>
            <option value="percent">Percent</option>
            <option value="duration">Duration</option>
          </select>
        </div>
        <div class="modal-actions full">
          <button type="button" class="admin-btn admin-btn-secondary" data-close="modal-add-metric">Cancel</button>
          <button class="admin-btn admin-btn-primary">Save</button>
        </div>
      </form>
    </div>
  </div>
  <div id="toast-root"></div>

  <style>
    .preview-modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.35);align-items:center;justify-content:center;z-index:1200;padding:16px}
    .modal{width:min(720px,100%);max-height:90vh;overflow:auto;background:#fff;border-radius:12px;padding:18px}
    .grid-form{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .grid-form .full{grid-column:1/-1}
    .modal-actions{display:flex;justify-content:flex-end;gap:8px;grid-column:1/-1;margin-top:6px}
    #toast-root{position:fixed;right:16px;bottom:16px;display:flex;flex-direction:column;gap:8px;z-index:2000}
    .toast{background:#111;color:#fff;border-radius:8px;padding:10px 12px;font-size:12px;min-width:260px}
    .toast.error{background:#7f1d1d}
    .pill{display:inline-block;border-radius:999px;padding:2px 8px;font-size:11px;font-weight:700}
    .pill-good{background:rgba(22,163,74,.15);color:#166534}
    .pill-bad{background:rgba(239,68,68,.15);color:#b91c1c}
  </style>

  <script>
    function showToast(message,type='success'){
      const toast=document.createElement('div'); toast.className=`toast ${type==='error'?'error':''}`;
      toast.textContent=message;
      document.getElementById('toast-root').appendChild(toast);
      setTimeout(()=>toast.remove(),5000);
    }
    function showModal(id){var el=document.getElementById(id); if(el) el.style.display='flex';}
    function closeModal(id){var el=document.getElementById(id); if(el) el.style.display='none';}
    document.addEventListener('click',(e)=>{const c=e.target.closest('[data-close]'); if(c) closeModal(c.dataset.close);});
    document.querySelectorAll('.preview-modal-overlay').forEach(function(overlay){
      overlay.addEventListener('click', function(e){
        if(e.target===overlay) closeModal(overlay.id);
      });
    });

    async function loadMetric(key){
      const rows=[...document.querySelectorAll('tr[data-service-client-id]')];
      await Promise.all(rows.map(async (row)=>{
        const id=row.dataset.serviceClientId;
        const res=await fetch(`/api/roi/comparison?serviceClientId=${encodeURIComponent(id)}`);
        const data=await res.json().catch(()=>({}));
        const v=data?.[key];
        const baseline=v?.baseline ?? null;
        const current=v?.current ?? null;
        row.querySelector('.cell-baseline').textContent = baseline==null?'—':Number(baseline).toLocaleString();
        row.querySelector('.cell-current').textContent = current==null?'—':Number(current).toLocaleString();
        if(baseline!=null && current!=null && baseline!==0){
          const pct=((current-baseline)/Math.abs(baseline))*100;
          const improved = pct>=0;
          row.querySelector('.cell-change').innerHTML = `<span class="pill ${improved?'pill-good':'pill-bad'}">${improved?'▲':'▼'} ${Math.abs(pct).toFixed(1)}%</span>`;
        } else {
          row.querySelector('.cell-change').textContent='—';
        }
        row.querySelector('.cell-updated').textContent = '—';
      }));
    }

    document.getElementById('metric-select').addEventListener('change',(e)=>loadMetric(e.target.value));
    loadMetric(document.getElementById('metric-select').value);

    document.getElementById('btn-add-metric').addEventListener('click',()=>showModal('modal-add-metric'));
    document.getElementById('form-add-metric').addEventListener('submit', async (e)=>{
      e.preventDefault();
      const payload={
        key: document.getElementById('m-key').value.trim(),
        label: document.getElementById('m-label').value.trim(),
        unit: document.getElementById('m-unit').value.trim() || null,
        direction: document.getElementById('m-direction').value,
        format: document.getElementById('m-format').value,
      };
      const r=await fetch('/api/roi/definitions',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
      const d=await r.json().catch(()=>({}));
      if(!r.ok){showToast(d.error||'Failed to save','error');return;}
      closeModal('modal-add-metric');
      location.reload();
    });
  </script>
</AdminLayout>

