---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import LogosMarquee from '../components/LogosMarquee.astro';
import StatsBar from '../components/StatsBar.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import ParticleHero from '../components/ParticleHero.astro';
import HeroWireframe from '../components/HeroWireframe.astro';
import PaymentForm from '../components/PaymentForm.astro';
import ContactForm from '../components/ContactForm.astro';
import { getProducts, getServices } from '../lib/sanity';

const faqItems = [
  { q: 'What is included in the free trial?', a: 'The 14-day free trial gives you full access to the Professional plan — all three product modules, advanced analytics, and API access — with no credit card required.' },
  { q: 'How does Zyntel handle data security?', a: 'All data is encrypted at rest (AES-256) and in transit (TLS 1.3). We are SOC 2 Type II certified and fully GDPR-compliant, with role-based access control on every account.' },
  { q: 'Can I integrate Zyntel with my existing systems?', a: 'Yes. Zyntel provides a comprehensive REST API, webhooks, and pre-built connectors for popular ERP, CRM, and BI tools. Our team can assist with custom integrations on Enterprise plans.' },
  { q: 'What support options are available?', a: 'Starter plans include email support. Professional plans add priority ticket queues. Enterprise clients receive a dedicated account manager and optional on-site implementation support.' },
];

const sanityProducts = await getProducts();
const FALLBACK = [
  { name: 'Zyntel Forms', slug: { current: 'zyntel-forms' }, description: 'Digital form builder and data collection platform for replacing paper workflows. Create, deploy, and manage forms with automated routing and structured data capture.', icon: '📋' },
  { name: 'Zyntel Dashboard & Tracker', slug: { current: 'dashboard' }, description: 'Real-time operational visibility with sample journey tracking, performance analytics, and automated notifications.', icon: '◐' },
  { name: 'Kanta', slug: { current: 'kanta' }, description: 'Equipment inventory management system for tracking assets, maintenance schedules, and utilization across facilities.', icon: '📦' },
  { name: 'Property Management', slug: { current: 'property-management' }, description: 'End-to-end property and facility management for portfolios and estates. Lease tracking, maintenance workflows, tenant communications, and reporting.', icon: '🏢' },
  { name: 'Laboratory Quality Management', slug: { current: 'laboratory-quality-management' }, description: 'Lab quality management for accredited laboratories. QC workflows, audits, compliance documentation, and traceability for diagnostics and testing.', icon: '🔬' },
];
const homeProducts = sanityProducts.length > 0 ? sanityProducts : FALLBACK;

const features = [
  { icon: '◉', title: 'Real-Time Analytics', desc: 'Advanced insights with machine learning algorithms and predictive analytics for data-driven decision making.' },
  { icon: '⚡', title: 'High-Performance Processing', desc: 'Process millions of data points in real-time with optimized infrastructure and scalable architecture.' },
  { icon: '🛡', title: 'Enterprise Security', desc: 'Military-grade security with full compliance, data protection, and role-based access control.' },
  { icon: '🔗', title: 'Seamless Integration', desc: 'Connect with existing systems and workflows through robust APIs and data pipelines.' },
];


const sanityServices = await getServices();
const FALLBACK_SERVICES = [
  { title: 'Implementation & Onboarding', desc: 'End-to-end setup of Zyntel products with data import, configuration, and go-live support.' },
  { title: 'Custom Integration', desc: 'Connect Zyntel to your ERP, CRM, and BI tools via our API and pre-built connectors.' },
  { title: 'Training & Adoption', desc: 'Onboarding sessions and training programs so your team gets the most from the platform.' },
  { title: 'Dedicated Support', desc: 'Priority support and dedicated account managers for Enterprise plans.' },
  { title: 'Data Migration', desc: 'Secure migration of existing data into Zyntel with validation and reconciliation.' },
  { title: 'API & Integration Support', desc: 'Technical assistance for custom integrations and webhook setup.' },
];
const services = sanityServices.length > 0
  ? sanityServices.map(s => ({ title: s.title, desc: s.description || '' }))
  : FALLBACK_SERVICES;

const purchaseProducts = sanityProducts.length > 0
  ? sanityProducts.map(p => ({ id: p._id, name: p.name, amount: 500000 }))
  : FALLBACK.map(p => ({ id: p.slug.current, name: p.name, amount: 500000 }));
---
<BaseLayout title="Enterprise Digital Solutions" description="Transform your operations with Zyntel's comprehensive digital solutions platform. Streamline workflows, gain real-time insights, and drive operational excellence.">
  <Nav />
  <main>
    <!-- Hero -->
    <section class="hero">
      <ParticleHero />
      <HeroWireframe />
      <div class="hero-noise"></div>
      <div class="hero-grid"></div>
      <div class="hero-bg"></div>
      <div class="hero-bg-animated" aria-hidden="true"></div>
      <div class="container hero-inner">
        <div class="hero-content">
          <p class="hero-badge hero-anim" data-delay="0.2">Measured Managed</p>
          <h1 class="hero-title hero-anim" data-delay="0.35">Transform your operations with <span class="hero-hl">enterprise</span> digital solutions</h1>
          <p class="hero-desc hero-anim" data-delay="0.5">Streamline workflows, gain real-time insights, and drive operational excellence across your organization.</p>
          <div class="hero-actions hero-anim" data-delay="0.65">
            <a href="/#products" class="btn btn-primary">Start Free Trial</a>
            <a href="/#features" class="btn btn-secondary">View Capabilities</a>
          </div>
        </div>
        <div class="hero-visual hero-anim hero-anim-left" data-delay="0.5">
          <div class="mini-card mini-card-tl">
            <span class="mini-label">Uptime SLA</span>
            <span class="mini-val up">99.9%</span>
          </div>
          <div class="hero-dashboard-card">
            <div class="dc-header">
              <span class="dc-title">Operations Overview</span>
              <span class="dc-badge">● Live</span>
            </div>
            <div class="dc-stats">
              <div class="dc-stat"><span class="dc-stat-val">50+</span><span class="dc-stat-lbl">Facilities</span></div>
              <div class="dc-stat"><span class="dc-stat-val">30%</span><span class="dc-stat-lbl">Cost Saved</span></div>
              <div class="dc-stat"><span class="dc-stat-val">48K</span><span class="dc-stat-lbl">Requests</span></div>
            </div>
            <div class="dc-chart">
              <div class="chart-bars">
                <div class="chart-bar" style="--h:40%"></div>
                <div class="chart-bar" style="--h:65%"></div>
                <div class="chart-bar" style="--h:50%"></div>
                <div class="chart-bar" style="--h:80%"></div>
                <div class="chart-bar" style="--h:55%"></div>
                <div class="chart-bar" style="--h:90%"></div>
                <div class="chart-bar" style="--h:70%"></div>
                <div class="chart-bar" style="--h:85%"></div>
                <div class="chart-bar" style="--h:60%"></div>
                <div class="chart-bar" style="--h:95%"></div>
                <div class="chart-bar" style="--h:75%"></div>
                <div class="chart-bar" style="--h:100%"></div>
              </div>
            </div>
          </div>
          <div class="mini-card mini-card-br">
            <span class="mini-label">Cost Reduction</span>
            <span class="mini-val gold">−30%</span>
          </div>
        </div>
      </div>
      <div class="hero-scroll-cue" aria-hidden="true">
        <span class="hero-scroll-label">Scroll</span>
        <span class="hero-scroll-line"></span>
      </div>
    </section>

    <LogosMarquee />

    <StatsBar />

    <!-- Features -->
    <section class="section features" id="features">
      <div class="container">
        <h2 class="section-title" data-reveal>Enterprise-Grade Capabilities</h2>
        <div class="features-grid">
          {features.map((f, i) => (
            <div class="feature-card" data-reveal data-delay={i}>
              <div class="feature-icon">{f.icon}</div>
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Our Products -->
    <section class="section section-alt" id="products">
      <div class="container">
        <h2 class="section-title" data-reveal>Our Products</h2>
        <p class="section-sub" data-reveal>Enterprise software solutions built for healthcare and operations excellence</p>
        <div class="product-cards">
          {homeProducts.map((p, i) => (
            <a href={`/products/${p.slug.current}`} class="product-card" data-reveal data-delay={i}>
              <span class="product-icon">{p.icon || '◈'}</span>
              <h3>{p.name}</h3>
              <p>{p.description || ''}</p>
              <span class="product-link">Learn more →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="section services-section" id="services">
      <div class="container">
        <h2 class="section-title" data-reveal>Implementation & Support</h2>
        <p class="section-sub" data-reveal>Get the most out of Zyntel with setup, training, and dedicated support</p>
        <div class="services-grid">
          {services.map((s, i) => (
            <div class="service-card" data-reveal data-delay={i}>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Purchase -->
    <section class="section section-alt" id="purchase">
      <div class="container">
        <h2 class="section-title" data-reveal>Purchase Desktop Apps</h2>
        <p class="section-sub" data-reveal>Get licenses for Zyntel enterprise software. Pay via Mobile Money, M-Pesa, or card.</p>
        <div class="purchase-grid">
          {purchaseProducts.map((p, i) => (
            <div class="purchase-card" data-reveal data-delay={i}>
              <h3>{p.name}</h3>
              <span class="price">License</span>
              <div class="purchase-pay">
                <PaymentForm productName={p.name} productId={p.id} suggestedAmount={p.amount} />
              </div>
            </div>
          ))}
        </div>
        <p class="purchase-cta" data-reveal>Enterprise or volume licensing? <a href="mailto:contact@zyntel.net" class="link">Request a quote</a></p>
      </div>
    </section>

    <!-- Vision / Stats copy -->
    <section class="section vision" id="vision">
      <div class="vision-bg"></div>
      <canvas id="vision-canvas" aria-hidden="true"></canvas>

      <!-- floating data pills -->
      <div class="vision-pill vision-pill-1" aria-hidden="true">
        <span class="pill-dot"></span>Data Processing
      </div>
      <div class="vision-pill vision-pill-2" aria-hidden="true">
        <span class="pill-dot pill-dot-green"></span>99.9% Uptime
      </div>
      <div class="vision-pill vision-pill-3" aria-hidden="true">
        <span class="pill-dot pill-dot-violet"></span>AI Analytics
      </div>

      <div class="container vision-inner">
        <h2 class="vision-caption" data-reveal>Enterprise Scale</h2>
        <h3 class="vision-title title-single-line" data-reveal data-delay="1">The Future of Digital <span class="hero-hl">Intelligence</span></h3>
        <p class="vision-body">Zyntel makes processing complex enterprise data as intuitive as exploring the cosmos. Our platform handles billions of data points each year for ambitious businesses of all sizes.</p>

        <!-- stat counters -->
        <div class="vision-stats" data-reveal>
          <div class="vision-stat">
            <span class="vision-stat-val" data-target="50">0</span><span class="vision-stat-suffix">+</span>
            <span class="vision-stat-lbl">Enterprise Facilities</span>
          </div>
          <div class="vision-stat">
            <span class="vision-stat-val" data-target="30">0</span><span class="vision-stat-suffix">%</span>
            <span class="vision-stat-lbl">Cost Reduction</span>
          </div>
          <div class="vision-stat">
            <span class="vision-stat-val" data-target="99">0</span><span class="vision-stat-suffix">.9%</span>
            <span class="vision-stat-lbl">Uptime SLA</span>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section faq-section section-light" id="faq">
      <div class="container faq-container">
        <h2 class="section-title" data-reveal>Your Questions, Answered</h2>
        <div class="faq-list">
          {faqItems.map((item, i) => (
            <div class="faq-item" data-reveal data-delay={i}>
              <button type="button" class="faq-q" aria-expanded="false" data-faq-trigger>
                <span>{item.q}</span>
                <span class="faq-icon" aria-hidden="true">+</span>
              </button>
              <div class="faq-a">
                <p>{item.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact CTA -->
    <section class="section contact-section section-light" id="contact">
      <div class="container contact-inner">
        <h2 class="section-title title-single-line" data-reveal>Ready to transform?</h2>
        <p class="section-sub" data-reveal>Start your free trial or talk to our team about Enterprise plans</p>
        <div class="contact-form-card" data-reveal>
          <ContactForm />
        </div>
      </div>
    </section>

    <!-- Bottom CTA / Newsletter -->
    <section class="section cta-section">
      <div class="container cta-inner">
        <h2 class="cta-title" data-reveal>Stay in the loop</h2>
        <p class="cta-desc" data-reveal>Get product updates and insights delivered to your inbox.</p>
        <div class="cta-form-wrap" data-reveal>
          <NewsletterSignup />
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  /* ─── helpers (character-level split, free SplitText alternative) ─── */
  function splitTextIntoSpans(el: HTMLElement, keepWords: string[] = []) {
    const text = el.textContent ?? '';
    const makeSpan = (c: string) =>
      `<span class="split-char" style="display:inline-block;overflow:hidden;vertical-align:bottom;">` +
      `<span class="split-inner" style="display:inline-block;">${c === ' ' ? '\u00A0' : c}</span></span>`;

    const segments = text.split(/([a-zA-Z]+)/g).filter(Boolean);
    let html = '';
    for (const seg of segments) {
      if (/^[a-zA-Z]+$/.test(seg) && keepWords.includes(seg)) {
        html += `<span class="no-break" style="white-space:nowrap;">` +
          seg.split('').map(c => makeSpan(c)).join('') + `</span>`;
      } else {
        html += seg.split('').map(c => makeSpan(c)).join('');
      }
    }
    el.innerHTML = html;
  }

  /* ─── main init ────────────────────────────────────── */
  document.addEventListener('DOMContentLoaded', () => {
    gsap.registerPlugin(ScrollTrigger);

    /* ── 1. Hero entrance ── */
    gsap.from('.hero-anim', {
      opacity: 0,
      y: 40,
      duration: 1,
      stagger: 0.12,
      ease: 'power3.out',
      delay: 0.2,
      immediateRender: false,
    });
    gsap.from('.hero-anim-left', {
      opacity: 0,
      x: 60,
      duration: 1.2,
      ease: 'power3.out',
      delay: 0.5,
      immediateRender: false,
    });

    /* ── 2. Hero parallax ── */
    const heroBg = document.querySelector('.hero-bg') as HTMLElement | null;
    if (heroBg) {
      gsap.to(heroBg, {
        scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 1 },
        y: 150,
        opacity: 0.3,
        ease: 'none',
      });
    }

    /* ── 3. Character-level split-text on section titles ── */
    document.querySelectorAll<HTMLElement>('.section-title, .vision-title').forEach(title => {
      /* vision-title has hero-hl span — skip split to preserve it */
      if (title.classList.contains('vision-title')) {
        gsap.from(title, {
          scrollTrigger: { trigger: title, start: 'top 90%' },
          opacity: 0,
          y: 28,
          duration: 0.9,
          ease: 'power3.out',
        });
        return;
      }
      const txt = title.textContent ?? '';
      const keepWords: string[] = txt.includes('transform') ? ['transform'] : [];
      splitTextIntoSpans(title, keepWords);
      gsap.from(title.querySelectorAll('.split-inner'), {
        scrollTrigger: { trigger: title, start: 'top 92%' },
        y: '110%',
        opacity: 0,
        duration: 0.65,
        stagger: 0.018,
        ease: 'power3.out',
      });
    });

    /* ── 4. Generic scroll reveals (skip titles + elements with dedicated animations) ── */
    document.querySelectorAll<HTMLElement>('[data-reveal]:not(.section-title):not(.vision-title):not(.feature-card):not(.service-card)').forEach(el => {
      const delay = parseInt(el.dataset.delay || '0', 10) * 0.08;
      gsap.from(el, {
        scrollTrigger: { trigger: el, start: 'top 90%', toggleActions: 'play none none none' },
        y: 40,
        opacity: 0,
        duration: 0.9,
        delay,
        ease: 'power3.out',
        immediateRender: false,
      });
    });

    /* ── 5. Clip-path stagger — feature cards ── */
    const featuresGrid = document.querySelector('.features-grid');
    if (featuresGrid) {
      gsap.from('.feature-card', {
        scrollTrigger: { trigger: featuresGrid, start: 'top 88%' },
        clipPath: 'inset(30px 30px 30px 30px round 20px)',
        opacity: 0,
        y: 30,
        stagger: 0.12,
        duration: 0.85,
        ease: 'power3.out',
        clearProps: 'clipPath',
        immediateRender: false,
      });
    }

    /* ── 6. Clip-path stagger — service cards ── */
    const servicesGrid = document.querySelector('.services-grid');
    if (servicesGrid) {
      gsap.from('.service-card', {
        scrollTrigger: { trigger: servicesGrid, start: 'top 88%' },
        clipPath: 'inset(30px 30px 30px 30px round 20px)',
        opacity: 0,
        scale: 0.96,
        stagger: { amount: 0.55, from: 'start' },
        duration: 0.75,
        ease: 'power3.out',
        clearProps: 'clipPath,scale',
        immediateRender: false,
      });
    }

    /* ── 7. Vision section — scrub parallax timeline ── */
    const visionEl = document.querySelector('.vision');
    if (visionEl) {
      const vTl = gsap.timeline({
        scrollTrigger: {
          trigger: visionEl,
          start: 'top 75%',
          end: 'bottom 30%',
          scrub: 1.5,
        },
      });
      vTl
        .from('.vision-caption', { opacity: 0, y: 28, scale: 0.88 }, 0)
        .from('.vision-body',    { opacity: 0, y: 18 },              0.3);
      gsap.to('.vision-bg', {
        scrollTrigger: { trigger: visionEl, start: 'top bottom', end: 'bottom top', scrub: 2 },
        scale: 1.6,
        opacity: 0.03,
        ease: 'none',
      });
    }

    /* ── 9. Magnetic buttons ── */
    document.querySelectorAll<HTMLElement>('.btn').forEach(btn => {
      btn.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width  / 2;
        const y = e.clientY - rect.top  - rect.height / 2;
        gsap.to(btn, { x: x * 0.28, y: y * 0.28, duration: 0.3, ease: 'power2.out', overwrite: 'auto' });
      });
      btn.addEventListener('mouseleave', () => {
        gsap.to(btn, { x: 0, y: 0, duration: 0.65, ease: 'elastic.out(1, 0.45)', overwrite: 'auto' });
      });
    });

    /* ── 10. 3D perspective tilt on cards ── */
    document.querySelectorAll<HTMLElement>('.feature-card, .service-card, .product-card').forEach(card => {
      card.classList.add('tilt-card');
      card.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const rx = ((y - rect.height / 2) / rect.height) * -10;
        const ry = ((x - rect.width  / 2) / rect.width)  *  10;
        gsap.to(card, {
          rotateX: rx,
          rotateY: ry,
          transformPerspective: 800,
          duration: 0.25,
          ease: 'power2.out',
          overwrite: 'auto',
        });
      });
      card.addEventListener('mouseleave', () => {
        gsap.to(card, { rotateX: 0, rotateY: 0, duration: 0.7, ease: 'power3.out', overwrite: 'auto' });
      });
    });

    ScrollTrigger.refresh();

    /* ── 11. Hero visual: Stripe-like 3D depth tilt ── */
    const heroEl     = document.querySelector<HTMLElement>('.hero');
    const heroVisual = document.querySelector<HTMLElement>('.hero-visual');
    const dashCard   = document.querySelector<HTMLElement>('.hero-dashboard-card');
    const miniTL     = document.querySelector<HTMLElement>('.mini-card-tl');
    const miniBR     = document.querySelector<HTMLElement>('.mini-card-br');

    if (heroEl && heroVisual) {
      const setRX = gsap.quickSetter(heroVisual, 'rotateX', 'deg') as (v: number) => void;
      const setRY = gsap.quickSetter(heroVisual, 'rotateY', 'deg') as (v: number) => void;
      gsap.set(heroVisual, { transformPerspective: 1200, transformStyle: 'preserve-3d' });

      let targetRX = 0, targetRY = 0;
      let currRX = 0, currRY = 0;

      heroEl.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = heroEl.getBoundingClientRect();
        const nx = (e.clientX - rect.left) / rect.width  - 0.5;
        const ny = (e.clientY - rect.top)  / rect.height - 0.5;
        targetRX = -ny * 10;
        targetRY =  nx * 10;

        /* mini-cards float at a higher depth — extra parallax x/y shift */
        if (miniTL) gsap.to(miniTL, { x: nx * -22, duration: 0.7, ease: 'power2.out', overwrite: 'auto' });
        if (miniBR) gsap.to(miniBR, { x: nx *  22, duration: 0.7, ease: 'power2.out', overwrite: 'auto' });
      });

      heroEl.addEventListener('mouseleave', () => {
        targetRX = 0;
        targetRY = 0;
        if (miniTL) gsap.to(miniTL, { x: 0, duration: 1.2, ease: 'elastic.out(1, 0.5)', overwrite: 'auto' });
        if (miniBR) gsap.to(miniBR, { x: 0, duration: 1.2, ease: 'elastic.out(1, 0.5)', overwrite: 'auto' });
      });

      /* smoothed RAF loop — lerp toward target */
      (function loop() {
        currRX += (targetRX - currRX) * 0.07;
        currRY += (targetRY - currRY) * 0.07;
        setRX(currRX);
        setRY(currRY);
        requestAnimationFrame(loop);
      })();
    }

    /* ── 12. Hero dashboard: count-up stat numbers ── */
    const statEls      = document.querySelectorAll<HTMLElement>('.dc-stat-val');
    const statEnds     = [50, 30, 48];
    const statSuffixes = ['+', '%', 'K'];
    statEls.forEach((el, i) => {
      const counter = { val: 0 };
      gsap.to(counter, {
        val: statEnds[i],
        duration: 1.8,
        delay: 1.6 + i * 0.18,
        ease: 'power2.out',
        onUpdate() { el.textContent = Math.floor(counter.val) + statSuffixes[i]; },
      });
    });

    /* ── 13. Hero chart: live-data bar animation ── */
    const chartBars = document.querySelectorAll<HTMLElement>('.chart-bar');
    if (chartBars.length) {
      const liveChart = () => {
        chartBars.forEach((bar, i) => {
          const h = (Math.random() * 65 + 25).toFixed(1) + '%';
          gsap.to(bar, { height: h, duration: 0.6 + Math.random() * 0.5, delay: i * 0.04, ease: 'power2.inOut' });
        });
      };
      /* first run after hero fades in */
      setTimeout(() => { liveChart(); setInterval(liveChart, 2800); }, 2200);
    }
  });

  /* ── Vision canvas: orbiting particles & rings ── */
  (function visionCanvas() {
    const canvas = document.getElementById('vision-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let W = 0, H = 0;
    function resize() {
      const rect = canvas!.parentElement!.getBoundingClientRect();
      W = canvas!.width  = rect.width;
      H = canvas!.height = rect.height;
    }
    resize();
    window.addEventListener('resize', resize);

    /* rings config */
    const rings = [
      { r: 220, speed: 0.00018, phase: 0,    opacity: 0.18, color: '#00f0ff', dashes: [8,14] },
      { r: 320, speed: -0.00012, phase: 1.2, opacity: 0.12, color: '#8b5cf6', dashes: [4,20] },
      { r: 160, speed: 0.00028, phase: 2.5,  opacity: 0.14, color: '#7de19a', dashes: [6,18] },
    ];

    /* orbiting dots */
    const dots: {ring:number; angle:number; speed:number; size:number; color:string; trail:{x:number;y:number}[]}[] = [];
    const dotCols = ['#00f0ff','#8b5cf6','#7de19a'];
    rings.forEach((ring, ri) => {
      for (let i = 0; i < 3; i++) {
        dots.push({
          ring: ri,
          angle: (Math.PI * 2 / 3) * i,
          speed: ring.speed * (1.4 + i * 0.3) * (ri % 2 === 0 ? 1 : -1),
          size: 3.5 + i * 0.8,
          color: dotCols[ri % dotCols.length],
          trail: [],
        });
      }
    });

    /* floating micro particles */
    const particles = Array.from({ length: 60 }, () => ({
      x: Math.random(),
      y: Math.random(),
      vx: (Math.random() - 0.5) * 0.0003,
      vy: (Math.random() - 0.5) * 0.0003,
      r: 0.8 + Math.random() * 1.4,
      alpha: 0.15 + Math.random() * 0.35,
      color: dotCols[Math.floor(Math.random() * dotCols.length)],
    }));

    let raf = 0;
    function draw(ts: number) {
      raf = requestAnimationFrame(draw);
      ctx!.clearRect(0, 0, W, H);

      const cx = W / 2, cy = H / 2;

      /* draw dashed ellipse rings */
      rings.forEach(ring => {
        ctx!.save();
        ctx!.strokeStyle = ring.color;
        ctx!.globalAlpha = ring.opacity;
        ctx!.lineWidth = 1;
        ctx!.setLineDash(ring.dashes);
        ctx!.lineDashOffset = -ts * ring.speed * 500;
        ctx!.beginPath();
        ctx!.ellipse(cx, cy, ring.r, ring.r * 0.32, ring.phase, 0, Math.PI * 2);
        ctx!.stroke();
        ctx!.restore();
      });

      /* draw orbiting dots with trail */
      dots.forEach(dot => {
        const ring = rings[dot.ring];
        dot.angle += dot.speed * 16;
        const ex = cx + Math.cos(dot.angle) * ring.r;
        const ey = cy + Math.sin(dot.angle) * ring.r * 0.32;
        dot.trail.push({ x: ex, y: ey });
        if (dot.trail.length > 14) dot.trail.shift();

        /* trail */
        dot.trail.forEach((pt, ti) => {
          const a = (ti / dot.trail.length) * 0.55;
          ctx!.beginPath();
          ctx!.arc(pt.x, pt.y, dot.size * (ti / dot.trail.length) * 0.7, 0, Math.PI * 2);
          ctx!.fillStyle = dot.color;
          ctx!.globalAlpha = a;
          ctx!.fill();
        });

        /* glow dot */
        const grd = ctx!.createRadialGradient(ex, ey, 0, ex, ey, dot.size * 3.5);
        grd.addColorStop(0, dot.color);
        grd.addColorStop(1, 'transparent');
        ctx!.globalAlpha = 0.9;
        ctx!.beginPath();
        ctx!.arc(ex, ey, dot.size * 3.5, 0, Math.PI * 2);
        ctx!.fillStyle = grd;
        ctx!.fill();

        ctx!.globalAlpha = 1;
        ctx!.beginPath();
        ctx!.arc(ex, ey, dot.size, 0, Math.PI * 2);
        ctx!.fillStyle = dot.color;
        ctx!.fill();
      });

      /* micro particles */
      particles.forEach(p => {
        p.x += p.vx; p.y += p.vy;
        if (p.x < 0) p.x = 1; if (p.x > 1) p.x = 0;
        if (p.y < 0) p.y = 1; if (p.y > 1) p.y = 0;
        ctx!.globalAlpha = p.alpha;
        ctx!.beginPath();
        ctx!.arc(p.x * W, p.y * H, p.r, 0, Math.PI * 2);
        ctx!.fillStyle = p.color;
        ctx!.fill();
      });

      ctx!.globalAlpha = 1;
    }
    requestAnimationFrame(draw);

    /* pause when section out of view */
    const section = document.getElementById('vision');
    if (section) {
      const io = new IntersectionObserver(([e]) => {
        if (e.isIntersecting) { if (!raf) requestAnimationFrame(draw); }
        else { cancelAnimationFrame(raf); raf = 0; }
      }, { threshold: 0.1 });
      io.observe(section);
    }
  })();

  /* ── Vision stats: count-up on scroll ── */
  (function visionCountUp() {
    const statsWrap = document.querySelector('.vision-stats');
    if (!statsWrap) return;
    let ran = false;
    const io = new IntersectionObserver(([e]) => {
      if (!e.isIntersecting || ran) return;
      ran = true;
      document.querySelectorAll<HTMLElement>('.vision-stat-val').forEach(el => {
        const end = parseInt(el.dataset.target ?? '0', 10);
        const counter = { val: 0 };
        gsap.to(counter, {
          val: end,
          duration: 2,
          ease: 'power2.out',
          onUpdate() { el.textContent = Math.floor(counter.val).toString(); },
        });
      });
    }, { threshold: 0.5 });
    io.observe(statsWrap);
  })();

  /* ── FAQ accordion (GSAP height) ── */
  document.addEventListener('DOMContentLoaded', () => {
    /* initialise all answers at height: 0 */
    document.querySelectorAll<HTMLElement>('.faq-a').forEach(a => {
      a.style.overflow = 'hidden';
      gsap.set(a, { height: 0 });
    });

    document.querySelectorAll<HTMLElement>('[data-faq-trigger]').forEach(btn => {
      btn.addEventListener('click', () => {
        const item   = btn.closest<HTMLElement>('.faq-item');
        const answer = item?.querySelector<HTMLElement>('.faq-a');
        const isOpen = item?.classList.contains('open');

        /* close all */
        document.querySelectorAll<HTMLElement>('.faq-item').forEach(i => {
          if (i === item) return;
          const a = i.querySelector<HTMLElement>('.faq-a');
          if (a) gsap.to(a, { height: 0, duration: 0.32, ease: 'power2.inOut' });
          i.classList.remove('open');
          i.querySelector('[data-faq-trigger]')?.setAttribute('aria-expanded', 'false');
        });

        if (!item || !answer) return;
        if (isOpen) {
          gsap.to(answer, { height: 0, duration: 0.32, ease: 'power2.inOut' });
          item.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
        } else {
          const h = answer.scrollHeight;
          gsap.to(answer, { height: h, duration: 0.4, ease: 'power2.out' });
          item.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
</script>

