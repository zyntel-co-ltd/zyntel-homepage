---
// Three.js wireframe geometry — subtle rotating torus in hero background
---
<div id="hero-wireframe-wrap" class="hero-wireframe-wrap" aria-hidden="true"></div>

<script>
  (function initWireframe() {
    const wrap = document.getElementById('hero-wireframe-wrap');
    if (!wrap) return;

    const loadThree = () => {
      if (typeof window !== 'undefined' && (window as any).THREE) {
        init((window as any).THREE);
        return;
      }
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js';
      script.onload = () => init((window as any).THREE);
      document.head.appendChild(script);
    };

    function init(THREE: typeof import('three')) {
      const canvas = document.createElement('canvas');
      wrap.appendChild(canvas);

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(50, 1, 0.1, 1000);
      camera.position.z = 6;

      const geometry = new THREE.TorusGeometry(1.2, 0.08, 16, 64);
      const material = new THREE.MeshBasicMaterial({
        color: 0x00f0ff,
        wireframe: true,
        transparent: true,
        opacity: 0.4,
      });
      const torus = new THREE.Mesh(geometry, material);
      scene.add(torus);

      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      renderer.setPixelRatio(Math.min(2, window.devicePixelRatio));

      function resize() {
        const rect = wrap.getBoundingClientRect();
        const size = Math.min(rect.width, rect.height, 360);
        canvas.width = size;
        canvas.height = size;
        renderer.setSize(size, size);
        camera.aspect = 1;
        camera.updateProjectionMatrix();
      }
      resize();
      window.addEventListener('resize', resize);

      function animate() {
        requestAnimationFrame(animate);
        const t = performance.now() * 0.0008;
        torus.rotation.x = Math.sin(t * 0.5) * 0.15;
        torus.rotation.y = t * 0.6;
        renderer.render(scene, camera);
      }
      animate();
    }

    loadThree();
  })();
</script>

<style>
  .hero-wireframe-wrap {
    position: absolute;
    top: 50%;
    right: 8%;
    width: min(320px, 28vw);
    height: min(320px, 28vw);
    transform: translateY(-50%);
    pointer-events: none;
    z-index: 1;
    opacity: 0.7;
  }
  .hero-wireframe-wrap canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
  @media (max-width: 1024px) {
    .hero-wireframe-wrap {
      top: 30%;
      right: 50%;
      transform: translate(50%, -50%);
      width: min(220px, 35vw);
      height: min(220px, 35vw);
      opacity: 0.5;
    }
  }
  @media (max-width: 640px) {
    .hero-wireframe-wrap { display: none; }
  }
</style>
