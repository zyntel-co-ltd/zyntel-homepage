# Sanity CMS (create project at sanity.io/manage)
PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
PUBLIC_SANITY_DATASET=production

# PostHog product analytics (per-product project; create at app.posthog.com)
# Marketing site uses the "Zyntel Homepage" project.
# Key from: PostHog → Project settings → Project API Key. Host should be the reverse-proxy
# domain (eu.i.posthog.com or us.i.posthog.com) so ad blockers do not nuke the snippet.
PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Neon PostgreSQL (from neon.tech or Vercel integration)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Flutterwave (from dashboard.flutterwave.com)
FLW_SECRET_KEY=FLWSECK-xxx
FLW_VERIFY_HASH=your_webhook_secret_hash

# Site URL (for Astro build; Vercel: Production=zyntel.net, Preview=preview.zyntel.net)
SITE_URL=https://zyntel.net

# Invoicing (optional - for create/record-payment/send APIs)
INVOICE_API_KEY=your_secret_key_here

# Resend (for sending invoices/receipts by email) — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# Must be a sender you verify in Resend (domain or onboarding@resend.dev for testing)
EMAIL_FROM=Zyntel <billing@zyntel.net>

# Payment details (shown on invoice PDF)
INVOICE_BANK_NAME=ABSA Bank
INVOICE_BANK_ACCOUNT=6007816276
INVOICE_ACCOUNT_NAME=Zyntel Ltd
INVOICE_BANK_ADDRESS=Kampala, Uganda
INVOICE_SWIFT_CODE=
INVOICE_PAYMENT_INSTRUCTIONS=Please use invoice number as reference when paying.
