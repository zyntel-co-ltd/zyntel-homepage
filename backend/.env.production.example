# Production .env - copy to .env before running start-production-pm2.bat
# Or use: copy backend\.env.production.example backend\.env

# Database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/zyntel_dashboard_v2

# JWT
JWT_SECRET=your-production-secret-change-this
JWT_EXPIRE=7d

# Server
PORT=5000
NODE_ENV=production
HOST=192.168.10.198
FRONTEND_URL=http://192.168.10.198:5000

# Python - REQUIRED for LabGuru insights. Use full path so PM2/Task Scheduler can find it.
# Find your path: py -3.11 -c "import sys; print(sys.executable)"
PYTHON_PATH=C:\Users\TempAdmin\AppData\Local\Programs\Python\Python311\python.exe

# LIMS (LabGuru SQL Server)
LIMS_DB_DRIVER=SQL Server
LIMS_DB_SERVER=192.168.10.84\MSSQL
LIMS_DB_USER=Analytics
LIMS_DB_PASSWORD=analytics_123
LIMS_DB_KRANIUM=Kranium
LIMS_DB_LABGURU=LabGuruV3

# Paths
PUBLIC_DIR=../frontend/public
SOURCE_FOLDER=\\192.168.10.84\lab_results
