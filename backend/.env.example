# Database
DATABASE_URL=postgresql://username:password@host:5432/zyntel_db
# DATABASE_SSL=true   # Set only if Postgres has SSL. Leave unset for local/VMs without SSL.

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=30d

# Server
PORT=5000
NODE_ENV=development

# Optional: bind to specific IP (e.g. for hospital LAN only). Leave empty to bind to all interfaces.
# HOST=192.168.10.198

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# LIMS Data Fetch Mode: db | scrape | auto
# db = direct SQL Server; scrape = web scraping; auto = try db, fallback to scrape
LIMS_FETCH_MODE=auto

# Direct LIMS DB (LabGuru) - for LIMS_FETCH_MODE=db or auto
# Server: 192.168.10.84\MSSQL (from LabGuru dev)
LIMS_DB_SERVER=192.168.10.84\\MSSQL
LIMS_DB_USER=Analytics
LIMS_DB_PASSWORD=analytics_123
LIMS_DB_KRANIUM=Kranium
LIMS_DB_LABGURU=LabGuruV3
# Column mapping - Labno.InvoiceNo joins Labrequest.invoiceno
# LIMS_DB_DATE_COL=request_date  (from Labrequest)
# LIMS_DB_DRIVER=SQL Server  (or ODBC Driver 17 for SQL Server)
# LIMS_DB_QUERY= custom SQL - overrides default (no params; use {start} {end} in query)

# LIMS Web Scraping (fallback when LIMS_FETCH_MODE=scrape or when DB fails)
LIMS_URL=http://192.168.10.84:8080
LIMS_USERNAME=
LIMS_PASSWORD=

# File Paths
SOURCE_FOLDER=Z:/
PUBLIC_DIR=../frontend/public
OUTPUT_TIMEOUT_CSV_NAME=TimeOut.csv
OUTPUT_DATA_JSON_NAME=data.json
OUTPUT_META_CSV_NAME=meta.csv

# Socket.io
SOCKET_PORT=5001